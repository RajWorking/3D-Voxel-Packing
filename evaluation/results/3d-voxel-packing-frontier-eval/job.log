e(3)]\n                    vol = 1\n                    for i in range(3):\n                        vol *= (new_mx[i] - new_mn[i] + 1)\n                    if vol > max_vol:\n                        continue\n                    placed = set((v[0]+ox, v[1]+oy, v[2]+oz) for v in rotated)\n                    if not (placed & occ):\n                        results.append((p, ox, oy, oz, placed, vol))\n    # Sort by volume (prefer placements that don\'t increase bbox)\n    results.sort(key=lambda r: r[5])\n    return results\n\n# Config: ball at (1,-5,0), 12x17x6=1224\nball_ox, ball_oy = 1, -5\nshift_y = 5\n\noccupied_base = set()\nfor i in range(5):\n    for x,y,z in bowl:\n        occupied_base.add((x, y + shift_y + 2*i, z))\nfor x,y,z in ball:\n    occupied_base.add((x + ball_ox, y, z))\n\nmn = [min(v[i] for v in occupied_base) for i in range(3)]\nmx = [max(v[i] for v in occupied_base) for i in range(3)]\nprint(f"Base: [{mn[0]},{mx[0]}]x[{mn[1]},{mx[1]}]x[{mn[2]},{mx[2]}] = {(mx[0]-mn[0]+1)*(mx[1]-mn[1]+1)*(mx[2]-mn[2]+1)}")\n\nobj_names = [\'donut1\', \'chocolate\', \'donut2\', \'match_box1\', \'match_box2\', \'match_box3\', \'match_box4\']\n\nbest_result = None\nbest_vol = 1440\n\nfor trial in range(500):\n    order = obj_names[:]\n    if trial > 1:\n        random.shuffle(order)\n    elif trial == 1:\n        order = list(reversed(obj_names))\n    \n    remaining = occupied_base.copy()\n    cur_mn = list(mn)\n    cur_mx = list(mx)\n    placements = {}\n    success = True\n    \n    for name in order:\n        obj = small_objects[name]\n        valid = find_placements_flex(obj, remaining, best_vol, cur_mn, cur_mx)\n        if valid:\n            p, ox, oy, oz, placed, vol = valid[0]\n            remaining |= placed\n            placements[name] = (p, ox, oy, oz)\n            for i in range(3):\n                cur_mn[i] = min(cur_mn[i], min(v[i] for v in placed))\n                cur_mx[i] = max(cur_mx[i], max(v[i] for v in placed))\n        else:\n            success = False\n            break\n    \n    if success:\n        vol = 1\n        for i in range(3):\n            vol *= (cur_mx[i] - cur_mn[i] + 1)\n        if vol < best_vol:\n            best_vol = vol\n            best_result = (placements.copy(), list(cur_mn), list(cur_mx))\n            dims = [cur_mx[i]-cur_mn[i]+1 for i in range(3)]\n            print(f"Trial {trial}: vol={vol}, dims={dims[0]}x{dims[1]}x{dims[2]}, order={order}")\n\nif best_result:\n    placements, final_mn, final_mx = best_result\n    dims = [final_mx[i]-final_mn[i]+1 for i in range(3)]\n    print(f"\\n=== BEST: {dims[0]}x{dims[1]}x{dims[2]}={best_vol} ===")\n    # Compute actual offsets (shift so min=0)\n    shift = [-final_mn[i] for i in range(3)]\n    print(f"Shift: {shift}")\n    print(f"Ball: xyz +++ offset=({ball_ox+shift[0]},{shift[1]},{shift[2]})")\n    for i in range(5):\n        print(f"Bowl{i+1}: xyz +++ offset=({shift[0]},{shift_y+2*i+shift[1]},{shift[2]})")\n    for name in obj_names:\n        p, ox, oy, oz = placements[name]\n        pname = perm_names[perms_list.index(p)]\n        print(f"{name}: {pname} +++ offset=({ox+shift[0]},{oy+shift[1]},{oz+shift[2]})")\nelse:\n    print("No improvement found")\n\nPYEOF\npython3 /tmp/solve14.py\n'] min_timeout_sec: 60.0 max_timeout_sec: 180.0
