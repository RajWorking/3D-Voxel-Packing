Sending keys: ["python3 - <<'PY'\nimport json,itertools\nwith open('/task/objects.json') as f:\n    data=json.load(f)\nobjs={}\nfor name,obj in data.items():\n    pts=[]\n    for arr in obj.values(): pts.extend(map(tuple,arr))\n    objs[name]=sorted(set(pts))\nperms=['xyz','xzy','yxz','yzx','zxy','zyx']\nsigns=[''.join(s) for s in itertools.product('+-', repeat=3)]\n\ndef transf(pts,perm,sign):\n    out=[]\n    for x,y,z in pts:\n        d={'x':x,'y':y,'z':z}\n        q=[d[perm[i]] for i in range(3)]\n        q=[q[i] if sign[i]=='+' else -q[i] for i in range(3)]\n        out.append(tuple(q))\n    mins=[min(p[i] for p in out) for i in range(3)]\n    out=tuple(sorted((p[0]-mins[0],p[1]-mins[1],p[2]-mins[2]) for p in out))\n    dims=(max(p[0] for p in out)+1,max(p[1] for p in out)+1,max(p[2] for p in out)+1)\n    return out,dims\norients={}\nfor name,pts in objs.items():\n    seen={}\n    for perm in perms:\n        for sign in signs:\n            out,dims=transf(pts,perm,sign)\n            seen.setdefault(out,(perm,sign,dims))\n    orients[name]=[(v[0],v[1],v[2]) for k,v in seen.items()]\nboxes=[(12,12,10),(15,12,8),(16,10,9),(18,10,8),(20,9,8),(20,12,6),(24,10,6),(16,12,8),(18,12,7)]\nfor box in boxes:\n    print('\\nBOX',box,'vol',box[0]*box[1]*box[2])\n    total=0\n    for name in sorted(objs,key=lambda n:-len(objs[n])):\n        c=0\n        bydims={}\n        for perm,sign,dims in orients[name]:\n            n=max(0,box[0]-dims[0]+1)*max(0,box[1]-dims[1]+1)*max(0,box[2]-dims[2]+1)\n            if n:\n                bydims[dims]=bydims.get(dims,0)+n\n                c+=n\n        total+=c\n        print(f'{name:10s} placements={c:6d} dims={sorted(bydims.items())}')\n    print('total placements',total)\nPY\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
