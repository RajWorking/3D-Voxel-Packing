ve(q)\n    return False\n\nvol=108*N\ncands=[]\nfor X in range(4,25):\n  for Y in range(4,25):\n    for Z in range(4,25):\n      if X*Y*Z<vol: continue\n      cands.append((X*Y*Z,(X,Y,Z)))\nfor v,box in sorted(cands)[:250]:\n    print('try',box,'vol',v)\n    occ=set(); placements=[]\n    if search(box,0,occ,placements,set()):\n        print('FOUND',box,v)\n        for i,p in enumerate(placements,1): print('bowl',i,p)\n        break\nelse:\n    print('none found in time')\nPY\n"] min_timeout_sec: 30.0 max_timeout_sec: 180.0
