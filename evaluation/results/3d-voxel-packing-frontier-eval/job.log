p at y=1: bowl has x=0,1,10,11; ball has x=2,3,4,5,6,7 -> NO overlap!\n\n# So flipped bowl at dy=-2 works with ball!\n# Combined y range: -2 to 7 = 10 units\n\n# Now add normal bowls below ball:\n# Normal bowl at y=6: y=6..9\n# Normal bowl at y=8: y=8..11\n# etc.\n\n# Let\'s try: 1 flipped bowl above + 4 normal bowls below\n# Flipped bowl: y=-2..1\n# Ball: y=0..7\n# Normal bowls: y=6,8,10,12 -> y=6..15\n# Total y: -2..15 = 18 units\n# x: 0..11 = 12 units\n# Volume: 12x18x6 = 1296\n\n# But we still need donut1! Let\'s check if it fits.\noccupied = set()\noccupied |= ball_v\n\n# Flipped bowl at dy=-2\nfor x,y in flipped_bowl_xy:\n    for z in range(6):\n        occupied.add((x, y-2, z))\n\n# 4 normal bowls at y=6,8,10,12\nfor i in range(4):\n    for x,y,z in bowl_v:\n        occupied.add((x, y + 6 + i*2, z))\n\nmin_y = min(y for x,y,z in occupied)\nmax_y = max(y for x,y,z in occupied)\nmin_x = min(x for x,y,z in occupied)\nmax_x = max(x for x,y,z in occupied)\nprint(f"1 flipped + 4 normal bowls + ball:")\nprint(f"  x: {min_x}..{max_x}, y: {min_y}..{max_y}")\nprint(f"  Size: {max_x-min_x+1}x{max_y-min_y+1}x6")\nprint(f"  Voxels: {len(occupied)}")\n\n# Normalize to non-negative\nif min_y < 0 or min_x < 0:\n    shift_x = -min_x if min_x < 0 else 0\n    shift_y = -min_y if min_y < 0 else 0\n    occupied = set((x+shift_x, y+shift_y, z) for x,y,z in occupied)\n    print(f"  After normalization: x={min_x+shift_x}..{max_x+shift_x}, y={min_y+shift_y}..{max_y+shift_y}")\n\nw = max(x for x,y,z in occupied) + 1\nh = max(y for x,y,z in occupied) + 1\nd = 6\nprint(f"  Bbox: {w}x{h}x{d} = {w*h*d}")\n\n# Check donut1\ndonut1_v = get_voxels_normalized(\'donut1\')\nperms_list = [\'xyz\',\'xzy\',\'yxz\',\'yzx\',\'zxy\',\'zyx\']\n\ncount = 0\nfor perm in perms_list:\n    for signs in product(\'+-\', repeat=3):\n        signs_str = \'\'.join(signs)\n        transformed = transform_voxels(donut1_v, perm, signs_str)\n        sx = max(v[0] for v in transformed) + 1\n        sy = max(v[1] for