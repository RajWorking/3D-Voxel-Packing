Sending keys: ['python3 << \'EOF\'\nimport json\nfrom itertools import product\n\nwith open(\'/task/objects.json\') as f:\n    data = json.load(f)\n\ndef get_voxels(name):\n    voxels = set()\n    for group in data[name].values():\n        for v in group:\n            voxels.add(tuple(v))\n    return voxels\n\ndef transform_voxels(voxels, perm, signs):\n    pmap = {\'x\':0, \'y\':1, \'z\':2}\n    new_voxels = set()\n    for v in voxels:\n        nv = [0,0,0]\n        for i, c in enumerate(perm):\n            val = v[pmap[c]]\n            if signs[i] == \'-\':\n                val = -val\n            nv[i] = val\n        new_voxels.add(tuple(nv))\n    mx = min(v[0] for v in new_voxels)\n    my = min(v[1] for v in new_voxels)\n    mz = min(v[2] for v in new_voxels)\n    return set((x-mx, y-my, z-mz) for x,y,z in new_voxels)\n\n# Build occupied set: ball + 5 bowls\nbowl_v = get_voxels(\'bowl1\')\nball_v = get_voxels(\'ball\')\n\noccupied = set()\noccupied |= ball_v\nfor i in range(5):\n    for x,y,z in bowl_v:\n        occupied.add((x, y + 6 + i*2, z))\n\nprint(f"After ball + 5 bowls: {len(occupied)} voxels occupied")\n\n# Small objects to place\nsmall_objects = [\'donut1\', \'donut2\', \'chocolate\', \'match_box1\', \'match_box2\', \'match_box3\', \'match_box4\']\n\nperms = [\'xyz\',\'xzy\',\'yxz\',\'yzx\',\'zxy\',\'zyx\']\n\ndef find_best_placement(obj_name, occupied_set, max_dims=(12,18,6)):\n    """Find placement that fits within max_dims and doesn\'t collide."""\n    obj_v = get_voxels(obj_name)\n    best = None\n    best_score = 99999\n    \n    for perm in perms:\n        for signs in product(\'+-\', repeat=3):\n            signs_str = \'\'.join(signs)\n            transformed = transform_voxels(obj_v, perm, signs_str)\n            sx = max(v[0] for v in transformed) + 1\n            sy = max(v[1] for v in transformed) + 1\n            sz = max(v[2] for v in transformed) + 1\n            \n            if sx > max_dims[0] or sy > max_dims[1] or sz > max_dims[2]:\n                continue\n            \n            for ox in range(max_dims[0] - sx + 1):\n                for oy in range(max_dims[1] - sy + 1):\n                    for oz in range(max_dims[2] - sz + 1):\n                        placed = set((x+ox, y+oy, z+oz) for x,y,z in transformed)\n                        if not (placed & occupied_set):\n                            # Score: prefer placements that use less new bounding box\n                            score = ox + oy + oz  # simple heuristic\n                            if score < best_score:\n                                best_score = score\n                                best = (perm, signs_str, ox, oy, oz, placed)\n                                # Early exit for first valid\n                                return best\n    return best\n\n# Try placing objects in order (largest first)\nfor obj_name in [\'donut1\', \'chocolate\', \'donut2\', \'match_box1\', \'match_box2\', \'match_box3\', \'match_box4\']:\n    result = find_best_placement(obj_name, occupied)\n    if result:\n        perm, signs, ox, oy, oz, placed = result\n        occupied |= placed\n        obj_v = get_voxels(obj_name)\n        transformed = transform_voxels(obj_v, perm, signs)\n        sx = max(v[0] for v in transformed) + 1\n        sy = max(v[1] for v in transformed) + 1\n        sz = max(v[2] for v in transformed) + 1\n        print(f"{obj_name}: perm={perm} signs={signs} offset=({ox},{oy},{oz}) size={sx}x{sy}x{sz}")\n    else:\n        print(f"{obj_name}: DOES NOT FIT!")\n\n# Final check\nmin_x = min(v[0] for v in occupied)\nmax_x = max(v[0] for v in occupied)\nmin_y = min(v[1] for v in occupied)\nmax_y = max(v[1] for v in occupied)\nmin_z = min(v[2] for v in occupied)\nmax_z = max(v[2] for v in occupied)\nw = max_x - min_x + 1\nh = max_y - min_y + 1\nd = max_z - min_z + 1\nprint(f"\\nFinal bounding box: {w}x{h}x{d} = {w*h*d}")\nprint(f"Total voxels: {len(occupied)}")\nEOF\n'] min_timeout_sec: 60.0 max_timeout_sec: 180.0
