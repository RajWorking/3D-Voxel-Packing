.shuffle(syms)\n            \n            for sym_voxels, perm_str, signs_str, obj_grid in syms:\n                sx, sy, sz = obj_grid.shape\n                if sx > BOX_X or sy > BOX_Y or sz > BOX_Z:\n                    continue\n                    \n                valid_positions = []\n                for x in range(BOX_X - sx + 1):\n                    for y in range(BOX_Y - sy + 1):\n                        for z in range(BOX_Z - sz + 1):\n                            if not np.any(grid[x:x+sx, y:y+sy, z:z+sz] & obj_grid):\n                                valid_positions.append((x, y, z))\n                \n                if valid_positions:\n                    valid_positions.sort(key=lambda p: max(p[0]+sx, p[1]+sy, p[2]+sz))\n                    x, y, z = random.choice(valid_positions[:3])\n                    \n                    grid[x:x+sx, y:y+sy, z:z+sz] |= obj_grid\n                    placements[name] = (perm_str, signs_str, x, y, z)\n                    placed = True\n                    break\n                    \n            if not placed:\n                success = False\n                break\n                \n        if success:\n            print(f"  Found packing in {iterations} iterations!")\n            return placements\n    return None\n\nbest_placements = None\nbest_vol = float(\'inf\')\n\nfor box in [(12, 12, 10), (12, 12, 9), (12, 11, 9), (12, 10, 9), (12, 12, 8), (12, 11, 8), (12, 10, 8)]:\n    print(f"Trying {box}...")\n    placements = try_pack(*box, timeout=15)\n    if placements:\n        vol = box[0] * box[1] * box[2]\n        print(f"Success! Volume: {vol}")\n        if vol < best_vol:\n            best_vol = vol\n            best_placements = placements\n            with open(\'solution_cmds.sh\', \'w\') as f:\n                for name, (perm, signs, x, y, z) in best_placements.items():\n                    f.write(f"python3 /task/tools/place_object.py {name} {perm} {signs} {x} {y} {z}\\n")\n                f.write("python