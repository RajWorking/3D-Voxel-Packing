Sending keys: ["python3 - <<'PY'\nimport json,itertools,math,time\nfrom collections import defaultdict\n\nwith open('/task/objects.json') as f:\n    data=json.load(f)\nobjs={}\nfor name,obj in data.items():\n    pts=[]\n    for arr in obj.values(): pts.extend(map(tuple,arr))\n    objs[name]=sorted(set(pts))\n\nperms=['xyz','xzy','yxz','yzx','zxy','zyx']\nsigns=[''.join(s) for s in itertools.product('+-', repeat=3)]\n\ndef transf(pts,perm,sign):\n    out=[]\n    for x,y,z in pts:\n        d={'x':x,'y':y,'z':z}\n        q=[d[perm[i]] for i in range(3)]\n        q=[q[i] if sign[i]=='+' else -q[i] for i in range(3)]\n        out.append(tuple(q))\n    mins=[min(p[i] for p in out) for i in range(3)]\n    out=sorted((p[0]-mins[0],p[1]-mins[1],p[2]-mins[2]) for p in out)\n    dims=(max(p[0] for p in out)+1,max(p[1] for p in out)+1,max(p[2] for p in out)+1)\n    return tuple(out),dims\n\norients={}\nfor name,pts in objs.items():\n    seen={}\n    for perm in perms:\n        for sign in signs:\n            out,dims=transf(pts,perm,sign)\n            seen.setdefault(out,(perm,sign,dims))\n    orients[name]=[(v[0],v[1],v[2],list(k)) for k,v in seen.items()]\n    print(name, len(orients[name]), 'unique orientations', sorted(set(o[2] for o in orients[name])))\n\nnames=sorted(objs, key=lambda n:(-len(objs[n]), len(orients[n])))\nprint('order', names)\n\n# search candidate overall boxes in increasing volume\nvol=sum(len(v) for v in objs.values())\nprint('total voxels',vol)\n\n# occupancy and placement search using bottom-left-near candidate points\nbest=None\nstart=time.time()\n\ndef search(box, idx, occ, placements, frontier):\n    global best\n    if time.time()-start>25:\n        return False\n    if idx==len(names):\n        best=placements.copy()\n        return True\n    name=names[idx]\n    opts=orients[name]\n    # try larger objects with fewer candidate placements first\n    tried=[]\n    cand_points=sorted(frontier | {(0,0,0)}, key=lambda p:(p[2],p[1],p[0]))[:120]\n    for perm,sign,dims,pts in sorted(opts, key=lambda t:t[2][2]*10000+t[2][1]*100+t[2][0]):\n        dx,dy,dz=dims\n        for ox,oy,oz in cand_points:\n            if ox+dx>box[0] or oy+dy>box[1] or oz+dz>box[2]:\n                continue\n            placed=[]\n            ok=True\n            for x,y,z in pts:\n                q=(x+ox,y+oy,z+oz)\n                if q in occ:\n                    ok=False; break\n                placed.append(q)\n            if not ok:\n                continue\n            for p in placed: occ.add(p)\n            nf=set(frontier)\n            nf.add((ox+dx,oy,oz)); nf.add((ox,oy+dy,oz)); nf.add((ox,oy,oz+dz))\n            placements[name]=(perm,sign,ox,oy,oz)\n            if search(box, idx+1, occ, placements, nf):\n                return True\n            del placements[name]\n            for p in placed: occ.remove(p)\n    return False\n\ncands=[]\nfor X in range(10,25):\n  for Y in range(8,25):\n    for Z in range(6,25):\n      if X*Y*Z<vol: continue\n      if max(X,Y,Z)<12: continue\n      cands.append((X*Y*Z,(X,Y,Z)))\nfor _,box in sorted(cands)[:400]:\n    if time.time()-start>28: break\n    print('try box',box,'vol',box[0]*box[1]*box[2])\n    if search(box,0,set(),{},set()):\n        print('FOUND',box,box[0]*box[1]*box[2])\n        for n in names:\n            print(n,best[n])\n        break\nelse:\n    print('no solution found in time')\nPY\n"] min_timeout_sec: 30.0 max_timeout_sec: 180.0
Sending keys: ['python3 -c "\nimport json\nwith open(\'/task/objects.json\') as f:\n    data = json.load(f)\n\n# Analyze bowl shape in XY (it\'s the same for all z)\nbowl_voxels = []\nfor group in data[\'bowl1\'].values():\n    for v in group:\n        bowl_voxels.append(tuple(v))\n\n# Get unique XY positions\nxy = set()\nfor x,y,z in bowl_voxels:\n    xy.add((x,y))\n\nprint(\'Bowl XY footprint:\')\nfor y in range(4):\n    row = \'\'\n    for x in range(12):\n        if (x,y) in xy:\n            row += \'#\'\n        else:\n            row += \'.\'\n    print(f\'  y={y}: {row}\')\n\n# Analyze ball shape per layer\nball_voxels = []\nfor group in data[\'ball\'].values():\n    for v in group:\n        ball_voxels.append(tuple(v))\n\nprint(f\'\\nBall total voxels: {len(ball_voxels)}\')\nfor z in range(6):\n    layer = [(x,y) for x,y,zz in ball_voxels if zz==z]\n    print(f\'\\nBall z={z} ({len(layer)} voxels):\')\n    for y in range(8):\n        row = \'\'\n        for x in range(10):\n            if (x,y) in layer:\n                row += \'#\'\n            else:\n                row += \'.\'\n        print(f\'  y={y}: {row}\')\n"\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
