Sending keys: ["python3 - <<'PY'\nimport json,itertools,time\nwith open('/task/objects.json') as f:\n    data=json.load(f)\nobjs={}\nfor name,obj in data.items():\n    pts=[]\n    for arr in obj.values(): pts.extend(map(tuple,arr))\n    objs[name]=sorted(set(pts))\nperms=['xyz','xzy','yxz','yzx','zxy','zyx']\nsigns=[''.join(s) for s in itertools.product('+-', repeat=3)]\nbox=(24,10,6)\n\ndef transf(pts,perm,sign):\n    out=[]\n    for x,y,z in pts:\n        d={'x':x,'y':y,'z':z}\n        q=[d[perm[i]] for i in range(3)]\n        q=[q[i] if sign[i]=='+' else -q[i] for i in range(3)]\n        out.append(tuple(q))\n    mins=[min(p[i] for p in out) for i in range(3)]\n    out=tuple(sorted((p[0]-mins[0],p[1]-mins[1],p[2]-mins[2]) for p in out))\n    dims=(max(p[0] for p in out)+1,max(p[1] for p in out)+1,max(p[2] for p in out)+1)\n    return out,dims\n# unique orientations\norients={}\nfor name,pts in objs.items():\n    seen={}\n    for perm in perms:\n        for sign in signs:\n            out,dims=transf(pts,perm,sign)\n            seen.setdefault(out,(perm,sign,dims))\n    orients[name]=[(v[0],v[1],v[2],k) for k,v in seen.items()]\n# candidate placements\nplacements={}\nfor name in objs:\n    lst=[]\n    for perm,sign,dims,pts in orients[name]:\n        dx,dy,dz=dims\n        if dx>box[0] or dy>box[1] or dz>box[2]:\n            continue\n        for ox in range(box[0]-dx+1):\n            for oy in range(box[1]-dy+1):\n                for oz in range(box[2]-dz+1):\n                    vox=tuple((x+ox,y+oy,z+oz) for x,y,z in pts)\n                    lst.append((perm,sign,ox,oy,oz,dims,vox))\n    placements[name]=lst\n    print(name,len(lst))\norder=sorted(objs,key=lambda n: len(placements[n]))\nprint('order',order)\nstart=time.time(); best=None\n# occupancy index from voxel to candidate ids not built; use recursion with frontier anchors\n\ndef search(i, occ, ans):\n    global best\n    if time.time()-start>55: return False\n    if i==len(order):\n        best=ans.copy(); return True\n    name=order[i]\n    # choose lexicographically lowest empty cell as anchor if any occupancy exists\n    anchor=None\n    if occ:\n        for z in range(box[2]):\n            for y in range(box[1]):\n                for x in range(box[0]):\n                    if (x,y,z) not in occ:\n                        anchor=(x,y,z); break\n                if anchor: break\n            if anchor: break\n    cand=placements[name]\n    # prefer placements near origin and intersecting anchor neighborhood if possible\n    cand2=[]\n    for p in cand:\n        vox=p[6]\n        s=set(vox)\n        if any(v in occ for v in vox):\n            continue\n        score=(p[4],p[3],p[2])\n        if anchor is None or anchor in s:\n            cand2.append((0,score,p))\n        else:\n            ax,ay,az=anchor\n            md=min(abs(x-ax)+abs(y-ay)+abs(z-az) for x,y,z in vox)\n            cand2.append((1+md,score,p))\n    cand2.sort(key=lambda t:(t[0],t[1]))\n    for _,_,p in cand2[:400]:\n        perm,sign,ox,oy,oz,dims,vox=p\n        for v in vox: occ.add(v)\n        ans[name]=(perm,sign,ox,oy,oz)\n        if search(i+1,occ,ans): return True\n        del ans[name]\n        for v in vox: occ.remove(v)\n    return False\n\nok=search(0,set(),{})\nprint('ok',ok,'elapsed',time.time()-start)\nif ok:\n    for n in order:\n        print(n,best[n])\nPY\n"] min_timeout_sec: 60.0 max_timeout_sec: 180.0
