int(f"Occupied: {len(occupied)}")\n\n# Visualize per z-layer\nfor z in [0, 2]:\n    print(f"\\nz={z}:")\n    for y in range(17):\n        row = \'\'.join(\'#\' if (x,y,z) in occupied else \'.\' for x in range(12))\n        print(f"  y={y:2d}: {row}")\n\n# Now try to fit small objects\nprint("\\n=== Fitting small objects ===")\nperms_list = [(0,1,2),(0,2,1),(1,0,2),(1,2,0),(2,0,1),(2,1,0)]\n\ndef try_place(obj_voxels, occupied_set, bbox=(12,17,6)):\n    results = []\n    for p in perms_list:\n        rotated = apply_perm(obj_voxels, p)\n        rdims = [max(v[i] for v in rotated)+1 for i in range(3)]\n        if rdims[0] > bbox[0] or rdims[1] > bbox[1] or rdims[2] > bbox[2]:\n            continue\n        for ox in range(bbox[0] - rdims[0] + 1):\n            for oy in range(bbox[1] - rdims[1] + 1):\n                for oz in range(bbox[2] - rdims[2] + 1):\n                    placed = set((v[0]+ox, v[1]+oy, v[2]+oz) for v in rotated)\n                    if not (placed & occupied_set):\n                        results.append((p, ox, oy, oz, placed))\n    return results\n\nsmall_objects = {\n    \'chocolate\': get_voxels(\'chocolate\'),\n    \'donut1\': get_voxels(\'donut1\'),\n    \'donut2\': get_voxels(\'donut2\'),\n    \'match_box1\': get_voxels(\'match_box1\'),\n    \'match_box2\': get_voxels(\'match_box2\'),\n    \'match_box3\': get_voxels(\'match_box3\'),\n    \'match_box4\': get_voxels(\'match_box4\'),\n}\n\nremaining = occupied.copy()\nplacements = {}\norder = [\'donut1\', \'chocolate\', \'donut2\', \'match_box1\', \'match_box2\', \'match_box3\', \'match_box4\']\n\nfor name in order:\n    obj = small_objects[name]\n    valid = try_place(obj, remaining, (12, 17, 6))\n    if valid:\n        p, ox, oy, oz, placed = valid[0]\n        remaining |= placed\n        placements[name] = (p, ox, oy, oz)\n        print(f"Placed {name}: perm={p}, offset=({ox},{oy},{oz})")\n    else:\n        print(f"FAILED to place {name}!")\n\nprint(f"\\nTotal placed: {len(remaining)} voxels")\nprint(f"Volume: 12x17x6 = {12*17*6}")\n\n# Print placement summary for tool commands\nprint("\\n=== Placement commands ===")\nprint("Bowl placements (identity xyz +++):") \nfor i in range(5):\n    print(f"  bowl{i+1}: offset (0, {5+2*i}, 0)")\nprint(f"  ball: offset (1, 0, 0)")\nfor name in order:\n    if name in placements:\n        p, ox, oy, oz = placements[name]\n        pname = [\'xyz\',\'xzy\',\'yxz\',\'yzx\',\'zxy\',\'zyx\'][perms_list.index(p)]\n        print(f"  {name}: perm={pname} offset ({ox},{oy},{oz})")\n\nPYEOF\npython3 /tmp/solve11.py\n'] min_timeout_sec: 30.0 max_timeout_sec: 180.0
