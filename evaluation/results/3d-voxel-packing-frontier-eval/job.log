ment with vol <= 1296...")\n\nbest_vol = 1296\nbest_config = None\n\n# Try different ball positions relative to 5-bowl stack\nfor ball_ox in range(-1, 3):\n    for ball_oy in range(-8, 0):\n        # Build base\n        shift_y = -ball_oy\n        occupied = set()\n        for i in range(5):\n            for x,y,z in bowl:\n                occupied.add((x, y + shift_y + 2*i, z))\n        ball_v = set((x + ball_ox, y, z) for x,y,z in ball)\n        \n        if occupied & ball_v:\n            continue\n        \n        occupied |= ball_v\n        mn = [min(v[i] for v in occupied) for i in range(3)]\n        mx = [max(v[i] for v in occupied) for i in range(3)]\n        base_dims = [mx[i]-mn[i]+1 for i in range(3)]\n        base_vol = base_dims[0]*base_dims[1]*base_dims[2]\n        \n        if base_vol > best_vol:\n            continue\n        \n        # Normalize\n        occupied = set((v[0]-mn[0], v[1]-mn[1], v[2]-mn[2]) for v in occupied)\n        bbox = tuple(base_dims)\n        \n        # Try placing all small objects (donut1 first since it\'s hardest)\n        obj_names = [\'donut1\', \'chocolate\', \'donut2\', \'match_box1\', \'match_box2\', \'match_box3\', \'match_box4\']\n        \n        for trial in range(50):\n            if trial == 0:\n                order = obj_names[:]\n            elif trial == 1:\n                order = list(reversed(obj_names))\n            else:\n                order = obj_names[:]\n                random.shuffle(order)\n            \n            remaining = occupied.copy()\n            placements = {}\n            success = True\n            \n            for name in order:\n                obj = small_objects[name]\n                valid = find_placements(obj, remaining, bbox)\n                if valid:\n                    p, ox, oy, oz, placed = valid[0]\n                    remaining |= placed\n                    placements[name] = (p, ox, oy, oz)\n                else:\n                    success = False\n                    break\n            \n            if success:\n                vol = bbox[0]*bbox[1]*bbox[2]\n                if vol < best_vol:\n                    best_vol = vol\n                    best_config = (ball_ox, ball_oy, shift_y, bbox, placements, mn)\n                    print(f"  Found: ball=({ball_ox},{ball_oy}), {bbox[0]}x{bbox[1]}x{bbox[2]}={vol}")\n                elif vol == best_vol and best_config is None:\n                    best_config = (ball_ox, ball_oy, shift_y, bbox, placements, mn)\n                    print(f"  Found: ball=({ball_ox},{ball_oy}), {bbox[0]}x{bbox[1]}x{bbox[2]}={vol}")\n                break\n\nif best_config:\n    ball_ox, ball_oy, shift_y, bbox, placements, orig_mn = best_config\n    print(f"\\n=== BEST: {bbox[0]}x{bbox[1]}x{bbox[2]}={best_vol} ===")\n    print(f"Ball: xyz +++ offset=({ball_ox-orig_mn[0]},{-orig_mn[1]},{-orig_mn[2]})")\n    for i in range(5):\n        print(f"Bowl{i+1}: xyz +++ offset=({-orig_mn[0]},{shift_y+2*i-orig_mn[1]},{-orig_mn[2]})")\n    for name in [\'donut1\',\'chocolate\',\'donut2\',\'match_box1\',\'match_box2\',\'match_box3\',\'match_box4\']:\n        p, ox, oy, oz = placements[name]\n        pname = perm_names[perms_list.index(p)]\n        print(f"{name}: {pname} +++ offset=({ox},{oy},{oz})")\nelse:\n    print("No solution found <= 1296")\n\nPYEOF\npython3 /tmp/solve15.py\n'] min_timeout_sec: 60.0 max_timeout_sec: 180.0
