Sending keys: ['cat > /tmp/solve6.py << \'PYEOF\'\nimport json\n\nwith open(\'/task/objects.json\') as f:\n    data = json.load(f)\n\ndef get_voxels(name):\n    voxels = set()\n    for group in data[name].values():\n        for v in group:\n            voxels.add(tuple(v))\n    min_x = min(v[0] for v in voxels)\n    min_y = min(v[1] for v in voxels)\n    min_z = min(v[2] for v in voxels)\n    return set((x-min_x, y-min_y, z-min_z) for x,y,z in voxels)\n\ndef apply_perm(voxels, p):\n    transformed = set((v[p[0]], v[p[1]], v[p[2]]) for v in voxels)\n    mn = [min(v[i] for v in transformed) for i in range(3)]\n    return set((v[0]-mn[0], v[1]-mn[1], v[2]-mn[2]) for v in transformed)\n\nbowl = get_voxels(\'bowl1\')\nball = get_voxels(\'ball\')\n\n# Build occupied set: 5 bowls stacked + ball\noccupied = set()\nfor i in range(5):\n    for x,y,z in bowl:\n        occupied.add((x, y + 2*i, z))\nfor x,y,z in ball:\n    occupied.add((x, y + 12, z))\n\n# Empty spaces in 12x20x6\nempty = set()\nfor x in range(12):\n    for y in range(20):\n        for z in range(6):\n            if (x,y,z) not in occupied:\n                empty.add((x,y,z))\n\nprint(f"Total empty: {len(empty)}")\n\n# Small objects to place:\nsmall_objects = {\n    \'chocolate\': get_voxels(\'chocolate\'),  # 6x4x1, 24 voxels\n    \'donut1\': get_voxels(\'donut1\'),        # 8x4x1, 28 voxels\n    \'donut2\': get_voxels(\'donut2\'),        # 6x4x1, 20 voxels\n    \'match_box1\': get_voxels(\'match_box1\'),# 3x2x3, 18 voxels\n    \'match_box2\': get_voxels(\'match_box2\'),\n    \'match_box3\': get_voxels(\'match_box3\'),\n    \'match_box4\': get_voxels(\'match_box4\'),\n}\n\nperms_list = [(0,1,2),(0,2,1),(1,0,2),(1,2,0),(2,0,1),(2,1,0)]\n\ndef try_place(obj_voxels, occupied_set, bbox=(12,20,6)):\n    """Try all orientations and positions within bbox. Return list of valid placements."""\n    results = []\n    for p in perms_list:\n        rotated = apply_perm(obj_voxels, p)\n        rdims = [max(v[i] for v in rotated)+1 for i in range(3)]\n        for ox in range(bbox[0] - rdims[0] + 1):\n            for oy in range(bbox[1] - rdims[1] + 1):\n                for oz in range(bbox[2] - rdims[2] + 1):\n                    placed = set((v[0]+ox, v[1]+oy, v[2]+oz) for v in rotated)\n                    if not (placed & occupied_set):\n                        results.append((p, ox, oy, oz, placed))\n    return results\n\n# Try to place all small objects greedily (largest first)\nremaining = occupied.copy()\nplacements = {}\n\n# Order: donut1 (28), chocolate (24), donut2 (20), match_boxes (18 each)\norder = [\'donut1\', \'chocolate\', \'donut2\', \'match_box1\', \'match_box2\', \'match_box3\', \'match_box4\']\n\nfor name in order:\n    obj = small_objects[name]\n    valid = try_place(obj, remaining, (12, 20, 6))\n    if valid:\n        # Pick the first valid placement\n        p, ox, oy, oz, placed = valid[0]\n        remaining |= placed\n        placements[name] = (p, ox, oy, oz)\n        print(f"Placed {name}: perm={p}, offset=({ox},{oy},{oz}), {len(placed)} voxels")\n    else:\n        print(f"FAILED to place {name}!")\n\nprint(f"\\nTotal placed: {len(remaining)} voxels")\nprint(f"Remaining empty: {12*20*6 - len(remaining)}")\n\nPYEOF\npython3 /tmp/solve6.py\n'] min_timeout_sec: 60.0 max_timeout_sec: 180.0
