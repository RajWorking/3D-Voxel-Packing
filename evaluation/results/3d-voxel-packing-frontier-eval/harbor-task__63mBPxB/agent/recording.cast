[15.579695, "i", "cat << 'EOF' > inspect_all.py\nimport json\nwith open('/task/objects.json') as f:\n    objs = json.load(f)\nfor name, obj in objs.items():\n    voxels = []\n    for group in obj.values():\n        voxels.extend(group)\n    min_x = min(v[0] for v in voxels)\n    max_x = max(v[0] for v in voxels)\n    min_y = min(v[1] for v in voxels)\n    max_y = max(v[1] for v in voxels)\n    min_z = min(v[2] for v in voxels)\n    max_z = max(v[2] for v in voxels)\n    print(f\"{name:12}: {max_x-min_x+1}x{max_y-min_y+1}x{max_z-min_z+1} (vol: {(max_x-min_x+1)*(max_y-min_y+1)*(max_z-min_z+1)}), voxels: {len(voxels)}\")\nEOF\npython3 inspect_all.py\n"]
