[144.672222, "i", "       \n                orientations.append({\n                    'perm': perm_str,\n                    'signs': signs_str,\n                    'mask': mask_dict,\n                    'dx': max_x + 1,\n                    'dy': max_y + 1,\n                    'dz': max_z + 1\n                })\n    return orientations\n\nobj_orientations = {name: get_orientations(voxels) for name, voxels in flat_objs.items()}\n\nordered_names = sorted(flat_objs.keys(), key=lambda k: len(flat_objs[k]), reverse=True)\n\nfor name in ordered_names:\n    if not obj_orientations[name]:\n        print(f\"Object {name} cannot fit in {W}x{H}x{D}\")\n        sys.exit(1)\n\ngrid = [[0] * H for _ in range(D)]\nsolution = {}\n\ndef solve(idx):\n    if idx == len(ordered_names):\n        return True\n    \n    name = ordered_names[idx]\n    for ori in obj_orientations[name]:\n        mask = ori['mask']\n        dx, dy, dz = ori['dx'], ori['dy'], ori['dz']\n        \n        for z_off in range(D - dz + 1):\n            for y_off in range(H - dy + 1):\n                for"]
