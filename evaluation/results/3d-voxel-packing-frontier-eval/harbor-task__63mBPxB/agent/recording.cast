[197.325399, "i", "for h in {8..12}; do\n  for d in {8..12}; do\n    if [ $h -ge $d ]; then\n      vol=$((12 * h * d))\n      if [ $vol -ge 1004 ]; then\n        echo \"Trying 12x${h}x${d} (vol $vol)\"\n        python3 solver.py 12 $h $d\n      fi\n    fi\n  done\ndone\n"]
