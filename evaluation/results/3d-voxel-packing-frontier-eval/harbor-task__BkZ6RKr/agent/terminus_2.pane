}

def try_place_all(occupied, bbox, obj_names):
    """Try to place all objects using backtracking with different orderings."""
    def find_placements(obj_voxels, occ, bbox):
        results = []
        for p in perms_list:
            rotated = apply_perm(obj_voxels, p)
            rdims = [max(v[i] for v in rotated)+1 for i in range(3)]
            if rdims[0] > bbox[0] or rdims[1] > bbox[1] or rdims[2] > bbox[2]:
                continue
            for ox in range(bbox[0] - rdims[0] + 1):
                for oy in range(bbox[1] - rdims[1] + 1):
                    for oz in range(bbox[2] - rdims[2] + 1):
                        placed = set((v[0]+ox, v[1]+oy, v[2]+oz) for v in rotated)
                        if not (placed & occ):
                            results.append((p, ox, oy, oz, placed))
        return results
    
    def backtrack(remaining_names, occ):
        if not remaining_names:
            return {}
        name = remaining_names[0]
        rest = remaining_names[1:]
        placements = find_placements(small_objects[name], occ, bbox)
        for p, ox, oy, oz, placed in placements:
            result = backtrack(rest, occ | placed)
            if result is not None:
                result[name] = (p, ox, oy, oz)
                return result
        return None
    
    return backtrack(obj_names, occupied)

# Test configurations
configs = [
    # (ball_ox, ball_oy, description)
    (1, -5, "12x17x6=1224"),
    (0, -6, "12x18x6=1296"),
    (1, -6, "12x18x6=1296"),
    (0, -5, "12x17x6=1224"),
    (2, -5, "12x17x6=1224"),
]

