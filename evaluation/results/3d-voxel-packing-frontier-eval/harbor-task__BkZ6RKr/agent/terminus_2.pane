def find_placements(obj_voxels, occ, bbox):
    results = []
    for p in perms_list:
        rotated = apply_perm(obj_voxels, p)
        rdims = [max(v[i] for v in rotated)+1 for i in range(3)]
        if rdims[0] > bbox[0] or rdims[1] > bbox[1] or rdims[2] > bbox[2]:
            continue
        for ox in range(bbox[0] - rdims[0] + 1):
            for oy in range(bbox[1] - rdims[1] + 1):
                for oz in range(bbox[2] - rdims[2] + 1):
                    placed = set((v[0]+ox, v[1]+oy, v[2]+oz) for v in rotated)
                    if not (placed & occ):
                        results.append((p, ox, oy, oz, placed))
    return results

# Try all ball offsets that give volume <= 1296
print("Searching for best arrangement with vol <= 1296...")

best_vol = 1296
best_config = None

# Try different ball positions relative to 5-bowl stack
for ball_ox in range(-1, 3):
    for ball_oy in range(-8, 0):
        # Build base
        shift_y = -ball_oy
        occupied = set()
        for i in range(5):
            for x,y,z in bowl:
                occupied.add((x, y + shift_y + 2*i, z))
        ball_v = set((x + ball_ox, y, z) for x,y,z in ball)
        
        if occupied & ball_v:
            continue
        
        occupied |= ball_v
        mn = [min(v[i] for v in occupied) for i in range(3)]
        mx = [max(v[i] for v in occupied) for i in range(3)]
        base_dims = [mx[i]-mn[i]+1 for i in range(3)]
        base_vol = base_dims[0]*base_dims[1]*base_dims[2]
        
        if base_vol > best_vol:
            continue
        
        # Normalize
        occupied = set((v[0]-mn[0], v[1]-mn[1], v[2]-mn[2]) for v in occupied)
        bbox = tuple(base_dims)
        
        # Try placing all small objects (donut1 first since it's hardest)
        obj_names = ['donut1', 'chocolate', 'donut2', 'match_box1', 'match_box2', 'match_box3', 'match_box4']
        
        for trial in range(50):
            if trial == 0:
                order = obj_names[:]
            elif trial == 1:
                order = list(reversed(obj_names))
            else:
                order = obj_names[:]
                random.shuffle(order)
            
            remaining = occupied.copy()
            placements = {}
            success = True
            
            for name in order:
                obj = small_objects[name]
                valid = find_placements(obj, remaining, bbox)
                if valid:
                    p, ox, oy, oz, placed = valid[0]
                    remaining |= placed
                    placements[name] = (p, ox, oy, oz)
                else:
                    success = False
                    break
            
            if success:
                vol = bbox[0]*bbox[1]*bbox[2]
                if vol < best_vol:
                    best_vol = vol
                    best_config = (ball_ox, ball_oy, shift_y, bbox, placements, mn)
                    print(f"  Found: ball=({ball_ox},{ball_oy})[?2004h> import json
