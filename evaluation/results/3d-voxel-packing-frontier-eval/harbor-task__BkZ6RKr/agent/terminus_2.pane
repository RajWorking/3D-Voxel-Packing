[?2004l[?2004h> import json
[?2004l[?2004h> 
[?2004l[?2004h> with open('/task/objects.json') as f:
[?2004l[?2004h>     data = json.load(f)
[?2004l[?2004h> 
[?2004l[?2004h> def get_voxels(name):
[?2004l[?2004h>     voxels = set()
[?2004l[?2004h>     for group in data[name].values():
[?2004l[?2004h>         for v in group:
[?2004l[?2004h>             voxels.add(tuple(v))
[?2004l[?2004h>     min_x = min(v[0] for v in voxels)
[?2004l[?2004h>     min_y = min(v[1] for v in voxels)
[?2004l[?2004h>     min_z = min(v[2] for v in voxels)
[?2004l[?2004h>     return set((x-min_x, y-min_y, z-min_z) for x,y,z in voxels)
[?2004l[?2004h> 
[?2004l[?2004h> def apply_perm(voxels, p):
[?2004l[?2004h>     transformed = set((v[p[0]], v[p[1]], v[p[2]]) for v in voxels)
[?2004l[?2004h>     mn = [min(v[i] for v in transformed) for i in range(3)]
[?2004l[?2004h>     return set((v[0]-mn[0], v[1]-mn[1], v[2]-mn[2]) for v in transformed)
[?2004l[?2004h> 
[?2004l[?2004h> bowl = get_voxels('bowl1')
[?2004l[?2004h> ball = get_voxels('ball')
[?2004l[?2004h> 
[?2004l[?2004h> perms = [(0,1,2),(0,2,1),(1,0,2),(1,2,0),(2,0,1),(2,1,0)]
[?2004l[?2004h> 
[?2004l[?2004h> # Strategy: try all bowl orientations, all ball orientations
[?2004l[?2004h> # For each, build 5-bowl stack, then try placing ball at all offsets
[?2004l[?2004h> # Also try stacking bowls along z (if bowl has 4 in z-dim)
[?2004l[?2004h> 
[?2004l[?2004h> best = None
[?2004l[?2004h> 
[?2004l[?2004h> for bp in perms:
[?2004l[?2004h>     bowl_t = apply_perm(bowl, bp)
[?2004l[?2004h>     bx = max(v[0] for v in bowl_t)+1
[?2004l[?2004h>     by = max(v[1] for v in bowl_t)+1
[?2004l[?2004h>     bz = max(v[2] for v in bowl_t)+1
[?2004l[?2004h>     dims = (bx, by, bz)
[?2004l[?2004h>     
[?2004l[?2004h>     # Find nest axis (size 4)
[?2004l[?2004h>     for nest_ax in range(3):
[?2004l[?2004h>         if dims[nest_ax] == 4:
[?2004l[?2004h>             break
[?2004l[?2004h>     else:
[?2004l[?2004h>         continue
[?2004l[?2004h>     
[?2004l[?2004h>     # Build 5-bowl stack
[?2004l[?2004h>     stack = set()
[?2004l[?2004h>     for i in range(5):
[?2004l[?2004h>         for v in bowl_t:
[?2004l[?2004h>             nv = list(v)
[?2004l[?2004h>             nv[nest_ax] += 2*i
[?2004l[?2004h>             stack.add(tuple(nv))
[?2004l[?2004h>     
[?2004l[?2004h>     sdims = [max(v[i] for v in stack)+1 for i in range(3)]
[?2004l[?2004h>     
[?2004l[?2004h>     for abp in perms:
[?2004l[?2004h>         ball_t = apply_perm(ball, abp)
[?2004l[?2004h>         abdims = [max(v[i] for v in ball_t)+1 for i in range(3)]
[?2004l[?2004h>         
[?2004l[?2004h>         # Try offsets - limit search range
[?2004l[?2004h>         for ox in range(-2, sdims[0]+3):
[?2004l[?2004h>             for oy in range(-2, sdims[1]+3):
[?2004l[?2004h>                 for oz in range(-2, sdims[2]+3):
[?2004l[?2004h>                     # Quick bbox check first
[?2004l[?2004h>                     total_min = [min(0, ox), min(0, oy), min(0, oz)]
[?2004l[?2004h>                     total_max = [max(sdims[0], ox+abdims[0]), max(sdims[1], oy+abdims[1]), max(sdims[2], oz+abdims[2])]
[?2004l[?2004h>                     vol = 1
[?2004l[?2004h>                     for i in range(3):
[?2004l[?2004h>                         vol *= (total_max[i] - total_min[i])
[?2004l[?2004h>                     
[?2004l[?2004h>                     if best is not None and vol >= best[0]:
[?2004l[?2004h>                         continue
[?2004l[?2004h>                     
[?2004l[?2004h>                     # Check collision
[?2004l[?2004h>                     ball_shifted = set((v[0]+ox, v[1]+oy, v[2]+oz) for v in ball_t)
[?2004l[?2004h>                     if ball_shifted & stack:
[?2004l[?2004h>                         continue
[?2004l[?2004h>                     
[?2004l[?2004h>                     # Valid placement
[?2004l[?2004h>                     union = stack | ball_shifted
[?2004l[?2004h>                     mn = [min(v[i] for v in union) for i in range(3)]
[?2004l[?2004h>                     mx = [max(v[i] for v in union) for i in range(3)]
[?2004l[?2004h>                     actual_vol = 1
[?2004l[?2004h>                     for i in range(3):
[?2004l[?2004h>                         actual_vol *= (mx[i] - mn[i] + 1)
[?2004l[?2004h>                     
[?2004l[?2004h>                     if best is None or actual_vol < best[0]:
[?2004l[?2004h>                         best = (actual_vol, [mx[i]-mn[i]+1 for i in range(3)], bp, abp, ox, oy, oz, sdims, abdims)
[?2004l[?2004h>                         print(f"New best: {actual_vol}, bbox={best[1]}, bowl_perm={bp}, ball_perm={abp}, offset=({ox},{oy},{oz})")
[?2004l[?2004h> 
[?2004l[?2004h> print(f"\nFinal best: vol={best[0]}, dims={best[1]}")
[?2004l[?2004h> print(f"  bowl_perm={best[2]}, ball_perm={best[3]}, offset=({best[4]},{best[5]},{best[6]})")
[?2004l[?2004h> print(f"  bowl_stack_dims={best[7]}, ball_dims={best[8]}")
[?2004l[?2004h> 
