[?2004l[?2004h> total = sum(len(v) for v in d.values())
[?2004l[?2004h> print('Total voxels:', total)
[?2004l[?2004h> all_v = []
[?2004l[?2004h> for v in d.values():
[?2004l[?2004h>     all_v.extend(v)
[?2004l[?2004h> mx = [max(p[i] for p in all_v) for i in range(3)]
[?2004l[?2004h> mn = [min(p[i] for p in all_v) for i in range(3)]
[?2004l[?2004h> dims = [mx[i]-mn[i]+1 for i in range(3)]
[?2004l[?2004h> print(f'Bbox: {dims[0]}x{dims[1]}x{dims[2]} = {dims[0]*dims[1]*dims[2]}')
[?2004l[?2004h> # Check for duplicates
[?2004l[?2004h> all_tuples = [tuple(p) for p in all_v]
[?2004l[?2004h> print(f'Unique voxels: {len(set(all_tuples))}')
[?2004l[?2004h> if len(set(all_tuples)) != len(all_tuples):
