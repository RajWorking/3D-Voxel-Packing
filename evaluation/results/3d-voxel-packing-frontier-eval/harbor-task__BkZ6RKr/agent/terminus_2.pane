[?2004l[?2004h> import json
[?2004l[?2004h> import random
[?2004l[?2004h> 
[?2004l[?2004h> with open('/task/objects.json') as f:
[?2004l[?2004h>     data = json.load(f)
[?2004l[?2004h> 
[?2004l[?2004h> def get_voxels(name):
[?2004l[?2004h>     voxels = set()
[?2004l[?2004h>     for group in data[name].values():
[?2004l[?2004h>         for v in group:
[?2004l[?2004h>             voxels.add(tuple(v))
[?2004l[?2004h>     min_x = min(v[0] for v in voxels)
[?2004l[?2004h>     min_y = min(v[1] for v in voxels)
[?2004l[?2004h>     min_z = min(v[2] for v in voxels)
[?2004l[?2004h>     return set((x-min_x, y-min_y, z-min_z) for x,y,z in voxels)
[?2004l[?2004h> 
[?2004l[?2004h> def apply_perm(voxels, p):
[?2004l[?2004h>     transformed = set((v[p[0]], v[p[1]], v[p[2]]) for v in voxels)
[?2004l[?2004h>     mn = [min(v[i] for v in transformed) for i in range(3)]
[?2004l[?2004h>     return set((v[0]-mn[0], v[1]-mn[1], v[2]-mn[2]) for v in transformed)
[?2004l[?2004h> 
[?2004l[?2004h> bowl = get_voxels('bowl1')
[?2004l[?2004h> ball = get_voxels('ball')
[?2004l[?2004h> perms_list = [(0,1,2),(0,2,1),(1,0,2),(1,2,0),(2,0,1),(2,1,0)]
[?2004l[?2004h> perm_names = ['xyz','xzy','yxz','yzx','zxy','zyx']
[?2004l[?2004h> 
[?2004l[?2004h> small_objs = {n: get_voxels(n) for n in ['chocolate','donut1','donut2','match_box1','match_box2','match_box3','match_box4']}
[?2004l[?2004h> 
[?2004l[?2004h> # Build the 12x17x6 base (ball at (1,-5,0))
[?2004l[?2004h> occupied = set()
[?2004l[?2004h> for i in range(5):
[?2004l[?2004h>     for x,y,z in bowl:
[?2004l[?2004h>         occupied.add((x, y + 5 + 2*i, z))
[?2004l[?2004h> for x,y,z in ball:
[?2004l[?2004h>     occupied.add((x + 1, y, z))
[?2004l[?2004h> 
[?2004l[?2004h> bbox = (12, 17, 6)
[?2004l[?2004h> 
[?2004l[?2004h> # Check all orientations of donut1
[?2004l[?2004h> donut1 = small_objs['donut1']
[?2004l[?2004h> print("Donut1 orientations:")
[?2004l[?2004h> for pi, p in enumerate(perms_list):
[?2004l[?2004h>     rotated = apply_perm(donut1, p)
[?2004l[?2004h>     rdims = [max(v[i] for v in rotated)+1 for i in range(3)]
