[?2004l[?2004h>                     if not (placed & occupied_set):
[?2004l[?2004h>                         results.append((p, ox, oy, oz, placed))
[?2004l[?2004h>     return results
[?2004l[?2004h> 
[?2004l[?2004h> # Try to place all small objects greedily (largest first)
[?2004l[?2004h> remaining = occupied.copy()
[?2004l[?2004h> placements = {}
[?2004l[?2004h> 
[?2004l[?2004h> # Order: donut1 (28), chocolate (24), donut2 (20), match_boxes (18 each)
