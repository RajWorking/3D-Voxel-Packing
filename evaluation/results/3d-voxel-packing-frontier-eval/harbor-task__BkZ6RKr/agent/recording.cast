[1034.659714, "i", "ls (stacked along nest axis) and ball\n# with the ball potentially overlapping in the z-range\n\nbest = 1440\nbest_info = None\n\nfor bp in perms:\n    bowl_t = apply_perm(bowl, bp)\n    bdims = [max(v[i] for v in bowl_t)+1 for i in range(3)]\n    \n    # Find nest axis (size 4)\n    nest_ax = None\n    for a in range(3):\n        if bdims[a] == 4:\n            nest_ax = a\n            break\n    if nest_ax is None:\n        continue\n    \n    # Build 5-bowl stack\n    stack = set()\n    for i in range(5):\n        for v in bowl_t:\n            nv = list(v)\n            nv[nest_ax] += 2*i\n            stack.add(tuple(nv))\n    sdims = [max(v[i] for v in stack)+1 for i in range(3)]\n    \n    for abp in perms:\n        ball_t = apply_perm(ball, abp)\n        abdims = [max(v[i] for v in ball_t)+1 for i in range(3)]\n        \n        # Try all offsets where the ball might overlap with the stack's z-range\n        for ox in range(-abdims[0]+1, sdims[0]):\n            for oy in range(-abdims[1]+1, sdims[1]):\n                for oz in range(-abdi"]
