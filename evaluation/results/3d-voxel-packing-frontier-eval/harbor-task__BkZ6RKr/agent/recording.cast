[150.424062, "o", "[]\r\n\u001b[?2004l\r\u001b[?2004h> for a in '+-':\r\n\u001b[?2004l\r\u001b[?2004h>     for b in '+-':\r\n\u001b[?2004l\r\u001b[?2004h>         for c in '+-':\r\n\u001b[?2004l\r\u001b[?2004h>             signs_list.append(a+b+c)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # For each transform, compute the bowl shape\r\n\u001b[?2004l\r\u001b[?2004h> bowl_transforms = []\r\n\u001b[?2004l\r\u001b[?2004h> for perm in perms:\r\n\u001b[?2004l\r\u001b[?2004h>     for signs in signs_list:\r\n\u001b[?2004l\r\u001b[?2004h>         t = apply_transform(bowl, perm, signs)\r\n\u001b[?2004l\r\u001b[?2004h>         bx, by, bz = bbox(t)\r\n\u001b[?2004l\r\u001b[?2004h>         # Use frozenset as key to deduplicate\r\n\u001b[?2004l\r\u001b[?2004h>         bowl_transforms.append((perm, signs, t, bx, by, bz))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Deduplicate by shape\r\n\u001b[?2004l\r\u001b[?2004h> unique_shapes = {}\r\n\u001b[?2004l\r\u001b[?2004h> for perm, signs, t, bx, by, bz in bowl_transforms:\r\n\u001b[?2004l\r\u001b[?2004h>     key = frozenset(t)\r\n\u001b[?2004l\r\u001b[?2004h>     if key not in unique_shapes:\r\n\u001b[?2004l\r\u001b[?2004h>         unique_shapes[key] = (perm, signs, bx, by, bz)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b["]
[150.42453, "o", "?2004l\r\u001b[?2004h> print(f'Unique bowl orientations: {len(unique_shapes)}')\r\n\u001b[?2004l\r\u001b[?2004h> for key, (perm, signs, bx, by, bz) in sorted(unique_shapes.items(), key=lambda x: x[1]):\r\n\u001b[?2004l\r\u001b[?2004h>     print(f'  {perm} {signs}: {bx}x{by}x{bz}')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> PYEOF\r\n\u001b[?2004l\r"]
