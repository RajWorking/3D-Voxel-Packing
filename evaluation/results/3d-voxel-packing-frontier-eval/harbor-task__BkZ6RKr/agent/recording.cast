[1837.422688, "i", "python3 -c \"\nimport json\nwith open('/home/user/solution.json') as f:\n    d = json.load(f)\nprint('Objects:', len(d))\ntotal = sum(len(v) for v in d.values())\nprint('Total voxels:', total)\nall_v = []\nfor v in d.values():\n    all_v.extend(v)\nmx = [max(p[i] for p in all_v) for i in range(3)]\nmn = [min(p[i] for p in all_v) for i in range(3)]\ndims = [mx[i]-mn[i]+1 for i in range(3)]\nprint(f'Bbox: {dims[0]}x{dims[1]}x{dims[2]} = {dims[0]*dims[1]*dims[2]}')\n# Check for duplicates\nall_tuples = [tuple(p) for p in all_v]\nprint(f'Unique voxels: {len(set(all_tuples))}')\nif len(set(all_tuples)) != len(all_tuples):\n    print('WARNING: duplicate voxels!')\n\"\n"]
