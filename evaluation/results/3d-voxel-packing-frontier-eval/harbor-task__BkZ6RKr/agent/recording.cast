[85.577528, "i", "python3 -c \"\nimport json\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\n# Analyze bowl cross-section (same for all z)\nbowl_voxels = set()\nfor group in data['bowl1'].values():\n    for v in group:\n        bowl_voxels.add(tuple(v))\nmin_x = min(v[0] for v in bowl_voxels)\nmin_y = min(v[1] for v in bowl_voxels)\nmin_z = min(v[2] for v in bowl_voxels)\nbowl = set((x-min_x, y-min_y, z-min_z) for x,y,z in bowl_voxels)\n\nprint('Bowl XY cross-section (same for all z):')  \nfor y in range(4):\n    row = ''\n    for x in range(12):\n        if (x,y,0) in bowl:\n            row += '#'\n        else:\n            row += '.'\n    print(f'  y={y}: {row}')\n\nprint()\nprint('Bowl interior (empty space inside bbox):')  \nfor y in range(4):\n    row = ''\n    for x in range(12):\n        if (x,y,0) not in bowl:\n            row += 'O'\n        else:\n            row += '#'\n    print(f'  y={y}: {row}')\n\n# Count empty per row\nprint()\nfor y in range(4):\n    empty = sum(1 for x in range(12) if (x,y,0) not in bowl)\n    print(f'  y={y}: {e"]
[85.578787, "i", "mpty} empty cells per z-layer')\n\"\n"]
