[309.247265, "i", "stack: {s3x}x{s3y}\")\nfor y in range(s3y):\n    row = ''.join('#' if (x,y) in stack3_2d else '.' for x in range(s3x))\n    print(f\"  y={y}: {row}\")\n\n# Ball is 10x8. 3 bowls are 12x8. Place side by side: 22x8x6 = 1056\n# Or overlap in x? Ball is 10 wide, bowls 12 wide.\n# What about placing ball at x=0 and bowls at x=10? -> 22x8x6\n# Or ball at x=2 (centered in 12)? Ball is 10 wide, fits in 12 with 2 spare.\n# Can ball and 3-bowl-stack share the same 12x8 footprint?\n\n# Check overlap between ball 2D (at z=0) and 3-bowl-stack\nball_2d_z0 = set((x,y) for x,y,z in ball if z == 0)\nprint(f\"\\nBall 2D at z=0: {len(ball_2d_z0)} cells in {max(x for x,y in ball_2d_z0)+1}x{max(y for x,y in ball_2d_z0)+1}\")\n\n# Try placing ball at offset (1,0) within the 12x8 region\nfor ox in range(3):\n    ball_shifted = set((x+ox, y) for x,y in ball_2d_z0)\n    overlap = ball_shifted & stack3_2d\n    union = ball_shifted | stack3_2d\n    print(f\"  Ball at ox={ox}: overlap={len(overlap)}, union={len(union)}\")\n\nPYEOF\npython3 /tmp/solve.py\n"]
