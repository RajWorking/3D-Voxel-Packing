[449.904341, "o", "  total=12x6x20=1440, bowls=12x6x12, ball=10x6x8, bowl_perm=1, ball_perm=1, place_axis=2\r\n  total=20x6x12=1440, bowls=12x6x12, ball=8x6x10, bowl_perm=1, ball_perm=3, place_axis=0\r\n  total=12x20x6=1440, bowls=12x12x6, ball=10x8x6, bowl_perm=2, ball_perm=0, place_axis=1\r\n\r\n--- Split bowls: 3+2 ---\r\n"]
