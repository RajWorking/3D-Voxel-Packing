[449.875726, "o", "            elif vol == best_split:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.875828, "o", "                split_results.append((vol, total, stack3, stack2, ball_dims, bowl_perm, ball_perm, axis))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.875854, "o", "print(f\"Best split volume: {best_split}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.875968, "o", "for r in split_results[:5]:\r\n\u001b[?2004l\r\u001b[?2004h>     vol, td, s3, s2, bd, bp, abp, ax = r\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.876114, "o", "    print(f\"  total={td[0]}x{td[1]}x{td[2]}={vol}, 3stack={s3[0]}x{s3[1]}x{s3[2]}, 2stack={s2[0]}x{s2[1]}x{s2[2]}, ball={bd[0]}x{bd[1]}x{bd[2]}\")\r\n\u001b[?2004l\r"]
[449.876187, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.876336, "o", "# Try L-shaped arrangements: ball + 3-stack share a dimension, 2-stack fills gap\r\n\u001b[?2004l\r\u001b[?2004h> print(\"\\n--- L-shaped: ball next to 3-stack, 2-stack fills gap ---\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.876562, "o", "best_L = None\r\n\u001b[?2004l\r\u001b[?2004h> for bowl_perm in range(6):\r\n\u001b[?2004l\r\u001b[?2004h>     bowl_t = apply_perm(bowl, bowl_perm)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.876578, "o", "    bx = max(v[0] for v in bowl_t) + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.876664, "o", "    by = max(v[1] for v in bowl_t) + 1\r\n\u001b[?2004l\r"]
[449.877122, "o", "\u001b[?2004h>     bz = max(v[2] for v in bowl_t) + 1\r\n\u001b[?2004l\r\u001b[?2004h>     dims = [bx, by, bz]\r\n\u001b[?2004l\r\u001b[?2004h>     nest_axis = dims.index(4)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     stack3 = list(dims); stack3[nest_axis] = 8\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.87715, "o", "    stack2 = list(dims); stack2[nest_axis] = 6\r\n\u001b[?2004l\r\u001b[?2004h"]
[449.877274, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h>     for ball_perm in range(6):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.87739, "o", "        ball_t = apply_perm(ball, ball_perm)\r\n\u001b[?2004l\r\u001b[?2004h>         bd = [max(v[0] for v in ball_t)+1, max(v[1] for v in ball_t)+1, max(v[2] for v in ball_t)+1]\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[449.877505, "o", "\u001b[?2004h>         # Ball + 3-stack side by side along axis A\r\n\u001b[?2004l\r\u001b[?2004h>         # 2-stack placed to fill the gap along axis B\r\n\u001b[?2004l\r\u001b[?2004h"]
[449.877531, "o", "> "]
[449.877637, "o", "        for axA in range(3):\r\n\u001b[?2004l\r\u001b[?2004h>             for axB in range(3):\r\n\u001b[?2004l\r\u001b[?2004h>                 if axA == axB: continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.877699, "o", "                axC = 3 - axA - axB  # remaining axis\r\n\u001b[?2004l\r"]
[449.877758, "o", "\u001b[?2004h>                 \r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.877854, "o", "                # Along axA: ball and 3-stack side by side\r\n\u001b[?2004l\r\u001b[?2004h>                 lenA = stack3[axA] + bd[axA]\r\n\u001b[?2004l\r\u001b[?2004h"]
[449.877946, "o", "> "]
[449.878025, "o", "                # Along axB: max of (ball, 3-stack) for the main part\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.878149, "o", "                main_B = max(stack3[axB], bd[axB])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.878337, "o", "                # 2-stack goes along axB, extending it\r\n\u001b[?2004l\r\u001b[?2004h"]
[449.878362, "o", "> "]
[449.878454, "o", "                # But 2-stack needs to fit in axA direction\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.87858, "o", "                if stack2[axA] <= lenA:  # 2-stack fits within the axA extent\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.878675, "o", "                    lenB = max(main_B, stack2[axB])  # if 2-stack is within main_B\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.878779, "o", "                    # Actually 2-stack could be placed at axB = main_B\r\n\u001b[?2004l\r"]
[449.878794, "o", "\u001b[?2004h> "]
[449.879067, "o", "                    # Total axB = main_B + stack2[axB] if placed adjacent\r\n\u001b[?2004l\r\u001b[?2004h>                     # Or = max(main_B, stack2[axB]) if placed overlapping in axB\r\n\u001b[?2004l\r\u001b[?2004h>                     # Let's try: 2-stack placed at axB = main_B (adjacent)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.879172, "o", "                    lenB_adj = main_B + stack2[axB]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.879314, "o", "                    lenC = max(stack3[axC], bd[axC], stack2[axC])\r\n\u001b[?2004l\r\u001b[?2004h>                     vol = lenA * lenB_adj * lenC\r\n\u001b[?2004l\r"]
[449.879441, "o", "\u001b[?2004h>                     if best_L is None or vol < best_L:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.879555, "o", "                        best_L = vol\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.879692, "o", "                        L_info = f\"total={lenA}x{lenB_adj}x{lenC} (axes {axA},{axB},{axC}), 3stack={stack3}, ball={bd}, 2stack={stack2}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Best L-shaped: {best_L}\")\r\n\u001b[?2004l\r\u001b[?2004h> if best_L:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.879729, "o", "    print(f\"  {L_info}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[449.87981, "o", "\u001b[?2004l\r\u001b[?2004h> PYEOF"]
[449.879897, "o", "\r\n\u001b[?2004l\r"]
