[1186.450848, "i", "cat > /tmp/solve12.py << 'PYEOF'\nimport json\nfrom itertools import permutations as iterperms\n\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\ndef get_voxels(name):\n    voxels = set()\n    for group in data[name].values():\n        for v in group:\n            voxels.add(tuple(v))\n    min_x = min(v[0] for v in voxels)\n    min_y = min(v[1] for v in voxels)\n    min_z = min(v[2] for v in voxels)\n    return set((x-min_x, y-min_y, z-min_z) for x,y,z in voxels)\n\ndef apply_perm(voxels, p):\n    transformed = set((v[p[0]], v[p[1]], v[p[2]]) for v in voxels)\n    mn = [min(v[i] for v in transformed) for i in range(3)]\n    return set((v[0]-mn[0], v[1]-mn[1], v[2]-mn[2]) for v in transformed)\n\nbowl = get_voxels('bowl1')\nball = get_voxels('ball')\nperms_list = [(0,1,2),(0,2,1),(1,0,2),(1,2,0),(2,0,1),(2,1,0)]\nperm_names = ['xyz','xzy','yxz','yzx','zxy','zyx']\n\nsmall_objects = {\n    'chocolate': get_voxels('chocolate'),\n    'donut1': get_voxels('donut1'),\n    'donut2': get_voxels('donut2'),\n    'match_box1': get_v"]
[1186.451814, "o", "cat > /tmp/solve12.py << 'PYEOF'\r\n\u001b[?2004l\r"]
[1186.451845, "i", "oxels('match_box1'),\n    'match_box2': get_voxels('match_box2'),\n    'match_box3': get_voxels('match_box3'),\n    'match_box4': get_voxels('match_box4'),\n}\n\ndef try_place_all(occupied, bbox, obj_names):\n    \"\"\"Try to place all objects using backtracking with different orderings.\"\"\"\n    def find_placements(obj_voxels, occ, bbox):\n        results = []\n        for p in perms_list:\n            rotated = apply_perm(obj_voxels, p)\n            rdims = [max(v[i] for v in rotated)+1 for i in range(3)]\n            if rdims[0] > bbox[0] or rdims[1] > bbox[1] or rdims[2] > bbox[2]:\n                continue\n            for ox in range(bbox[0] - rdims[0] + 1):\n                for oy in range(bbox[1] - rdims[1] + 1):\n                    for oz in range(bbox[2] - rdims[2] + 1):\n                        placed = set((v[0]+ox, v[1]+oy, v[2]+oz) for v in rotated)\n                        if not (placed & occ):\n                            results.append((p, ox, oy, oz, placed))\n        return results\n    \n    def backtrack(remainin"]
[1186.451854, "o", "\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> from itertools import permutations as iterperms\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> with open('/task/objects.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     data = json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def get_voxels(name):\r\n\u001b[?2004l\r\u001b[?2004h>     voxels = set()\r\n\u001b[?2004l\r"]
[1186.451868, "i", "g_names, occ):\n        if not remaining_names:\n            return {}\n        name = remaining_names[0]\n        rest = remaining_names[1:]\n        placements = find_placements(small_objects[name], occ, bbox)\n        for p, ox, oy, oz, placed in placements:\n            result = backtrack(rest, occ | placed)\n            if result is not None:\n                result[name] = (p, ox, oy, oz)\n                return result\n        return None\n    \n    return backtrack(obj_names, occupied)\n\n# Test configurations\nconfigs = [\n    # (ball_ox, ball_oy, description)\n    (1, -5, \"12x17x6=1224\"),\n    (0, -6, \"12x18x6=1296\"),\n    (1, -6, \"12x18x6=1296\"),\n    (0, -5, \"12x17x6=1224\"),\n    (2, -5, \"12x17x6=1224\"),\n]\n\nfor ball_ox, ball_oy, desc in configs:\n    print(f\"\\n=== Config: ball at ({ball_ox},{ball_oy},0) - {desc} ===\")\n    \n    # Build occupied\n    occupied = set()\n    shift_y = -ball_oy  # shift to make min y = 0\n    \n    for i in range(5):\n        for x,y,z in bowl:\n            occupied.add((x, y + shift_y + 2*i, z))\n "]
