[944.462224, "i", "egion:\")\nbest = (1440, None)\nfor pi, p in enumerate(perms):\n    ball_t = apply_perm(ball, p)\n    bdims = [max(v[i] for v in ball_t)+1 for i in range(3)]\n    \n    for ox in range(-2, 14):\n        for oy in range(6, 14):  # Try y=6 to 13 (partially overlapping)\n            for oz in range(-2, 8):\n                # Quick bbox check\n                mn = [min(0, ox), min(0, oy), min(0, oz)]\n                mx = [max(12, ox+bdims[0]), max(12, oy+bdims[1]), max(6, oz+bdims[2])]\n                vol = (mx[0]-mn[0]) * (mx[1]-mn[1]) * (mx[2]-mn[2])\n                if vol >= best[0]:\n                    continue\n                \n                ball_s = set((v[0]+ox, v[1]+oy, v[2]+oz) for v in ball_t)\n                if ball_s & stack5:\n                    continue\n                \n                union = stack5 | ball_s\n                amn = [min(v[i] for v in union) for i in range(3)]\n                amx = [max(v[i] for v in union) for i in range(3)]\n                actual_vol = 1\n                for i in range(3):\n   "]
