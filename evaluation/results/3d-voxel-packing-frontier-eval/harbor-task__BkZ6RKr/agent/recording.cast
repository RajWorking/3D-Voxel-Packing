[366.480133, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.480223, "o", "# Try placing ball at various offsets relative to bowl stack\r\n\u001b[?2004l\r\u001b[?2004h> best = None\r\n"]
