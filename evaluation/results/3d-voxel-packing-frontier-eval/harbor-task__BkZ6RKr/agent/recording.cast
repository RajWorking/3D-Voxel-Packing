[1854.738468, "i", "python3 -c \"\nimport json\nwith open('/home/user/solution.json') as f:\n    d = json.load(f)\nprint('Objects:', sorted(d.keys()))\ntotal = 0\nall_v = set()\nfor name, obj in d.items():\n    voxels = obj['pos']\n    total += len(voxels)\n    for v in voxels:\n        t = tuple(v)\n        if t in all_v:\n            print(f'DUPLICATE at {t}!')\n        all_v.add(t)\n    print(f'  {name}: {len(voxels)} voxels')\nprint(f'Total voxels: {total}')\nprint(f'Unique voxels: {len(all_v)}')\nmx = [max(v[i] for v in all_v) for i in range(3)]\nmn = [min(v[i] for v in all_v) for i in range(3)]\ndims = [mx[i]-mn[i]+1 for i in range(3)]\nprint(f'Bbox: {dims[0]}x{dims[1]}x{dims[2]} = {dims[0]*dims[1]*dims[2]}')\n\"\n"]
[1854.739601, "o", "python3 -c \"\r\n"]
