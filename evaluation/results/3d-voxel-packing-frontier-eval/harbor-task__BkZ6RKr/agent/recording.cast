[1889.466641, "o", "            print(\"\\n=== PLACEMENT COMMANDS ===\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1889.466822, "o", "            print(f\"Ball: xyz +++ offset=(1,0,0)\")\r\n\u001b[?2004l\r\u001b[?2004h>             for i in range(5):\r\n\u001b[?2004l\r\u001b[?2004h>                 print(f\"Bowl{i+1}: xyz +++ offset=(0,{5+2*i},0)\")\r\n\u001b[?2004l\r\u001b[?2004h>             for name in obj_names:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1889.466921, "o", "                p,ox,oy,oz = placements[name]\r\n\u001b[?2004l\r\u001b[?2004h> "]
