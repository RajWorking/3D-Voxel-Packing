[1889.459191, "i", "r i in range(5):\n    for x,y,z in bowl:\n        occupied.add((x, y + 5 + 2*i, z))\nfor x,y,z in ball:\n    occupied.add((x + 1, y, z))\n\nbbox = (12, 17, 6)\n\n# Check all orientations of donut1\ndonut1 = small_objs['donut1']\nprint(\"Donut1 orientations:\")\nfor pi, p in enumerate(perms_list):\n    rotated = apply_perm(donut1, p)\n    rdims = [max(v[i] for v in rotated)+1 for i in range(3)]\n    print(f\"  {perm_names[pi]}: {rdims[0]}x{rdims[1]}x{rdims[2]}\")\n    \n    if rdims[0] > bbox[0] or rdims[1] > bbox[1] or rdims[2] > bbox[2]:\n        print(f\"    Doesn't fit in bbox\")\n        continue\n    \n    count = 0\n    for ox in range(bbox[0] - rdims[0] + 1):\n        for oy in range(bbox[1] - rdims[1] + 1):\n            for oz in range(bbox[2] - rdims[2] + 1):\n                placed = set((v[0]+ox, v[1]+oy, v[2]+oz) for v in rotated)\n                if not (placed & occupied):\n                    count += 1\n                    if count <= 3:\n                        print(f\"    Valid at ({ox},{oy},{oz})\")\n    print(f\"    Total val"]
