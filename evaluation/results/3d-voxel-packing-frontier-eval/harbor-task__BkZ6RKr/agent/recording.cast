[519.499945, "i", "cat > /tmp/solve5.py << 'PYEOF'\nimport json\n\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\ndef get_voxels(name):\n    voxels = set()\n    for group in data[name].values():\n        for v in group:\n            voxels.add(tuple(v))\n    min_x = min(v[0] for v in voxels)\n    min_y = min(v[1] for v in voxels)\n    min_z = min(v[2] for v in voxels)\n    return set((x-min_x, y-min_y, z-min_z) for x,y,z in voxels)\n\ndef apply_perm(voxels, p):\n    transformed = set((v[p[0]], v[p[1]], v[p[2]]) for v in voxels)\n    mn = [min(v[i] for v in transformed) for i in range(3)]\n    return set((v[0]-mn[0], v[1]-mn[1], v[2]-mn[2]) for v in transformed)\n\nbowl = get_voxels('bowl1')\nball = get_voxels('ball')\n\nperms = [(0,1,2),(0,2,1),(1,0,2),(1,2,0),(2,0,1),(2,1,0)]\n\n# Strategy: try all bowl orientations, all ball orientations\n# For each, build 5-bowl stack, then try placing ball at all offsets\n# Also try stacking bowls along z (if bowl has 4 in z-dim)\n\nbest = None\n\nfor bp in perms:\n    bowl_t = apply_perm(bowl, bp)\n    b"]
[519.500407, "i", "x = max(v[0] for v in bowl_t)+1\n    by = max(v[1] for v in bowl_t)+1\n    bz = max(v[2] for v in bowl_t)+1\n    dims = (bx, by, bz)\n    \n    # Find nest axis (size 4)\n    for nest_ax in range(3):\n        if dims[nest_ax] == 4:\n            break\n    else:\n        continue\n    \n    # Build 5-bowl stack\n    stack = set()\n    for i in range(5):\n        for v in bowl_t:\n            nv = list(v)\n            nv[nest_ax] += 2*i\n            stack.add(tuple(nv))\n    \n    sdims = [max(v[i] for v in stack)+1 for i in range(3)]\n    \n    for abp in perms:\n        ball_t = apply_perm(ball, abp)\n        abdims = [max(v[i] for v in ball_t)+1 for i in range(3)]\n        \n        # Try offsets - limit search range\n        for ox in range(-2, sdims[0]+3):\n            for oy in range(-2, sdims[1]+3):\n                for oz in range(-2, sdims[2]+3):\n                    # Quick bbox check first\n                    total_min = [min(0, ox), min(0, oy), min(0, oz)]\n                    total_max = [max(sdims[0], ox+abdims[0]), max(sdims[1"]
[519.500437, "i", "], oy+abdims[1]), max(sdims[2], oz+abdims[2])]\n                    vol = 1\n                    for i in range(3):\n                        vol *= (total_max[i] - total_min[i])\n                    \n                    if best is not None and vol >= best[0]:\n                        continue\n                    \n                    # Check collision\n                    ball_shifted = set((v[0]+ox, v[1]+oy, v[2]+oz) for v in ball_t)\n                    if ball_shifted & stack:\n                        continue\n                    \n                    # Valid placement\n                    union = stack | ball_shifted\n                    mn = [min(v[i] for v in union) for i in range(3)]\n                    mx = [max(v[i] for v in union) for i in range(3)]\n                    actual_vol = 1\n                    for i in range(3):\n                        actual_vol *= (mx[i] - mn[i] + 1)\n                    \n                    if best is None or actual_vol < best[0]:\n                        best = (actual_vol, [mx[i]-m"]
[519.500456, "i", "n[i]+1 for i in range(3)], bp, abp, ox, oy, oz, sdims, abdims)\n                        print(f\"New best: {actual_vol}, bbox={best[1]}, bowl_perm={bp}, ball_perm={abp}, offset=({ox},{oy},{oz})\")\n\nprint(f\"\\nFinal best: vol={best[0]}, dims={best[1]}\")\nprint(f\"  bowl_perm={best[2]}, ball_perm={best[3]}, offset=({best[4]},{best[5]},{best[6]})\")\nprint(f\"  bowl_stack_dims={best[7]}, ball_dims={best[8]}\")\n\nPYEOF\npython3 /tmp/solve5.py\n"]
