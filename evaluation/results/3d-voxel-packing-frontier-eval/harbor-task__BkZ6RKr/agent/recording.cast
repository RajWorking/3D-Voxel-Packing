[449.863881, "i", "cat > /tmp/solve3.py << 'PYEOF'\nimport json\nfrom itertools import permutations\n\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\ndef get_voxels(name):\n    voxels = set()\n    for group in data[name].values():\n        for v in group:\n            voxels.add(tuple(v))\n    min_x = min(v[0] for v in voxels)\n    min_y = min(v[1] for v in voxels)\n    min_z = min(v[2] for v in voxels)\n    return set((x-min_x, y-min_y, z-min_z) for x,y,z in voxels)\n\ndef apply_perm(voxels, perm_idx):\n    # perm_idx: which permutation of axes (0-5)\n    perms = [(0,1,2),(0,2,1),(1,0,2),(1,2,0),(2,0,1),(2,1,0)]\n    p = perms[perm_idx]\n    transformed = set()\n    for v in voxels:\n        transformed.add((v[p[0]], v[p[1]], v[p[2]]))\n    min_x = min(v[0] for v in transformed)\n    min_y = min(v[1] for v in transformed)\n    min_z = min(v[2] for v in transformed)\n    return set((x-min_x, y-min_y, z-min_z) for x,y,z in transformed)\n\nbowl = get_voxels('bowl1')\nball = get_voxels('ball')\n\n# The bowl cross-section is the same for all z."]
[449.864369, "o", "cat > /tmp/solve3.py << 'PYEOF'\r\n"]
[449.86517, "i", " The nesting direction is y (size 4).\n# When we permute axes, the nesting direction changes.\n# Bowl canonical: x=12, y=4(nest), z=6\n# Nesting: shift along the 4-dim by 2, up to 5 bowls -> 4+8=12\n\n# For each axis permutation of the bowl, identify which axis is the nest axis (size 4)\n# and try stacking N bowls (1-5) along that axis\n\n# For the ball, try all 6 axis permutations\n\n# Then try placing ball adjacent to bowl stack in various ways\n\nbest_overall = None\nresults = []\n\nfor bowl_perm in range(6):\n    bowl_t = apply_perm(bowl, bowl_perm)\n    bx = max(v[0] for v in bowl_t) + 1\n    by = max(v[1] for v in bowl_t) + 1\n    bz = max(v[2] for v in bowl_t) + 1\n    dims = [bx, by, bz]\n    \n    # Find the nest axis (size 4)\n    nest_axis = dims.index(4)\n    \n    for ball_perm in range(6):\n        ball_t = apply_perm(ball, ball_perm)\n        abx = max(v[0] for v in ball_t) + 1\n        aby = max(v[1] for v in ball_t) + 1\n        abz = max(v[2] for v in ball_t) + 1\n        \n        # Try stacking 5 bowls along nest_axis\n "]
[449.865213, "o", "\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> from itertools import permutations\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> with open('/task/objects.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     data = json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def get_voxels(name):\r\n\u001b[?2004l\r\u001b[?2004h>     voxels = set()\r\n\u001b[?2004l\r\u001b[?2004h>     for group in data[name].values():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[449.865229, "i", "       # Bowl stack dimensions\n        stack_dims = list(dims)\n        stack_dims[nest_axis] = 12  # 4 + 4*2 = 12\n        \n        # Now place ball adjacent to bowl stack\n        # Try placing along each axis\n        for place_axis in range(3):\n            ball_dims = [abx, aby, abz]\n            total_dims = list(stack_dims)\n            total_dims[place_axis] += ball_dims[place_axis]\n            # Other dims: max of stack and ball\n            for a in range(3):\n                if a != place_axis:\n                    total_dims[a] = max(total_dims[a], ball_dims[a])\n            vol = total_dims[0] * total_dims[1] * total_dims[2]\n            if best_overall is None or vol < best_overall:\n                best_overall = vol\n                results = [(vol, total_dims, stack_dims, ball_dims, bowl_perm, ball_perm, place_axis)]\n            elif vol == best_overall:\n                results.append((vol, total_dims, stack_dims, ball_dims, bowl_perm, ball_perm, place_axis))\n\nprint(f\"Best volume (ball adjacent to 5-bowl s"]
