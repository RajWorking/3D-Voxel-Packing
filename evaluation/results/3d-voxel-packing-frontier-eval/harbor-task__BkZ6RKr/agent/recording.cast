[1334.299132, "i", "aining, bbox)\n        if valid:\n            p, ox, oy, oz, placed = valid[0]\n            remaining |= placed\n            placements[name] = (p, ox, oy, oz)\n        else:\n            return None\n    return placements\n\n# Test multiple configurations and orderings\nconfigs = [\n    (1, -5, \"12x17x6=1224\"),\n    (0, -6, \"12x18x6=1296\"),\n    (1, -6, \"12x18x6=1296\"),\n    (0, -5, \"12x17x6=1224\"),\n    (2, -5, \"12x17x6=1224\"),\n]\n\nobj_names = ['donut1', 'chocolate', 'donut2', 'match_box1', 'match_box2', 'match_box3', 'match_box4']\n\nbest_result = None\nbest_vol = 1440\n\nfor ball_ox, ball_oy, desc in configs:\n    shift_y = -ball_oy\n    \n    occupied = set()\n    for i in range(5):\n        for x,y,z in bowl:\n            occupied.add((x, y + shift_y + 2*i, z))\n    for x,y,z in ball:\n        occupied.add((x + ball_ox, y, z))\n    \n    mn = [min(v[i] for v in occupied) for i in range(3)]\n    mx = [max(v[i] for v in occupied) for i in range(3)]\n    bbox = (mx[0]-mn[0]+1, mx[1]-mn[1]+1, mx[2]-mn[2]+1)\n    vol = bbox[0]*bbox[1]*bbox[2"]
