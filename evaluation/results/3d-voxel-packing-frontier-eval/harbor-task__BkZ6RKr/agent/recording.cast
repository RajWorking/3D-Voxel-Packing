[1334.298718, "i", "cat > /tmp/solve13.py << 'PYEOF'\nimport json\nfrom itertools import permutations as iterperms\nimport random\n\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\ndef get_voxels(name):\n    voxels = set()\n    for group in data[name].values():\n        for v in group:\n            voxels.add(tuple(v))\n    min_x = min(v[0] for v in voxels)\n    min_y = min(v[1] for v in voxels)\n    min_z = min(v[2] for v in voxels)\n    return set((x-min_x, y-min_y, z-min_z) for x,y,z in voxels)\n\ndef apply_perm(voxels, p):\n    transformed = set((v[p[0]], v[p[1]], v[p[2]]) for v in voxels)\n    mn = [min(v[i] for v in transformed) for i in range(3)]\n    return set((v[0]-mn[0], v[1]-mn[1], v[2]-mn[2]) for v in transformed)\n\nbowl = get_voxels('bowl1')\nball = get_voxels('ball')\nperms_list = [(0,1,2),(0,2,1),(1,0,2),(1,2,0),(2,0,1),(2,1,0)]\nperm_names = ['xyz','xzy','yxz','yzx','zxy','zyx']\n\nsmall_objects = {\n    'chocolate': get_voxels('chocolate'),\n    'donut1': get_voxels('donut1'),\n    'donut2': get_voxels('donut2'),\n    'matc"]
[1334.29898, "i", "h_box1': get_voxels('match_box1'),\n    'match_box2': get_voxels('match_box2'),\n    'match_box3': get_voxels('match_box3'),\n    'match_box4': get_voxels('match_box4'),\n}\n\ndef find_placements(obj_voxels, occ, bbox):\n    results = []\n    for p in perms_list:\n        rotated = apply_perm(obj_voxels, p)\n        rdims = [max(v[i] for v in rotated)+1 for i in range(3)]\n        if rdims[0] > bbox[0] or rdims[1] > bbox[1] or rdims[2] > bbox[2]:\n            continue\n        for ox in range(bbox[0] - rdims[0] + 1):\n            for oy in range(bbox[1] - rdims[1] + 1):\n                for oz in range(bbox[2] - rdims[2] + 1):\n                    placed = set((v[0]+ox, v[1]+oy, v[2]+oz) for v in rotated)\n                    if not (placed & occ):\n                        results.append((p, ox, oy, oz, placed))\n    return results\n\ndef greedy_place(occupied, bbox, obj_order):\n    remaining = occupied.copy()\n    placements = {}\n    for name in obj_order:\n        obj = small_objects[name]\n        valid = find_placements(obj, rem"]
