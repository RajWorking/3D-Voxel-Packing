[67.2639, "i", "python3 -c \"\nimport json\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\n# Get bowl1 voxels\nbowl_voxels = set()\nfor group in data['bowl1'].values():\n    for v in group:\n        bowl_voxels.add(tuple(v))\n\n# Normalize\nmin_x = min(v[0] for v in bowl_voxels)\nmin_y = min(v[1] for v in bowl_voxels)\nmin_z = min(v[2] for v in bowl_voxels)\nbowl_norm = set((x-min_x, y-min_y, z-min_z) for x,y,z in bowl_voxels)\n\nmax_x = max(v[0] for v in bowl_norm)\nmax_y = max(v[1] for v in bowl_norm)\nmax_z = max(v[2] for v in bowl_norm)\nprint(f'Bowl bbox: {max_x+1}x{max_y+1}x{max_z+1}')\nprint(f'Bowl voxels: {len(bowl_norm)}')\n\n# Full block\nfull = set((x,y,z) for x in range(max_x+1) for y in range(max_y+1) for z in range(max_z+1))\nprint(f'Full block: {len(full)}')\n\n# Interior (not in bowl)\ninterior = full - bowl_norm\nprint(f'Interior voxels: {len(interior)}')\n\n# Flip y: new_y = max_y - y\nbowl_flipped = set((x, max_y - y, z) for x,y,z in bowl_norm)\noverlap = bowl_norm & bowl_flipped\nprint(f'Overlap with y-flipped: {len(over"]
[67.265008, "o", "python3 -c \"\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> with open('/task/objects.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     data = json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Get bowl1 voxels\r\n\u001b[?2004l\r\u001b[?2004h> "]
[67.265065, "i", "lap)}')\nunion = bowl_norm | bowl_flipped\nprint(f'Union: {len(union)}, Full: {len(full)}')\nif union == full:\n    print('Two bowls (normal + y-flipped) perfectly fill the 12x4x6 block!')\nelse:\n    missing = full - union\n    extra = union - full\n    print(f'Missing from full: {len(missing)}')\n    print(f'Extra: {len(extra)}')\n\"\n"]
