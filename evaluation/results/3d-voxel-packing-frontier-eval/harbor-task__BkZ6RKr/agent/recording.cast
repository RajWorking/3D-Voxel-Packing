[366.480987, "o", "> if best:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.481071, "o", "    print(f\"Best ball+5bowls same z: vol={best[0]}, bbox={best[1]}x{best[2]}x6, ball at ox={best[3]}, oy={best[4]}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.481108, "o", "else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[366.48112, "o", "> "]
