[1747.353879, "i", " set((v[0]+ox,v[1]+oy,v[2]+oz) for v in ball)\n                    if ball_s & stack:\n                        continue\n                    \n                    # Valid! Now try to fit small objects\n                    union = stack | ball_s\n                    amn = [min(v[i] for v in union) for i in range(3)]\n                    amx = [max(v[i] for v in union) for i in range(3)]\n                    dims = [amx[i]-amn[i]+1 for i in range(3)]\n                    actual_vol = dims[0]*dims[1]*dims[2]\n                    if actual_vol >= best_vol:\n                        continue\n                    \n                    # Normalize\n                    norm_union = set((v[0]-amn[0],v[1]-amn[1],v[2]-amn[2]) for v in union)\n                    bbox = tuple(dims)\n                    \n                    # Try to fit small objects\n                    for trial in range(20):\n                        order = obj_names[:]\n                        if trial > 0:\n                            random.shuffle(order)\n              "]
