[1747.353716, "i", "k\n    if nest_ax is None:\n        continue\n    \n    # Build 5-bowl stack\n    stack = set()\n    for i in range(5):\n        for v in bowl:\n            nv = list(v)\n            nv[nest_ax] += 2*i\n            stack.add(tuple(nv))\n    sdims = [max(v[i] for v in stack)+1 for i in range(3)]\n    \n    # Try all ball orientations\n    for ball_pi, ball_p in enumerate(perms_list):\n        ball = apply_perm(ball_raw, ball_p)\n        abdims = [max(v[i] for v in ball)+1 for i in range(3)]\n        \n        # Try offsets\n        for ox in range(-abdims[0]+1, sdims[0]):\n            for oy in range(-abdims[1]+1, sdims[1]):\n                for oz in range(-abdims[2]+1, sdims[2]):\n                    mn = [min(0,ox),min(0,oy),min(0,oz)]\n                    mx = [max(sdims[0],ox+abdims[0]),max(sdims[1],oy+abdims[1]),max(sdims[2],oz+abdims[2])]\n                    vol = (mx[0]-mn[0])*(mx[1]-mn[1])*(mx[2]-mn[2])\n                    if vol >= best_vol:\n                        continue\n                    \n                    ball_s ="]
