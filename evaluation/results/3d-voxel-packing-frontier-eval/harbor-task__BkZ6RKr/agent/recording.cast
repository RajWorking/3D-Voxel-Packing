[1889.459401, "i", "id positions: {count}\")\n\n# Now try placing donut1 first, then the rest\nprint(\"\\nTrying donut1-first approach:\")\nobj_names = ['donut1','chocolate','donut2','match_box1','match_box2','match_box3','match_box4']\n\ndef find_placements(obj_voxels, occ, bbox):\n    results = []\n    for p in perms_list:\n        rotated = apply_perm(obj_voxels, p)\n        rdims = [max(v[i] for v in rotated)+1 for i in range(3)]\n        if rdims[0]>bbox[0] or rdims[1]>bbox[1] or rdims[2]>bbox[2]:\n            continue\n        for ox in range(bbox[0]-rdims[0]+1):\n            for oy in range(bbox[1]-rdims[1]+1):\n                for oz in range(bbox[2]-rdims[2]+1):\n                    placed = set((v[0]+ox,v[1]+oy,v[2]+oz) for v in rotated)\n                    if not (placed & occ):\n                        results.append((p,ox,oy,oz,placed))\n    return results\n\n# Get all valid donut1 placements\ndonut1_placements = find_placements(donut1, occupied, bbox)\nprint(f\"Total donut1 placements: {len(donut1_placements)}\")\n\n# For each donut1 placement,"]
