[886.082369, "i", "v[i] for v in bowl5)+1 for i in range(3)]\n    count = 0\n    for ox in range(max(0, 12 - rdims[0]) + 1):\n        for oy in range(max(0, 18 - rdims[1]) + 1):\n            for oz in range(max(0, 6 - rdims[2]) + 1):\n                placed = set((v[0]+ox, v[1]+oy, v[2]+oz) for v in bowl5)\n                if not (placed & base):\n                    union = base | placed\n                    umx = [max(v[i] for v in union)+1 for i in range(3)]\n                    vol = umx[0]*umx[1]*umx[2]\n                    if vol < 1440:\n                        print(f\"  perm={p} at ({ox},{oy},{oz}): {umx[0]}x{umx[1]}x{umx[2]}={vol}\")\n                        count += 1\n    if count == 0:\n        print(f\"  perm={p} ({rdims[0]}x{rdims[1]}x{rdims[2]}): no improvement\")\n\nPYEOF\npython3 /tmp/solve8.py\n"]
