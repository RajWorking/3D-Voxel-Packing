[150.409727, "i", "cat > /tmp/analyze.py << 'PYEOF'\nimport json\n\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\ndef get_voxels(name):\n    voxels = set()\n    for group in data[name].values():\n        for v in group:\n            voxels.add(tuple(v))\n    # Normalize\n    min_x = min(v[0] for v in voxels)\n    min_y = min(v[1] for v in voxels)\n    min_z = min(v[2] for v in voxels)\n    return set((x-min_x, y-min_y, z-min_z) for x,y,z in voxels)\n\ndef bbox(voxels):\n    max_x = max(v[0] for v in voxels) + 1\n    max_y = max(v[1] for v in voxels) + 1\n    max_z = max(v[2] for v in voxels) + 1\n    return max_x, max_y, max_z\n\ndef apply_transform(voxels, perm, signs):\n    perm_map = {'x': 0, 'y': 1, 'z': 2}\n    pi = [perm_map[c] for c in perm]\n    si = [1 if c == '+' else -1 for c in signs]\n    transformed = set()\n    for v in voxels:\n        nv = (si[0]*v[pi[0]], si[1]*v[pi[1]], si[2]*v[pi[2]])\n        transformed.add(nv)\n    # Normalize\n    min_x = min(v[0] for v in transformed)\n    min_y = min(v[1] for v in transformed)\n    "]
[150.413951, "o", "cat > /tmp/analyze.py << 'PYEOF'\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> with open('/task/objects.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     data = json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def get_voxels(name):\r\n\u001b[?2004l\r\u001b[?2004h>     voxels = set()\r\n\u001b[?2004l\r\u001b[?2004h>     for group in data[name].values():\r\n\u001b[?2004l\r\u001b[?2004h>         for v in group:\r\n\u001b[?2004l\r\u001b[?2004h>             voxels.add(tuple(v))\r\n\u001b[?2004l\r\u001b[?2004h>     # Normalize\r\n\u001b[?2004l\r\u001b[?2004h>     min_x = min(v[0] for v in voxels)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[150.413997, "i", "min_z = min(v[2] for v in transformed)\n    return set((x-min_x, y-min_y, z-min_z) for x,y,z in transformed)\n\ndef translate(voxels, ox, oy, oz):\n    return set((x+ox, y+oy, z+oz) for x,y,z in voxels)\n\n# Get all objects\nobjects = {}\nfor name in data:\n    objects[name] = get_voxels(name)\n    bx, by, bz = bbox(objects[name])\n    print(f'{name}: {len(objects[name])} voxels, bbox {bx}x{by}x{bz}={bx*by*bz}')\n\n# Check if bowl can nest with flipped bowl with offset\nbowl = objects['bowl1']\nprint(f'\\nBowl analysis:')\n\n# Try all 48 transforms for bowl and see which pairs can nest\nperms = ['xyz', 'xzy', 'yxz', 'yzx', 'zxy', 'zyx']\nsigns_list = []\nfor a in '+-':\n    for b in '+-':\n        for c in '+-':\n            signs_list.append(a+b+c)\n\n# For each transform, compute the bowl shape\nbowl_transforms = []\nfor perm in perms:\n    for signs in signs_list:\n        t = apply_transform(bowl, perm, signs)\n        bx, by, bz = bbox(t)\n        # Use frozenset as key to deduplicate\n        bowl_transforms.append((perm, signs, t, bx,"]
[150.414003, "o", "    min_y = min(v[1] for v in voxels)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[150.414027, "i", " by, bz))\n\n# Deduplicate by shape\nunique_shapes = {}\nfor perm, signs, t, bx, by, bz in bowl_transforms:\n    key = frozenset(t)\n    if key not in unique_shapes:\n        unique_shapes[key] = (perm, signs, bx, by, bz)\n\nprint(f'Unique bowl orientations: {len(unique_shapes)}')\nfor key, (perm, signs, bx, by, bz) in sorted(unique_shapes.items(), key=lambda x: x[1]):\n    print(f'  {perm} {signs}: {bx}x{by}x{bz}')\n\nPYEOF\npython3 /tmp/analyze.py\n"]
