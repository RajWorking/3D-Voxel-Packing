[366.480702, "o", "        max_y = max(v[1] for v in union)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.480793, "o", "        bx = max_x - min_x + 1\r\n\u001b[?2004l\r\u001b[?2004h>         by = max_y - min_y + 1\r\n\u001b[?2004l\r\u001b[?2004h>         vol = bx * by * 6\r\n\u001b[?2004l\r\u001b[?2004h"]
