[1034.663283, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[1034.663408, "o", "\u001b[?2004h>         # Try all offsets where the ball might overlap with the stack's z-range\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1034.663418, "o", "        for ox in range(-abdims[0]+1, sdims[0]):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1034.663612, "o", "            for oy in range(-abdims[1]+1, sdims[1]):\r\n\u001b[?2004l\r\u001b[?2004h>                 for oz in range(-abdims[2]+1, sdims[2]):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1034.663649, "o", "                    # Quick bbox check\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1034.663704, "o", "                    mn = [min(0, ox), min(0, oy), min(0, oz)]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1034.663792, "o", "                    mx = [max(sdims[0], ox+abdims[0]), max(sdims[1], oy+abdims[1]), max(sdims[2], oz+abdims[2])]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1034.663834, "o", "                    vol = (mx[0]-mn[0]) * (mx[1]-mn[1]) * (mx[2]-mn[2])\r\n\u001b[?2004l\r\u001b[?2004h>                     if vol >= best:\r\n\u001b[?2004l\r"]
[1034.663879, "o", "\u001b[?2004h> "]
[1034.663898, "o", "                        continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1034.663954, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1034.664047, "o", "                    ball_s = set((v[0]+ox, v[1]+oy, v[2]+oz) for v in ball_t)\r\n\u001b[?2004l\r\u001b[?2004h> "]
