[1889.464132, "o", "print(f\"Total donut1 placements: {len(donut1_placements)}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # For each donut1 placement, try to fit the rest\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1889.464295, "o", "rest = ['chocolate','donut2','match_box1','match_box2','match_box3','match_box4']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1889.464425, "o", "for di, (dp, dox, doy, doz, dplaced) in enumerate(donut1_placements):\r\n\u001b[?2004l\r\u001b[?2004h>     occ2 = occupied | dplaced\r\n\u001b[?2004l\r\u001b[?2004h"]
[1889.46445, "o", "> "]
[1889.46455, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h>     # Try multiple orderings of the rest\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1889.464707, "o", "    for trial in range(30):\r\n\u001b[?2004l\r\u001b[?2004h>         order = rest[:]\r\n\u001b[?2004l\r\u001b[?2004h>         if trial > 0:\r\n\u001b[?2004l\r\u001b[?2004h>             random.shuffle(order)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1889.464738, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1889.464817, "o", "        remaining = occ2.copy()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1889.464958, "o", "        placements = {'donut1': (dp, dox, doy, doz)}\r\n\u001b[?2004l\r\u001b[?2004h>         ok = True\r\n\u001b[?2004l\r\u001b[?2004h>         for name in order:\r\n\u001b[?2004l\r\u001b[?2004h"]
[1889.464973, "o", "> "]
[1889.465081, "o", "            valid = find_placements(small_objs[name], remaining, bbox)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1889.465136, "o", ">             if valid:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1889.465341, "o", "                p2,ox2,oy2,oz2,placed2 = valid[0]\r\n\u001b[?2004l\r\u001b[?2004h>                 remaining |= placed2\r\n\u001b[?2004l\r\u001b[?2004h"]
[1889.465684, "o", ">                 placements[name] = (p2,ox2,oy2,oz2)\r\n\u001b[?2004l\r\u001b[?2004h>             else:\r\n\u001b[?2004l\r\u001b[?2004h>                 ok = False\r\n\u001b[?2004l\r\u001b[?2004h>                 break\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         if ok:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1889.465903, "o", "            print(f\"SUCCESS! donut1 at ({dox},{doy},{doz}) perm={perm_names[perms_list.index(dp)]}\")\r\n\u001b[?2004l\r\u001b[?2004h>             for name in obj_names:\r\n\u001b[?2004l\r\u001b[?2004h>                 p,ox,oy,oz = placements[name]\r\n\u001b[?2004l\r\u001b[?2004h>                 pn = perm_names[perms_list.index(p)]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1889.466028, "o", "                print(f\"  {name}: {pn} +++ ({ox},{oy},{oz})\")\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h> "]
