[1186.452547, "i", "   \n    for x,y,z in ball:\n        occupied.add((x + ball_ox, y, z))\n    \n    # Verify\n    mn = [min(v[i] for v in occupied) for i in range(3)]\n    mx = [max(v[i] for v in occupied) for i in range(3)]\n    bbox = (mx[0]-mn[0]+1, mx[1]-mn[1]+1, mx[2]-mn[2]+1)\n    vol = bbox[0]*bbox[1]*bbox[2]\n    print(f\"  Bbox: {bbox[0]}x{bbox[1]}x{bbox[2]}={vol}, occupied={len(occupied)}\")\n    \n    if vol > 1440:\n        print(\"  Skipping (worse than current best)\")\n        continue\n    \n    # Normalize to origin\n    occupied = set((v[0]-mn[0], v[1]-mn[1], v[2]-mn[2]) for v in occupied)\n    bbox_norm = (bbox[0], bbox[1], bbox[2])\n    \n    # Try different orderings of small objects\n    obj_names = ['donut1', 'chocolate', 'donut2', 'match_box1', 'match_box2', 'match_box3', 'match_box4']\n    \n    result = try_place_all(occupied, bbox_norm, obj_names)\n    if result:\n        print(f\"  SUCCESS! All objects placed.\")\n        for name in obj_names:\n            p, ox, oy, oz = result[name]\n            pname = perm_names[perms_list.ind"]
