[1334.299246, "i", "]\n    \n    if vol > best_vol:\n        continue\n    \n    occupied = set((v[0]-mn[0], v[1]-mn[1], v[2]-mn[2]) for v in occupied)\n    \n    # Try many random orderings\n    for trial in range(200):\n        if trial == 0:\n            order = obj_names[:]\n        elif trial == 1:\n            order = list(reversed(obj_names))\n        else:\n            order = obj_names[:]\n            random.shuffle(order)\n        \n        result = greedy_place(occupied, bbox, order)\n        if result:\n            if vol < best_vol or (vol == best_vol and best_result is None):\n                best_vol = vol\n                best_result = (ball_ox, ball_oy, shift_y, bbox, result, mn)\n                print(f\"SUCCESS: {desc}, ball=({ball_ox},{ball_oy}), vol={vol}, order={order}\")\n                for name in obj_names:\n                    p, ox, oy, oz = result[name]\n                    pname = perm_names[perms_list.index(p)]\n                    print(f\"  {name}: perm={pname} offset=({ox},{oy},{oz})\")\n            if vol <= 1224:\n          "]
