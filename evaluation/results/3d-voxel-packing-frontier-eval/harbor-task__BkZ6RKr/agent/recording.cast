[1034.66428, "o", "\u001b[?2004h>                     amn = [min(v[i] for v in union) for i in range(3)]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1034.664309, "o", "                    amx = [max(v[i] for v in union) for i in range(3)]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1034.664387, "o", "                    actual_vol = 1\r\n\u001b[?2004l\r\u001b[?2004h>                     dims = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1034.664498, "o", "                    for i in range(3):\r\n\u001b[?2004l\r\u001b[?2004h>                         d = amx[i] - amn[i] + 1\r\n\u001b[?2004l\r\u001b[?2004h>                         actual_vol *= d\r\n\u001b[?2004l\r"]
[1034.664544, "o", "\u001b[?2004h> "]
[1034.66462, "o", "                        dims.append(d)\r\n\u001b[?2004l\r\u001b[?2004h>                     \r\n\u001b[?2004l\r\u001b[?2004h>                     if actual_vol < best:\r\n\u001b[?2004l\r\u001b[?2004h> "]
