[366.477931, "o", "# All unique bowl orientations (just need the bbox dimensions)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.477953, "o", "# Bowl is 12x4x6. Possible bbox orientations: permutations of (12,4,6)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.478043, "o", "# (12,4,6), (12,6,4), (4,12,6), (4,6,12), (6,12,4), (6,4,12)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.478117, "o", "# For each orientation, the bowl nesting works along the 4-dimension\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.478243, "o", "# (bowls can stack with offset 2 along the 4-dim axis)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.478327, "o", "# Let's think about it: the bowl is 12 long, 4 wide (with U-shape), 6 deep\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.478375, "o", "# The nesting works by shifting along the 4-wide dimension\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.478462, "o", "# So for any orientation, we stack along the axis that has size 4\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Key insight: 5 bowls stacked along the 4-dim with step 2:\r\n\u001b[?2004l\r\u001b[?2004h"]
[366.478487, "o", "> "]
[366.478565, "o", "# Total along that dim: 4 + 4*2 = 12\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.478596, "o", "# So 5 bowls always form a block of 12 x 12 x (other dim)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.47861, "o", "# Possible 5-bowl blocks:\r\n\u001b[?2004l\r"]
[366.478649, "o", "\u001b[?2004h> "]
[366.478687, "o", "# Orient (12,4,6) -> stack along y -> 12 x 12 x 6\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.478785, "o", "# Orient (12,6,4) -> stack along z -> 12 x 6 x 12  \r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.47893, "o", "# Orient (4,12,6) -> stack along x -> 12 x 12 x 6 (same volume)\r\n\u001b[?2004l\r\u001b[?2004h> # Orient (6,4,12) -> stack along y -> 6 x 12 x 12\r\n\u001b[?2004l\r\u001b[?2004h> # etc.\r\n\u001b[?2004l\r\u001b[?2004h> # All give 12 x 12 x {6 or 12} depending on orientation\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.479005, "o", "# Wait: the 6-dim and 12-dim are different.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.479131, "o", "# 5 bowls always give 12 x 12 x D where D is the remaining dimension (6)\r\n\u001b[?2004l\r\u001b[?2004h> # So 5-bowl block is always 12x12x6 = 864 (just rotated)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.47918, "o", "# Now the ball is 10x8x6. Can be oriented as:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.479294, "o", "# (10,8,6), (10,6,8), (8,10,6), (8,6,10), (6,10,8), (6,8,10)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Best arrangement: minimize total bounding box\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.479393, "o", "# Option 1: Same z-depth (6), side by side in xy\r\n\u001b[?2004l\r\u001b[?2004h> #   Bowls 12x12x6, Ball 10x8x6\r\n\u001b[?2004l\r"]
[366.479442, "o", "\u001b[?2004h> "]
[366.479492, "o", "#   Place ball next to bowls: various arrangements\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.479589, "o", "# Let me try: bowls 12x12 in xy, ball 10x8 in xy, both z=6\r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.479642, "o", "# Arrange in xy to minimize bounding box\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[366.47972, "o", "# The ball can be placed overlapping with the empty spaces in the bowl stack!\r\n\u001b[?2004l\r\u001b[?2004h> # Let me check this properly in 3D\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[366.4798, "o", "\u001b[?2004h> bowl_2d = set((x,y) for x,y,z in bowl if z == 0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
