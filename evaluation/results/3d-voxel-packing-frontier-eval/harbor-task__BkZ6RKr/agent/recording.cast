[1424.831239, "i", "cat > /tmp/solve14.py << 'PYEOF'\nimport json\nimport random\n\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\ndef get_voxels(name):\n    voxels = set()\n    for group in data[name].values():\n        for v in group:\n            voxels.add(tuple(v))\n    min_x = min(v[0] for v in voxels)\n    min_y = min(v[1] for v in voxels)\n    min_z = min(v[2] for v in voxels)\n    return set((x-min_x, y-min_y, z-min_z) for x,y,z in voxels)\n\ndef apply_perm(voxels, p):\n    transformed = set((v[p[0]], v[p[1]], v[p[2]]) for v in voxels)\n    mn = [min(v[i] for v in transformed) for i in range(3)]\n    return set((v[0]-mn[0], v[1]-mn[1], v[2]-mn[2]) for v in transformed)\n\nbowl = get_voxels('bowl1')\nball = get_voxels('ball')\nperms_list = [(0,1,2),(0,2,1),(1,0,2),(1,2,0),(2,0,1),(2,1,0)]\nperm_names = ['xyz','xzy','yxz','yzx','zxy','zyx']\n\nsmall_objects = {\n    'chocolate': get_voxels('chocolate'),\n    'donut1': get_voxels('donut1'),\n    'donut2': get_voxels('donut2'),\n    'match_box1': get_voxels('match_box1'),\n    'match_bo"]
[1424.831829, "o", "cat > /tmp/solve14.py << 'PYEOF'\r\n\u001b[?2004l\r"]
[1424.831898, "i", "x2': get_voxels('match_box2'),\n    'match_box3': get_voxels('match_box3'),\n    'match_box4': get_voxels('match_box4'),\n}\n\ndef find_placements_flex(obj_voxels, occ, max_vol, current_mn, current_mx):\n    \"\"\"Find placements that keep total volume under max_vol.\"\"\"\n    results = []\n    for p in perms_list:\n        rotated = apply_perm(obj_voxels, p)\n        rdims = [max(v[i] for v in rotated)+1 for i in range(3)]\n        # Allow placement anywhere that keeps volume under max_vol\n        for ox in range(max(0, current_mn[0]-1), current_mx[0]+2):\n            for oy in range(max(0, current_mn[1]-1), current_mx[1]+2):\n                for oz in range(max(0, current_mn[2]-1), current_mx[2]+2):\n                    new_mn = [min(current_mn[i], [ox,oy,oz][i]) for i in range(3)]\n                    new_mx = [max(current_mx[i], [ox,oy,oz][i]+rdims[i]-1) for i in range(3)]\n                    vol = 1\n                    for i in range(3):\n                        vol *= (new_mx[i] - new_mn[i] + 1)\n                    if vol >"]
[1424.83303, "o", "\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> import random\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> with open('/task/objects.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     data = json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def get_voxels(name):\r\n\u001b[?2004l\r\u001b[?2004h>     voxels = set()\r\n\u001b[?2004l\r\u001b[?2004h>     for group in data[name].values():\r\n\u001b[?2004l\r\u001b[?2004h>         for v in group:\r\n\u001b[?2004l\rx2': get_voxels('match_box2'),\r\n    'match_box3': get_voxels('match_box3'),\r\n    'match_box4': get_voxels('match_box4'),\r\n}\r\n\r\ndef find_placements_flex(obj_voxels, occ, max_vol, current_mn, current_mx):\r\n    \"\"\"Find placements that keep total volume under max_vol.\"\"\"\r\n    results = []\r\n    for p in perms_list:\r\n        rotated = apply_perm(obj_voxels, p)\r\n        rdims = [max(v[i] for v in rotated)+1 for i in range(3)]\r\n        # Allow placement anywhere that keeps volume under max_vol\r\n        for ox in range(max(0, current_mn[0]-1), current_mx[0]+2):\r\n            for oy in range(max(0, current_mn[1]-1), current_mx[1]+2):\r"]
