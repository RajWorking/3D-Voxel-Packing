[102.145915, "i", "python3 -c \"\nimport json\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\n# Analyze ball\nball_voxels = set()\nfor group in data['ball'].values():\n    for v in group:\n        ball_voxels.add(tuple(v))\nmin_x = min(v[0] for v in ball_voxels)\nmin_y = min(v[1] for v in ball_voxels)\nmin_z = min(v[2] for v in ball_voxels)\nball = set((x-min_x, y-min_y, z-min_z) for x,y,z in ball_voxels)\n\nmax_x = max(v[0] for v in ball)\nmax_y = max(v[1] for v in ball)\nmax_z = max(v[2] for v in ball)\n\nprint(f'Ball bbox: {max_x+1}x{max_y+1}x{max_z+1}')\nprint(f'Ball voxels: {len(ball)}')\nfull = set((x,y,z) for x in range(max_x+1) for y in range(max_y+1) for z in range(max_z+1))\ninterior = full - ball\nprint(f'Interior empty: {len(interior)}')\n\nprint()\nfor z in range(max_z+1):\n    print(f'Ball z={z}:')\n    for y in range(max_y+1):\n        row = ''\n        for x in range(max_x+1):\n            if (x,y,z) in ball:\n                row += '#'\n            else:\n                row += '.'\n        print(f'  y={y}: {row}')\n    print()\n"]
[102.148271, "o", "python3 -c \"\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> with open('/task/objects.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     data = json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Analyze ball\r\n\u001b[?2004l\r\u001b[?2004h> ball_voxels = set()\r\n\u001b[?2004l\r\u001b[?2004h> for group in data['ball'].values():\r\n\u001b[?2004l\r\u001b[?2004h>     for v in group:\r\n\u001b[?2004l\r\u001b[?2004h>         ball_voxels.add(tuple(v))\r\n\u001b[?2004l\r\u001b[?2004h> min_x = min(v[0] for v in ball_voxels)\r\n\u001b[?2004l\r\u001b[?2004h> "]
