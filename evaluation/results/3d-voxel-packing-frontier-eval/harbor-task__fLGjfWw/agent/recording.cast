[726.180929, "o", "\u001b[?2004h> def get_symmetries(voxels):\r\n\u001b[?2004l\r            print(f\"  Found packing in {iterations} iterations!\")\r\n            return placements\r\n    return None\r\n\r\nbest_placements = None\r\nbest_vol = float('inf')\r\n\r\nfor box in [(12, 12, 10), (12, 12, 9), (12, 11, 9), (12, 10, 9), (12, 12, 8), (12, 11, 8), (12, 10, 8)]:\r\n    print(f\"Trying {box}...\")\r\n    placements = try_pack(*box, timeout=15)\r\n    if placements:\r\n        vol = box[0] * box[1] * box[2]\r\n        print(f\"Success! Volume: {vol}\")\r\n        if vol < best_vol:\r\n            best_vol = vol\r\n            best_placements = placements\r\n            with open('solution_cmds.sh', 'w') as f:\r\n                for name, (perm, signs, x, y, z) in best_placements.items():\r\n                    f.write(f\"python3 /task/tools/place_object.py {name} {perm} {signs} {x} {y} {z}\\n\")\r\n                f.write(\"python3 /task/tools/finalize.py\\n\")\r\n    else:\r\n        print(\"Failed.\")\r\nEOF\r\npython3 better_pack.py\r\n"]
