[42.902208, "i", "cat << 'EOF' > visualize.py\nimport json\nwith open('/task/objects.json') as f:\n    objs = json.load(f)\n\ndef print_obj(name):\n    print(f\"--- {name} ---\")\n    voxels = []\n    for layer in objs[name].values():\n        voxels.extend(layer)\n    if not voxels: return\n    min_x = min(v[0] for v in voxels)\n    max_x = max(v[0] for v in voxels)\n    min_y = min(v[1] for v in voxels)\n    max_y = max(v[1] for v in voxels)\n    min_z = min(v[2] for v in voxels)\n    max_z = max(v[2] for v in voxels)\n    \n    for z in range(min_z, max_z + 1):\n        print(f\"z={z}\")\n        for y in range(min_y, max_y + 1):\n            row = \"\"\n            for x in range(min_x, max_x + 1):\n                if [x, y, z] in voxels or [x, y, z] in voxels:\n                    row += \"X\"\n                else:\n                    row += \".\"\n            print(row)\n\nfor name in ['bowl1', 'ball', 'chocolate', 'donut1', 'donut2', 'match_box1']:\n    print_obj(name)\nEOF\npython3 visualize.py\n"]
[42.902573, "o", "cat << 'EOF' > visualize.py\r\n\u001b[?2004l\r\u001b[?2004h> "]
