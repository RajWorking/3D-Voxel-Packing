bowl_syms = get_symmetries(bowl)
print(f"Bowl has {len(bowl_syms)} unique symmetries")

# Find best shift for 2 bowls
best_vol = 100000
best_pair = None

v1_set = set(map(tuple, bowl))

for sym_idx, v2 in enumerate(bowl_syms):
    for dx in range(-12, 13):
        for dy in range(-12, 13):
            for dz in range(-12, 13):
                v2_shifted = v2 + [dx, dy, dz]
                v2_set = set(map(tuple, v2_shifted))
                if not v1_set.intersection(v2_set):
                    # valid placement
                    all_v = np.vstack((bowl, v2_shifted))
                    min_c = all_v.min(axis=0)
                    max_c = all_v.max(axis=0)
                    vol = np.prod(max_c - min_c + 1)
                    if vol < best_vol:
                        best_vol = vol
                        best_pair = (sym_idx, dx, dy, dz)

print(f"Best 2-bowl volume: {best_vol} at shift {best_pair}")
