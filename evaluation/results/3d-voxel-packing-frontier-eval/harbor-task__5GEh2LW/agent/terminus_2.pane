[?2004l[?2004h> signs=list(itertools.product([1,-1], repeat=3))
[?2004l[?2004h> 
[?2004l[?2004h> def transform(pts,perm,sgn):
[?2004ln sgn),dims,vox)
    orients[name]=list(seen.values())

names=sorted(objs, key=lambda n: -len(objs[n]))
print('order', names)

def search(W,H,D,limit_orients=6, timelimit=20):
    start=time.time()
    occ=set()
    placed=[]
    # reduce orientation count by preferring low z extent then area
    orient_choices={}
    for n in names:
        cand=[o for o in orients[n] if o[2][2] <= D and o[2][1] <= H and o[2][0] <= W]
        cand.sort(key=lambda o:(o[2][2],o[2][1]*o[2][0],o[2]))
        orient_choices[n]=cand[:limit_orients] if len(cand)>limit_orients else cand
    def first_empty():
        for z in range(D):
            for y in range(H):
                for x in range(W):
                    if (x,y,z) not in occ:
                        return (x,y,z)
        return None
    def rec(i):
        if time.time()-start>timelimit:
            raise TimeoutError
        if i==len(names):
            return True
        anchor=first_empty()
        n=names[i]
        tried=set()
        for perm,sgn,dims,vox in orient_choices[n]:
            if dims in tried: 
                pass
            tried.add(dims)
            ax,ay,az=anchor
            # try aligning one voxel of piece to anchor for a few low voxels
            lowvox=[v for v in vox if v[2]==0]
            lowvox=lowvox[:min(12,len(lowvox))]
            for vx,vy,vz in lowvox:
                ox,oy,oz=ax-vx,ay-vy,az-vz
                if ox<0 or oy<0 or oz<0: continue
                if ox+dims[0]>W or oy+dims[1]>H or oz+dims[2]>D: continue
                pts=[(x+ox,y+oy,z+oz) for x,y,z in vox]
                if any(p in occ for p in pts): continue
                occ.update(pts); placed.append((n,perm,sgn,ox,oy,oz,dims))
                if rec(i+1): return True
                placed.pop()
                for p in pts: occ.remove(p)
