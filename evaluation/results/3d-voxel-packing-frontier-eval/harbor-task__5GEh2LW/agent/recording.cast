[166.766848, "i", "python3 - <<'PY'\nimport json,time,sys\nwith open('/task/objects.json') as f:\n    data=json.load(f)\nobjs={n:sorted(set(tuple(p) for g in obj.values() for p in g)) for n,obj in data.items()}\n\ndef transf(pts,perm,signs):\n    out=[]\n    for p in pts:\n        d={'x':p[0],'y':p[1],'z':p[2]}\n        q=[(1 if signs[i]=='+' else -1)*d[perm[i]] for i in range(3)]\n        out.append(tuple(q))\n    mins=[min(a[i] for a in out) for i in range(3)]\n    out=tuple(sorted((a[0]-mins[0],a[1]-mins[1],a[2]-mins[2]) for a in out))\n    dims=(max(a[0] for a in out)+1,max(a[1] for a in out)+1,max(a[2] for a in out)+1)\n    return set(out),dims\nchoices={\n 'ball':[('xyz','+++'),('yxz','+++')],\n 'bowl1':[('xyz','+++'),('yxz','+++')],\n 'bowl2':[('xyz','+++'),('yxz','+++')],\n 'bowl3':[('xyz','+++'),('yxz','+++')],\n 'bowl4':[('xyz','+++'),('yxz','+++')],\n 'bowl5':[('xyz','+++'),('yxz','+++')],\n 'donut1':[('xyz','+++'),('yzx','+++'),('zxy','+++')],\n 'donut2':[('xyz','+++'),('yzx','+++'),('zxy','+++')],\n 'chocolate':[('xyz','+++'),('yzx','+++')"]
[166.768295, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json,time,sys\r\n\u001b[?2004l\r\u001b[?2004h> with open('/task/objects.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     data=json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> objs={n:sorted(set(tuple(p) for g in obj.values() for p in g)) for n,obj in data.items()}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def transf(pts,perm,signs):\r\n\u001b[?2004l\r\u001b[?2004h>     out=[]\r\n\u001b[?2004l\r"]
[166.768451, "i", ",('zxy','+++')],\n 'match_box1':[('xyz','+++'),('xzy','+++'),('yxz','+++')],\n 'match_box2':[('xyz','+++'),('xzy','+++'),('yxz','+++')],\n 'match_box3':[('xyz','+++'),('xzy','+++'),('yxz','+++')],\n 'match_box4':[('xyz','+++'),('xzy','+++'),('yxz','+++')],\n}\nshapes={}\nfor n,opts in choices.items():\n    arr=[]; seen=set()\n    for perm,sgn in opts:\n        vox,d=transf(objs[n],perm,sgn)\n        key=tuple(sorted(vox))\n        if key not in seen:\n            seen.add(key); arr.append((perm,sgn,vox,d))\n    shapes[n]=arr\nW,H,D=24,20,6\nocc=set(); placed=[]\ndef add(name,perm,sgn,vox,dims,off):\n    ox,oy,oz=off\n    pts={(x+ox,y+oy,z+oz) for x,y,z in vox}\n    if ox<0 or oy<0 or oz<0 or ox+dims[0]>W or oy+dims[1]>H or oz+dims[2]>D or (occ & pts): return False\n    occ.update(pts); placed.append((name,perm,sgn,ox,oy,oz,pts,dims)); return True\ndef rem():\n    *_,pts,_=placed.pop(); occ.difference_update(pts)\ndef cur():\n    xs=[p[0] for p in occ]; ys=[p[1] for p in occ]; zs=[p[2] for p in occ]\n    return (max(xs)+1)*(max(ys)+1)*"]
[166.768484, "o", "\u001b[?2004h>     for p in pts:\r\n\u001b[?2004l\r\u001b[?2004h>         d={'x':p[0],'y':p[1],'z':p[2]}\r\n\u001b[?2004l\r\u001b[?2004h> "]
