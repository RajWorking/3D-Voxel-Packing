[61.095004, "i", "python3 - <<'PY'\nimport json,itertools,sys,time\nwith open('/task/objects.json') as f:\n    data=json.load(f)\nobjs={}\nfor name,obj in data.items():\n    pts=[]\n    for g,arr in obj.items():\n        pts.extend(map(tuple,arr))\n    objs[name]=sorted(set(pts))\nperms=['xyz','xzy','yxz','yzx','zxy','zyx']\nsigns=list(itertools.product([1,-1], repeat=3))\n\ndef transform(pts,perm,sgn):\n    out=[]\n    for p in pts:\n        d={'x':p[0],'y':p[1],'z':p[2]}\n        q=[sgn[i]*d[perm[i]] for i in range(3)]\n        out.append(tuple(q))\n    mins=[min(p[i] for p in out) for i in range(3)]\n    out=tuple(sorted((p[0]-mins[0],p[1]-mins[1],p[2]-mins[2]) for p in out))\n    dims=(max(p[0] for p in out)+1,max(p[1] for p in out)+1,max(p[2] for p in out)+1)\n    return out,dims\n\norients={}\nfor name,pts in objs.items():\n    seen={}\n    for perm in perms:\n        for sgn in signs:\n            vox,dims=transform(pts,perm,sgn)\n            key=vox\n            if key not in seen:\n                seen[key]=(perm,''.join('+' if x==1 else '-' for x i"]
[61.09596, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r"]
[61.096164, "i", "n sgn),dims,vox)\n    orients[name]=list(seen.values())\n\nnames=sorted(objs, key=lambda n: -len(objs[n]))\nprint('order', names)\n\ndef search(W,H,D,limit_orients=6, timelimit=20):\n    start=time.time()\n    occ=set()\n    placed=[]\n    # reduce orientation count by preferring low z extent then area\n    orient_choices={}\n    for n in names:\n        cand=[o for o in orients[n] if o[2][2] <= D and o[2][1] <= H and o[2][0] <= W]\n        cand.sort(key=lambda o:(o[2][2],o[2][1]*o[2][0],o[2]))\n        orient_choices[n]=cand[:limit_orients] if len(cand)>limit_orients else cand\n    def first_empty():\n        for z in range(D):\n            for y in range(H):\n                for x in range(W):\n                    if (x,y,z) not in occ:\n                        return (x,y,z)\n        return None\n    def rec(i):\n        if time.time()-start>timelimit:\n            raise TimeoutError\n        if i==len(names):\n            return True\n        anchor=first_empty()\n        n=names[i]\n        tried=set()\n        for perm,sgn,dims,vox i"]
