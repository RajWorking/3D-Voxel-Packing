[61.096709, "i", "     if V<968 or V>1152: continue\n        cands.append((V,W,H,D))\ncands.sort()\nfor V,W,H,D in cands[:80]:\n    print('try',W,H,D,'V',V)\n    ok,placed,t=search(W,H,D,limit_orients=8,timelimit=6)\n    print(' ->',ok,'time',round(t,2),'placed',len(placed))\n    if ok:\n        print('FOUND',W,H,D,V)\n        for p in placed:\n            print('python3 /task/tools/place_object.py', p[0], p[1], p[2], p[3], p[4], p[5])\n        sys.exit(0)\nprint('no solution found')\nPY\n"]
