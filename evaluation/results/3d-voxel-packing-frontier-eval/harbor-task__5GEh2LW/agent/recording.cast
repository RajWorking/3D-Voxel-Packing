[61.096328, "i", "n orient_choices[n]:\n            if dims in tried: \n                pass\n            tried.add(dims)\n            ax,ay,az=anchor\n            # try aligning one voxel of piece to anchor for a few low voxels\n            lowvox=[v for v in vox if v[2]==0]\n            lowvox=lowvox[:min(12,len(lowvox))]\n            for vx,vy,vz in lowvox:\n                ox,oy,oz=ax-vx,ay-vy,az-vz\n                if ox<0 or oy<0 or oz<0: continue\n                if ox+dims[0]>W or oy+dims[1]>H or oz+dims[2]>D: continue\n                pts=[(x+ox,y+oy,z+oz) for x,y,z in vox]\n                if any(p in occ for p in pts): continue\n                occ.update(pts); placed.append((n,perm,sgn,ox,oy,oz,dims))\n                if rec(i+1): return True\n                placed.pop()\n                for p in pts: occ.remove(p)\n        return False\n    try:\n        ok=rec(0)\n    except TimeoutError:\n        ok=False\n    return ok,placed,time.time()-start\n\ncands=[]\nfor W in range(10,25):\n    for H in range(8,25):\n        D=6\n        V=W*H*D\n   "]
