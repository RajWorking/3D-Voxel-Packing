[12.761083, "i", "python3 - <<'PY'\nimport json\nwith open('/task/objects.json') as f:\n    data=json.load(f)\nprint('objects:', list(data))\nfor name,obj in data.items():\n    pts=[]\n    for g,arr in obj.items():\n        pts.extend(map(tuple,arr))\n    xs=[p[0] for p in pts]; ys=[p[1] for p in pts]; zs=[p[2] for p in pts]\n    print(name, 'voxels=',len(set(pts)), 'bbox=', (max(xs)-min(xs)+1, max(ys)-min(ys)+1, max(zs)-min(zs)+1))\nPY\n"]
