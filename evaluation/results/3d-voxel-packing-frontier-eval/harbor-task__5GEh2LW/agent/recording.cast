[37.970568, "i", "python3 - <<'PY'\nimport json, itertools, math\nfrom collections import defaultdict\nwith open('/task/objects.json') as f:\n    data=json.load(f)\nobjs={}\nfor name,obj in data.items():\n    pts=[]\n    for g,arr in obj.items():\n        pts.extend(map(tuple,arr))\n    objs[name]=sorted(set(pts))\nperms=['xyz','xzy','yxz','yzx','zxy','zyx']\nsign_opts=list(itertools.product([1,-1], repeat=3))\n\ndef tr(pt,perm,sgn):\n    d={'x':pt[0],'y':pt[1],'z':pt[2]}\n    q=[sgn[i]*d[perm[i]] for i in range(3)]\n    return tuple(q)\n\ndef norm(pts):\n    mins=[min(p[i] for p in pts) for i in range(3)]\n    return tuple(sorted((p[0]-mins[0],p[1]-mins[1],p[2]-mins[2]) for p in pts))\n\norients={}\nfor name,pts in objs.items():\n    seen={}\n    for perm in perms:\n        for sgn in sign_opts:\n            n=norm([tr(p,perm,sgn) for p in pts])\n            if n not in seen:\n                mx=[max(p[i] for p in n)+1 for i in range(3)]\n                seen[n]=(perm,''.join('+' if x==1 else '-' for x in sgn),mx,n)\n    orients[name]=list(seen.values())\n  "]
[37.971001, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> "]
