[77.932223, "i", "python3 - <<'PY'\nimport json\nwith open('/task/objects.json') as f:\n    data=json.load(f)\nfor name in ['ball','bowl1']:\n    pts=[]\n    for g,arr in data[name].items():\n        pts.extend(map(tuple,arr))\n    pts=sorted(set(pts))\n    print('\\n',name)\n    zs=sorted(set(p[2] for p in pts))\n    for z in zs:\n        layer=[(x,y) for x,y,zz in pts if zz==z]\n        xs=[p[0] for p in layer]; ys=[p[1] for p in layer]\n        print('z=',z,'count=',len(layer),'bbox=',(min(xs),max(xs),min(ys),max(ys)))\n        for y in range(min(ys),max(ys)+1):\n            row=''\n            for x in range(min(xs),max(xs)+1):\n                row += '#' if (x,y) in layer else '.'\n            print(row)\n        print()\nPY\n"]
