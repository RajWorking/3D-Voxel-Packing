[95.487336, "i", "python3 - <<'PY'\nimport json,itertools\nwith open('/task/objects.json') as f:\n    data=json.load(f)\npts=sorted(set(tuple(p) for g in data['bowl1'].values() for p in g))\nball=sorted(set(tuple(p) for g in data['ball'].values() for p in g))\n\ndef transf(pts,perm,signs):\n    out=[]\n    for p in pts:\n        d={'x':p[0],'y':p[1],'z':p[2]}\n        q=[(1 if signs[i]=='+' else -1)*d[perm[i]] for i in range(3)]\n        out.append(tuple(q))\n    mins=[min(a[i] for a in out) for i in range(3)]\n    out=[(a[0]-mins[0],a[1]-mins[1],a[2]-mins[2]) for a in out]\n    dims=(max(a[0] for a in out)+1,max(a[1] for a in out)+1,max(a[2] for a in out)+1)\n    return set(out),dims\nbowlset,bd=transf(pts,'xyz','+++')\nballset,ad=transf(ball,'xyz','+++')\nprint('bowl dims',bd,'ball dims',ad)\nbest=[]\nfor ox in range(-10,13):\n  for oy in range(-8,9):\n    for oz in range(-5,6):\n      shifted={(x+ox,y+oy,z+oz) for x,y,z in ballset}\n      inter=bowlset & shifted\n      if not inter:\n        xs=[p[0] for p in bowlset|shifted]; ys=[p[1] for p in bowls"]
[95.487417, "i", "et|shifted]; zs=[p[2] for p in bowlset|shifted]\n        bb=(max(xs)-min(xs)+1,max(ys)-min(ys)+1,max(zs)-min(zs)+1)\n        vol=bb[0]*bb[1]*bb[2]\n        best.append((vol,bb,(ox,oy,oz)))\nbest.sort()\nprint('best non-overlap placements count',len(best))\nfor item in best[:20]:\n    print(item)\nPY\n"]
