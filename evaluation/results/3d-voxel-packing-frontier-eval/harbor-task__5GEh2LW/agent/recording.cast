[120.278335, "i", "python3 - <<'PY'\nimport json,itertools,math,sys,time\nwith open('/task/objects.json') as f:\n    data=json.load(f)\nobjs={n:sorted(set(tuple(p) for g in obj.values() for p in g)) for n,obj in data.items()}\n\ndef transf(pts,perm,signs):\n    out=[]\n    for p in pts:\n        d={'x':p[0],'y':p[1],'z':p[2]}\n        q=[(1 if signs[i]=='+' else -1)*d[perm[i]] for i in range(3)]\n        out.append(tuple(q))\n    mins=[min(a[i] for a in out) for i in range(3)]\n    out=tuple(sorted((a[0]-mins[0],a[1]-mins[1],a[2]-mins[2]) for a in out))\n    dims=(max(a[0] for a in out)+1,max(a[1] for a in out)+1,max(a[2] for a in out)+1)\n    return set(out),dims\n\n# Choose a small orientation set emphasizing z<=6\nchoices={\n 'ball':[('xyz','+++'),('yxz','+++')],\n 'bowl1':[('xyz','+++'),('yxz','+++')],\n 'bowl2':[('xyz','+++'),('yxz','+++')],\n 'bowl3':[('xyz','+++'),('yxz','+++')],\n 'bowl4':[('xyz','+++'),('yxz','+++')],\n 'bowl5':[('xyz','+++'),('yxz','+++')],\n 'donut1':[('xyz','+++'),('yzx','+++'),('zxy','+++')],\n 'donut2':[('xyz','+++'),('yzx"]
[120.282459, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json,itertools,math,sys,time\r\n\u001b[?2004l\r\u001b[?2004h> with open('/task/objects.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     data=json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> objs={n:sorted(set(tuple(p) for g in obj.values() for p in g)) for n,obj in data.items()}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def transf(pts,perm,signs):\r\n\u001b[?2004l\r\u001b[?2004h>     out=[]\r\n\u001b[?2004l\r\u001b[?2004h>     for p in pts:\r\n\u001b[?2004l\r\u001b[?2004h>         d={'x':p[0],'y':p[1],'z':p[2]}\r\n\u001b[?2004l\r\u001b[?2004h>         q=[(1 if signs[i]=='+' else -1)*d[perm[i]] for i in range(3)]\r\n\u001b[?2004l\r\u001b[?2004h>         out.append(tuple(q))\r\n\u001b[?2004l\r\u001b[?2004h"]
[120.285283, "i", "','+++'),('zxy','+++')],\n 'chocolate':[('xyz','+++'),('yzx','+++'),('zxy','+++')],\n 'match_box1':[('xyz','+++'),('xzy','+++'),('yxz','+++')],\n 'match_box2':[('xyz','+++'),('xzy','+++'),('yxz','+++')],\n 'match_box3':[('xyz','+++'),('xzy','+++'),('yxz','+++')],\n 'match_box4':[('xyz','+++'),('xzy','+++'),('yxz','+++')],\n}\nshapes={}\nfor n,opts in choices.items():\n    arr=[]\n    seen=set()\n    for perm,sgn in opts:\n        vox,d=transf(objs[n],perm,sgn)\n        if tuple(sorted(vox)) not in seen:\n            seen.add(tuple(sorted(vox)))\n            arr.append((perm,sgn,vox,d))\n    shapes[n]=arr\n\n# seed arrangement: bowl1 at origin, ball at (1,4,0) gives combined 12x12x6 after shifting y by +4 from previous relative (1,-5,0)\nW,H,D=24,20,6\nocc=set(); placed=[]\n\ndef add(name,perm,sgn,vox,dims,off):\n    ox,oy,oz=off\n    pts={(x+ox,y+oy,z+oz) for x,y,z in vox}\n    if ox<0 or oy<0 or oz<0: return False\n    if ox+dims[0]>W or oy+dims[1]>H or oz+dims[2]>D: return False\n    if occ & pts: return False\n    occ.update(pts); pl"]
