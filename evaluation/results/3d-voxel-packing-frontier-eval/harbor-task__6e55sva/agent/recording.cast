[95.581714, "i", "python3 - <<'PY'\nimport json,itertools\nwith open('/task/objects.json') as f:\n    data=json.load(f)\npts=[]\nfor arr in data['bowl1'].values(): pts.extend(map(tuple,arr))\npts=set(pts)\nperms=['xyz','xzy','yxz','yzx','zxy','zyx']\nsigns=['+++','++-','+-+','+--','-++','-+-','--+','---']\n\ndef tr(pts,perm,sign):\n    out=[]\n    for x,y,z in pts:\n        d={'x':x,'y':y,'z':z}\n        q=[d[perm[i]] for i in range(3)]\n        q=[q[i] if sign[i]=='+' else -q[i] for i in range(3)]\n        out.append(tuple(q))\n    mins=[min(p[i] for p in out) for i in range(3)]\n    out={(p[0]-mins[0],p[1]-mins[1],p[2]-mins[2]) for p in out}\n    dims=(max(p[0] for p in out)+1,max(p[1] for p in out)+1,max(p[2] for p in out)+1)\n    return out,dims\n# show one orientation for each dims\nshown=set()\nfor perm in perms:\n    for sign in signs:\n        out,dims=tr(pts,perm,sign)\n        if dims in shown: continue\n        shown.add(dims)\n        print('\\nBOWL orientation',perm,sign,'dims',dims)\n        xs=range(dims[0]); ys=range(dims[1]); zs=range(dims"]
[95.581838, "i", "[2])\n        # print occupancy collapsed along smallest axis if possible\n        for z in zs[:min(6,dims[2])]:\n            print('slice',z)\n            for y in reversed(list(ys)):\n                print(''.join('#' if (x,y,z) in out else '.' for x in xs))\n        if len(shown)==6: raise SystemExit\nPY\n"]
