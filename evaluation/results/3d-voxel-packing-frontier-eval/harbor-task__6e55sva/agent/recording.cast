[46.552562, "i", "python3 - <<'PY'\nimport json,itertools,math,time\nfrom collections import defaultdict\n\nwith open('/task/objects.json') as f:\n    data=json.load(f)\nobjs={}\nfor name,obj in data.items():\n    pts=[]\n    for arr in obj.values(): pts.extend(map(tuple,arr))\n    objs[name]=sorted(set(pts))\n\nperms=['xyz','xzy','yxz','yzx','zxy','zyx']\nsigns=[''.join(s) for s in itertools.product('+-', repeat=3)]\n\ndef transf(pts,perm,sign):\n    out=[]\n    for x,y,z in pts:\n        d={'x':x,'y':y,'z':z}\n        q=[d[perm[i]] for i in range(3)]\n        q=[q[i] if sign[i]=='+' else -q[i] for i in range(3)]\n        out.append(tuple(q))\n    mins=[min(p[i] for p in out) for i in range(3)]\n    out=sorted((p[0]-mins[0],p[1]-mins[1],p[2]-mins[2]) for p in out)\n    dims=(max(p[0] for p in out)+1,max(p[1] for p in out)+1,max(p[2] for p in out)+1)\n    return tuple(out),dims\n\norients={}\nfor name,pts in objs.items():\n    seen={}\n    for perm in perms:\n        for sign in signs:\n            out,dims=transf(pts,perm,sign)\n            seen.setdefault(o"]
