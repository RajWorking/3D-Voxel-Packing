[226.702263, "o", "\u001b[?2004h>         for z in range(box[2]):\r\n\u001b[?2004l\r\u001b[?2004h>             for y in range(box[1]):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[226.702279, "o", "                for x in range(box[0]):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[226.702579, "o", "                    if (x,y,z) not in occ:\r\n\u001b[?2004l\r\u001b[?2004h>                         anchor=(x,y,z); break\r\n\u001b[?2004l\r\u001b[?2004h>                 if anchor: break\r\n\u001b[?2004l\r\u001b[?2004h>             if anchor: break\r\n\u001b[?2004l\r\u001b[?2004h>     cand=placements[name]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[226.702969, "o", "    # prefer placements near origin and intersecting anchor neighborhood if possible\r\n\u001b[?2004l\r\u001b[?2004h>     cand2=[]\r\n\u001b[?2004l\r\u001b[?2004h>     for p in cand:\r\n\u001b[?2004l\r\u001b[?2004h>         vox=p[6]\r\n\u001b[?2004l\r\u001b[?2004h>         s=set(vox)\r\n\u001b[?2004l\r\u001b[?2004h>         if any(v in occ for v in vox):\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h>         score=(p[4],p[3],p[2])\r\n\u001b[?2004l\r\u001b[?2004h>         if anchor is None or anchor in s:\r\n\u001b[?2004l\r\u001b[?2004h>             cand2.append((0,score,p))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[226.703056, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h>             ax,ay,az=anchor\r\n\u001b[?2004l\r"]
[226.703109, "o", "\u001b[?2004h>             md=min(abs(x-ax)+abs(y-ay)+abs(z-az) for x,y,z in vox)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[226.703192, "o", "            cand2.append((1+md,score,p))\r\n\u001b[?2004l\r\u001b[?2004h>     cand2.sort(key=lambda t:(t[0],t[1]))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[226.703215, "o", "    for _,_,p in cand2[:400]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
