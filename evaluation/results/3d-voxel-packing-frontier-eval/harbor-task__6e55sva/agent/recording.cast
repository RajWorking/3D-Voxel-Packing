[25.983435, "o", "\u001b[?2004huser@61aa19fdb377:~$ "]
[26.285989, "i", "python3 - <<'PY'\nimport json,itertools\nwith open('/task/objects.json') as f:\n    data=json.load(f)\nperms=['xyz','xzy','yxz','yzx','zxy','zyx']\nsigns=[''.join(s) for s in itertools.product('+-', repeat=3)]\nfor name,obj in data.items():\n    pts=[]\n    for arr in obj.values():\n        pts.extend(map(tuple,arr))\n    seen={}\n    for perm in perms:\n        for sign in signs:\n            out=[]\n            for x,y,z in pts:\n                d={'x':x,'y':y,'z':z}\n                q=[d[perm[i]] for i in range(3)]\n                q=[q[i] if sign[i]=='+' else -q[i] for i in range(3)]\n                out.append(tuple(q))\n            mins=[min(p[i] for p in out) for i in range(3)]\n            out=[(p[0]-mins[0],p[1]-mins[1],p[2]-mins[2]) for p in out]\n            dims=tuple(max(p[i] for p in out)+1 for i in range(3))\n            seen.setdefault(dims,0)\n            seen[dims]+=1\n    print(name, 'unique_dims', sorted(seen.items()))\nPY\n"]
[26.286128, "o", "python3 - <<'PY'"]
[26.286194, "o", "\r\n\u001b[?2004l\r"]
[26.286264, "o", "\u001b[?2004h> import json,itertools\r\n\u001b[?2004l\r\u001b[?2004h"]
[26.286299, "o", "> "]
