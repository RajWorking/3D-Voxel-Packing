[114.57833, "i", "python3 - <<'PY'\nimport json,itertools,time\nwith open('/task/objects.json') as f:\n    data=json.load(f)\npts=[]\nfor arr in data['bowl1'].values(): pts.extend(map(tuple,arr))\npts=set(pts)\nperms=['xyz','xzy','yxz','yzx','zxy','zyx']\nsigns=['+++','++-','+-+','+--','-++','-+-','--+','---']\n\ndef tr(pts,perm,sign):\n    out=[]\n    for x,y,z in pts:\n        d={'x':x,'y':y,'z':z}\n        q=[d[perm[i]] for i in range(3)]\n        q=[q[i] if sign[i]=='+' else -q[i] for i in range(3)]\n        out.append(tuple(q))\n    mins=[min(p[i] for p in out) for i in range(3)]\n    out={(p[0]-mins[0],p[1]-mins[1],p[2]-mins[2]) for p in out}\n    dims=(max(p[0] for p in out)+1,max(p[1] for p in out)+1,max(p[2] for p in out)+1)\n    return out,dims\nori=[]; seen={}\nfor perm in perms:\n    for sign in signs:\n        out,dims=tr(pts,perm,sign)\n        if out not in seen:\n            seen[out]=(perm,sign,dims)\n            ori.append((perm,sign,dims,out))\nprint('orientations',len(ori))\n\nbest=None\nstart=time.time()\nN=5\n\ndef search(box, idx, occ, p"]
[114.578771, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r"]
[114.579478, "i", "lacements, frontier):\n    if time.time()-start>25: return False\n    if idx==N: return True\n    cand=sorted(frontier|{(0,0,0)}, key=lambda p:(p[2],p[1],p[0]))[:80]\n    for perm,sign,dims,out in sorted(ori, key=lambda t:(t[2][2],t[2][1],t[2][0])):\n        dx,dy,dz=dims\n        for ox,oy,oz in cand:\n            if ox+dx>box[0] or oy+dy>box[1] or oz+dz>box[2]: continue\n            placed=[]; ok=True\n            for p in out:\n                q=(p[0]+ox,p[1]+oy,p[2]+oz)\n                if q in occ: ok=False; break\n                placed.append(q)\n            if not ok: continue\n            for q in placed: occ.add(q)\n            placements.append((perm,sign,ox,oy,oz,dims))\n            nf=set(frontier)\n            nf.update([(ox+dx,oy,oz),(ox,oy+dy,oz),(ox,oy,oz+dz)])\n            if search(box, idx+1, occ, placements, nf): return True\n            placements.pop()\n            for q in placed: occ.remove(q)\n    return False\n\nvol=108*N\ncands=[]\nfor X in range(4,25):\n  for Y in range(4,25):\n    for Z in range(4,25):\n   "]
[114.579489, "o", "\u001b[?2004h> import json,itertools,time\r\n\u001b[?2004l\r\u001b[?2004h> with open('/task/objects.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     data=json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> pts=[]\r\n\u001b[?2004l\r\u001b[?2004h> for arr in data['bowl1'].values(): pts.extend(map(tuple,arr))\r\n\u001b[?2004l\r\u001b[?2004h> pts=set(pts)\r\n\u001b[?2004l\r\u001b[?2004h> perms=['xyz','xzy','yxz','yzx','zxy','zyx']\r\n\u001b[?2004l\r\u001b[?2004h> signs=['+++','++-','+-+','+--','-++','-+-','--+','---']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def tr(pts,perm,sign):\r\n\u001b[?2004l\r\u001b[?2004h>     out=[]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[114.579498, "i", "   if X*Y*Z<vol: continue\n      cands.append((X*Y*Z,(X,Y,Z)))\nfor v,box in sorted(cands)[:250]:\n    print('try',box,'vol',v)\n    occ=set(); placements=[]\n    if search(box,0,occ,placements,set()):\n        print('FOUND',box,v)\n        for i,p in enumerate(placements,1): print('bowl',i,p)\n        break\nelse:\n    print('none found in time')\nPY\n"]
