[9.653215, "i", "python3 - <<'PY'\nimport json\nfrom pprint import pprint\nwith open('/task/objects.json') as f:\n    data=json.load(f)\nprint('objects:', list(data))\nfor name,obj in data.items():\n    pts=[]\n    for grp,arr in obj.items():\n        pts.extend(map(tuple,arr))\n    xs=[p[0] for p in pts]; ys=[p[1] for p in pts]; zs=[p[2] for p in pts]\n    print(name, 'voxels', len(set(pts)), 'bbox', (max(xs)-min(xs)+1, max(ys)-min(ys)+1, max(zs)-min(zs)+1))\nPY\n"]
[9.653427, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> from pprint import pprint\r\n\u001b[?2004l\r\u001b[?2004h> with open('/task/objects.json') as f:"]
