[95.325056, "i", "python3 - <<'PY'\nimport json\nfrom collections import defaultdict\nwith open('/task/objects.json') as f:\n    data=json.load(f)\nfor name in ['bowl1','ball','donut1','donut2','chocolate']:\n    pts=[]\n    for arr in data[name].values(): pts.extend(map(tuple,arr))\n    pts=set(pts)\n    xs=sorted(set(x for x,_,_ in pts)); ys=sorted(set(y for _,y,_ in pts)); zs=sorted(set(z for _,_,z in pts))\n    print('\\nOBJECT',name,'count',len(pts),'bbox',(max(xs)+1,max(ys)+1,max(zs)+1))\n    print('x-slices counts:', [sum(1 for p in pts if p[0]==x) for x in xs])\n    print('y-slices counts:', [sum(1 for p in pts if p[1]==y) for y in ys])\n    print('z-slices counts:', [sum(1 for p in pts if p[2]==z) for z in zs])\n    print('xy footprint by y descending (# occupied in z-collapsed slice):')\n    for y in reversed(ys):\n        row=''\n        for x in xs:\n            row += '#' if any((x,y,z) in pts for z in zs) else '.'\n        print(row)\n    if max(zs)==0:\n        continue\n    print('cross-sections per z:')\n    for z in zs:\n        prin"]
