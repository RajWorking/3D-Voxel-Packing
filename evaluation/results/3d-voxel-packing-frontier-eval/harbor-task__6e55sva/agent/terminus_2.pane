[?2004l[?2004h>     for perm in perms:
[?2004l[?2004h>         for sign in signs:
[?2004l[?2004h>             out,dims=transf(pts,perm,sign)
[?2004l[?2004h>             seen.setdefault(out,(perm,sign,dims))
[?2004l[?2004h>     orients[name]=[(v[0],v[1],v[2],list(k)) for k,v in seen.items()]
[?2004l[?2004h>     print(name, len(orients[name]), 'unique orientations', sorted(set(o[2] for o in orients[name])))
[?2004l[?2004h> 
[?2004l[?2004h> names=sorted(objs, key=lambda n:(-len(objs[n]), len(orients[n])))
[?2004l[?2004h> print('order', names)
[?2004l[?2004h> 
[?2004l[?2004h> # search candidate overall boxes in increasing volume
[?2004l[?2004h> vol=sum(len(v) for v in objs.values())
[?2004l[?2004h> print('total voxels',vol)
[?2004l[?2004h> 
[?2004l[?2004h> # occupancy and placement search using bottom-left-near candidate points
[?2004l[?2004h> best=None
[?2004l[?2004h> start=time.time()
[?2004l[?2004h> 
[?2004l[?2004h> def search(box, idx, occ, placements, frontier):
[?2004l[?2004h>     global best
[?2004l[?2004h>     if time.time()-start>25:
[?2004l[?2004h>         return False
[?2004l[?2004h>     if idx==len(names):
[?2004l[?2004h>         best=placements.copy()
[?2004l[?2004h>         return True
[?2004l[?2004h>     name=names[idx]
[?2004l[?2004h>     opts=orients[name]
[?2004l[?2004h>     # try larger objects with fewer candidate placements first
[?2004l[?2004h>     tried=[]
[?2004l[?2004h>     cand_points=sorted(frontier | {(0,0,0)}, key=lambda p:(p[2],p[1],p[0]))[:120]
[?2004l[?2004h>     for perm,sign,dims,pts in sorted(opts, key=lambda t:t[2][2]*10000+t[2][1]*100+t[2][0]):
[?2004l[?2004h>         dx,dy,dz=dims
[?2004l[?2004h>         for ox,oy,oz in cand_points:
[?2004l[?2004h>             if ox+dx>box[0] or oy+dy>box[1] or oz+dz>box[2]:
[?2004l[?2004h>                 continue
[?2004l[?2004h>             placed=[]
[?2004l[?2004h>             ok=True
[?2004l[?2004h>             for x,y,z in pts:
[?2004l[?2004h>                 q=(x+ox,y+oy,z+oz)
[?2004l[?2004h>                 if q in occ:
[?2004l[?2004h>                     ok=False; break
[?2004l[?2004h>                 placed.append(q)
[?2004l[?2004h>             if not ok:
[?2004l[?2004h>                 continue
[?2004l[?2004h>             for p in placed: occ.add(p)
[?2004l[?2004h>             nf=set(frontier)
[?2004l[?2004h>             nf.add((ox+dx,oy,oz)); nf.add((ox,oy+dy,oz)); nf.add((ox,oy,oz+dz))
[?2004l[?2004h>             placements[name]=(perm,sign,ox,oy,oz)
[?2004l[?2004h>             if search(box, idx+1, occ, placements, nf):
[?2004l[?2004h>                 return True
[?2004l[?2004h>             del placements[name]
[?2004l[?2004h>             for p in placed: occ.remove(p)
[?2004l[?2004h>     return False
[?2004l[?2004h> 
[?2004l[?2004h> cands=[]
[?2004l[?2004h> for X in range(10,25):
[?2004l[?2004h>   for Y in range(8,25):
[?2004l[?2004h>     for Z in range(6,25):
[?2004l[?2004h>       if X*Y*Z<vol: continue
[?2004l[?2004h>       if max(X,Y,Z)<12: continue
[?2004l[?2004h>       cands.append((X*Y*Z,(X,Y,Z)))
[?2004l[?2004h> for _,box in sorted(cands)[:400]:
[?2004l[?2004h>     if time.time()-start>28: break
[?2004l[?2004h>     print('try box',box,'vol',box[0]*box[1]*box[2])
[?2004l[?2004h>     if search(box,0,set(),{},set()):
[?2004l[?2004h>         print('FOUND',box,box[0]*box[1]*box[2])
[?2004l[?2004h>         for n in names:
[?2004l[?2004h>             print(n,best[n])
[?2004l[?2004h>         break
[?2004l[?2004h> else:
[?2004l[?2004h>     print('no solution found in time')
