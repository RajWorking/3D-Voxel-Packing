[?2004l,sign,dims))
    orients[name]=[(v[0],v[1],v[2],k) for k,v in seen.items()]
# candidate placements
placements={}
for name in objs:
    lst=[]
    for perm,sign,dims,pts in orients[name]:
        dx,dy,dz=dims
        if dx>box[0] or dy>box[1] or dz>box[2]:
            continue
        for ox in range(box[0]-dx+1):
            for oy in range(box[1]-dy+1):
                for oz in range(box[2]-dz+1):
                    vox=tuple((x+ox,y+oy,z+oz) for x,y,z in pts)
                    lst.append((perm,sign,ox,oy,oz,dims,vox))
    placements[name]=lst
    print(name,len(lst))
order=sorted(objs,key=lambda n: len(placements[n]))
print('order',order)
start=time.time(); best=None
# occupancy index from voxel to candidate ids not built; use recursion with frontier anchors

def search(i, occ, ans):
    global best
    if time.time()-start>55: return False
    if i==len(order):
        best=ans.copy(); return True
    name=order[i]
    # choose lexicographically lowest empty cell as anchor if any occupancy exists
    anchor=None
    if occ:
        for z in range(box[2]):
            for y in range(box[1]):
                for x in range(box[0]):
                    if (x,y,z) not in occ:
                        anchor=(x,y,z); break
                if anchor: break
            if anchor: break
    cand=placements[name]
    # prefer placements near origin and intersecting anchor neighborhood if possible
    cand2=[]
    for p in cand:
        vox=p[6]
        s=set(vox)
        if any(v in occ for v in vox):
            continue
        score=(p[4],p[3],p[2])
        if anchor is None or anchor in s:
            cand2.append((0,score,p))
        else:
            ax,ay,az=anchor
            md=min(abs(x-ax)+abs(y-ay)+abs(z-az) for x,y,z in vox)
            cand2.append((1+md,score,p))
    cand2.sort(key=lambda t:(t[0],t[1]))
    for _,_,p in cand2[:400]:
        perm,sign,ox,oy,oz,dims,vox=p
        for v in vox: occ.add(v)
        ans[name]=(perm,sign,ox,oy,oz)
        if search(i+1,occ,ans): return True
        del ans[name]
        for v in vox: occ.remove(v)
    return False

ok=search(0,set(),{})
print('ok',ok,'elapsed',time.time()-start)
if ok:
    for n in order:
        print(n,best[n])
