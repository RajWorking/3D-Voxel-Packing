[?2004huser@61aa19fdb377:~$ python3 - <<'PY'
[?2004l[?2004h> import json,itertools
[?2004l[?2004h> with open('/task/objects.json') as f:
[?2004l[?2004h>     data=json.load(f)
[?2004l[?2004h> objs={}
[?2004l[?2004h> for name,obj in data.items():
[?2004l[?2004h>     pts=[]
[?2004l[?2004h>     for arr in obj.values(): pts.extend(map(tuple,arr))
[?2004l[?2004h>     objs[name]=sorted(set(pts))
[?2004l[?2004h> perms=['xyz','xzy','yxz','yzx','zxy','zyx']
[?2004l[?2004h> signs=[''.join(s) for s in itertools.product('+-', repeat=3)]
[?2004l[?2004h> 
[?2004l[?2004h> def transf(pts,perm,sign):
[?2004l[?2004h>     out=[]
[?2004l[?2004h>     for x,y,z in pts:
[?2004l[?2004h>         d={'x':x,'y':y,'z':z}
[?2004l[?2004h>         q=[d[perm[i]] for i in range(3)]
[?2004l[?2004h>         q=[q[i] if sign[i]=='+' else -q[i] for i in range(3)]
[?2004l[?2004h>         out.append(tuple(q))
[?2004l[?2004h>     mins=[min(p[i] for p in out) for i in range(3)]
[?2004l[?2004h>     out=tuple(sorted((p[0]-mins[0],p[1]-mins[1],p[2]-mins[2]) for p in out))
[?2004l[?2004h>     dims=(max(p[0] for p in out)+1,max(p[1] for p in out)+1,max(p[2] for p in out)+1)
[?2004l[?2004h>     return out,dims
[?2004l[?2004h> orients={}
[?2004l[?2004h> for name,pts in objs.items():
[?2004l[?2004h>     seen={}
[?2004l[?2004h>     for perm in perms:
[?2004l[?2004h>         for sign in signs:
[?2004l[?2004h>             out,dims=transf(pts,perm,sign)
[?2004l[?2004h>             seen.setdefault(out,(perm,sign,dims))
[?2004l[?2004h>     orients[name]=[(v[0],v[1],v[2]) for k,v in seen.items()]
[?2004l[?2004h> boxes=[(12,12,10),(15,12,8),(16,10,9),(18,10,8),(20,9,8),(20,12,6),(24,10,6),(16,12,8),(18,12,7)]
[?2004l[?2004h> for box in boxes:
[?2004l[?2004h>     print('\nBOX',box,'vol',box[0]*box[1]*box[2])
[?2004l[?2004h>     total=0
[?2004l[?2004h>     for name in sorted(objs,key=lambda n:-len(objs[n])):
[?2004l[?2004h>         c=0
[?2004l[?2004h>         bydims={}
[?2004l[?2004h>         for perm,sign,dims in orients[name]:
[?2004l[?2004h>             n=max(0,box[0]-dims[0]+1)*max(0,box[1]-dims[1]+1)*max(0,box[2]-dims[2]+1)
[?2004l[?2004h>             if n:
[?2004l[?2004h>                 bydims[dims]=bydims.get(dims,0)+n
[?2004l[?2004h>                 c+=n
[?2004l[?2004h>         total+=c
[?2004l[?2004h>         print(f'{name:10s} placements={c:6d} dims={sorted(bydims.items())}')
[?2004l[?2004h>     print('total placements',total)
