[67.303994, "i", "python3 -c \"\nimport json\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\n# Analyze bowl shape in XY (it's the same for all z)\nbowl_voxels = []\nfor group in data['bowl1'].values():\n    for v in group:\n        bowl_voxels.append(tuple(v))\n\n# Get unique XY positions\nxy = set()\nfor x,y,z in bowl_voxels:\n    xy.add((x,y))\n\nprint('Bowl XY footprint:')\nfor y in range(4):\n    row = ''\n    for x in range(12):\n        if (x,y) in xy:\n            row += '#'\n        else:\n            row += '.'\n    print(f'  y={y}: {row}')\n\n# Analyze ball shape per layer\nball_voxels = []\nfor group in data['ball'].values():\n    for v in group:\n        ball_voxels.append(tuple(v))\n\nprint(f'\\nBall total voxels: {len(ball_voxels)}')\nfor z in range(6):\n    layer = [(x,y) for x,y,zz in ball_voxels if zz==z]\n    print(f'\\nBall z={z} ({len(layer)} voxels):')\n    for y in range(8):\n        row = ''\n        for x in range(10):\n            if (x,y) in layer:\n                row += '#'\n            else:\n                row += '.'\n    "]
[67.304781, "o", "python3 -c \"\r\n\u001b[?2004l\r"]
[67.304832, "i", "    print(f'  y={y}: {row}')\n\"\n"]
[67.306506, "o", "\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> with open('/task/objects.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     data = json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Analyze bowl shape in XY (it's the same for all z)\r\n\u001b[?2004l\r\u001b[?2004h> bowl_voxels = []\r\n\u001b[?2004l\r\u001b[?2004h> for group in data['bowl1'].values():\r\n\u001b[?2004l\r\u001b[?2004h>     for v in group:\r\n\u001b[?2004l\r\u001b[?2004h>         bowl_voxels.append(tuple(v))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Get unique XY positions\r\n\u001b[?2004l\r\u001b[?2004h> xy = set()\r\n\u001b[?2004l\r\u001b[?2004h> for x,y,z in bowl_voxels:\r\n\u001b[?2004l\r\u001b[?2004h>     xy.add((x,y))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print('Bowl XY footprint:')\r\n\u001b[?2004l\r\u001b[?2004h> for y in range(4):\r\n\u001b[?2004l\r\u001b[?2004h>     row = ''\r\n\u001b[?2004l\r\u001b[?2004h>     for x in range(12):\r\n\u001b[?2004l\r\u001b[?2004h>         if (x,y) in xy:\r\n\u001b[?2004l\r\u001b[?2004h>             row += '#'\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             row += '.'\r\n\u001b[?2004l\r\u001b[?2004h>     print(f'  y={y}: {row}')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2"]
[67.307003, "o", "004h> # Analyze ball shape per layer\r\n\u001b[?2004l\r\u001b[?2004h> ball_voxels = []\r\n\u001b[?2004l\r\u001b[?2004h> for group in data['ball'].values():\r\n\u001b[?2004l\r\u001b[?2004h>     for v in group:\r\n\u001b[?2004l\r\u001b[?2004h>         ball_voxels.append(tuple(v))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(f'\\nBall total voxels: {len(ball_voxels)}')\r\n\u001b[?2004l\r\u001b[?2004h> for z in range(6):\r\n\u001b[?2004l\r\u001b[?2004h>     layer = [(x,y) for x,y,zz in ball_voxels if zz==z]\r\n\u001b[?2004l\r\u001b[?2004h>     print(f'\\nBall z={z} ({len(layer)} voxels):')\r\n\u001b[?2004l\r\u001b[?2004h>     for y in range(8):\r\n\u001b[?2004l\r\u001b[?2004h>         row = ''\r\n\u001b[?2004l\r\u001b[?2004h>         for x in range(10):\r\n\u001b[?2004l\r\u001b[?2004h>             if (x,y) in layer:\r\n\u001b[?2004l\r\u001b[?2004h>                 row += '#'\r\n\u001b[?2004l\r\u001b[?2004h>             else:\r\n\u001b[?2004l\r\u001b[?2004h>                 row += '.'\r\n\u001b[?2004l\r\u001b[?2004h>         print(f'  y={y}: {row}')\r\n\u001b[?2004l\r\u001b[?2004h> \"\r\n\u001b[?2004l\r"]
[67.321685, "o", "Bowl XY footprint:\r\n  y=0: ##........##\r\n  y=1: .##......##.\r\n  y=2: ..##....##..\r\n  y=3: ...######...\r\n\r\nBall total voxels: 320\r\n\r\nBall z=0 (56 voxels):\r\n  y=0: ...####...\r\n  y=1: ..######..\r\n  y=2: .########.\r\n  y=3: ##########\r\n  y=4: ##########\r\n  y=5: .########.\r\n  y=6: ..######..\r\n  y=7: ...####...\r\n"]
[67.321951, "o", "\r\nBall z=1 (56 voxels):\r\n  y=0: ...####...\r\n  y=1: ..######..\r\n  y=2: .########.\r\n  y=3: ##########\r\n  y=4: ##########\r\n  y=5: .########.\r\n  y=6: ..######..\r\n  y=7: ...####...\r\n\r\nBall z=2 (48 voxels):\r\n  y=0: ...####...\r\n  y=1: ..######..\r\n  y=2: .###..###.\r\n  y=3: ##.####.##\r\n  y=4: ##.####.##\r\n  y=5: .###..###.\r\n  y=6: ..######..\r\n  y=7: ...####...\r\n\r\nBall z=3 (48 voxels):\r\n  y=0: ...####...\r\n  y=1: ..######..\r\n  y=2: .###..###.\r\n  y=3: ##.####.##\r\n  y=4: ##.####.##\r\n  y=5: .###..###.\r\n  y=6: ..######..\r\n  y=7: ...####...\r\n\r\nBall z=4 (56 voxels):\r\n  y=0: ...####...\r\n  y=1: ..######..\r\n  y=2: .########.\r\n  y=3: ##########\r\n  y=4: ##########\r\n  y=5: .########.\r\n  y=6: ..######..\r\n  y=7: ...####...\r\n\r\nBall z=5 (56 voxels):\r\n  y=0: ...####...\r\n  y=1: ..######..\r\n  y=2: .########.\r\n  y=3: ##########\r\n  y=4: ##########\r\n  y=5: .########.\r\n  y=6: ..######..\r\n  y=7: ...####...\r\n"]
