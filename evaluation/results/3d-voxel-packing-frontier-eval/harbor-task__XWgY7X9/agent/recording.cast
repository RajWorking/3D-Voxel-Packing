[656.77598, "i", "ut2_rot)\ndonut2_rot = set((x-min_x, y-min_y, z-min_z) for x,y,z in donut2_rot)\nmax_x = max(v[0] for v in donut2_rot)\nmax_y = max(v[1] for v in donut2_rot)\nmax_z = max(v[2] for v in donut2_rot)\nprint(f\"  Size: {max_x+1}x{max_y+1}x{max_z+1}\")\nfor z in range(max_z+1):\n    layer = set((x,y) for x,y,zz in donut2_rot if zz==z)\n    row = ''\n    for x in range(max_x+1):\n        row += '#' if (x,0) in layer else '.'\n    print(f\"  z={z}: {row}\")\n\n# Now let me think about the layout more carefully\n# Available bowl gaps (4x1 strips at y=8,10,12,14,16, x=4..7, all z):\n# Each gap is 4x1x6 = 24 voxels\n# 5 gaps total = 120 voxels\n\n# Chocolate (solid 6x4x1) as 4x1x6: 24 voxels -> fits in 1 gap\n# Donut2 (6x4x1 with hole) as 4x1x6: 20 voxels in 4x1x6 space (has holes at z=2,3 for x=1,2)\n# Donut1 (8x4x1 with hole) as 4x1x8: needs 8 in z but we only have 6!\n\n# Donut1 alternatives:\n# 8x4x1 -> 1x4x8 (too long in z)\n# 8x4x1 -> 8x1x4 (8 in x, 1 in y, 4 in z)\n# 8x1x4 needs 8 consecutive x positions at some y, for 4 z-layers\n# At y=0, "]
