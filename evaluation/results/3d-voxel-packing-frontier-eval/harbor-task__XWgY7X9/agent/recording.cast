[515.453932, "i", "python3 << 'EOF'\nimport json\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\ndef get_voxels(name):\n    voxels = set()\n    for group in data[name].values():\n        for v in group:\n            voxels.add(tuple(v))\n    return voxels\n\nbowl_v = get_voxels('bowl1')\nball_v = get_voxels('ball')\n\nbowl_xy = set((x,y) for x,y,z in bowl_v)\nball_all_xy = set((x,y) for x,y,z in ball_v)\nflipped_bowl_xy = set((x, 3-y) for x,y in bowl_xy)\n\n# Check normal bowl at various y offsets\nprint(\"Normal bowl (opening up) at various y offsets:\")\nfor dy in range(-8, 12):\n    shifted = set((x, y+dy) for x,y in bowl_xy)\n    overlap = shifted & ball_all_xy\n    if not overlap:\n        combined = ball_all_xy | shifted\n        min_y = min(y for x,y in combined)\n        max_y = max(y for x,y in combined)\n        min_x = min(x for x,y in combined)\n        max_x = max(x for x,y in combined)\n        w = max_x - min_x + 1\n        h = max_y - min_y + 1\n        print(f\"  dy={dy}: {w}x{h}, no overlap\")\n\n# Check flipped bowl at various "]
