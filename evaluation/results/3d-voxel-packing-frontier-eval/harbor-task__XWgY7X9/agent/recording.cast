[930.963845, "i", "python3 << 'EOF'\nimport json\nfrom itertools import product\n\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\ndef get_voxels_normalized(name):\n    voxels = set()\n    for group in data[name].values():\n        for v in group:\n            voxels.add(tuple(v))\n    # Normalize to origin\n    mx = min(v[0] for v in voxels)\n    my = min(v[1] for v in voxels)\n    mz = min(v[2] for v in voxels)\n    return set((x-mx, y-my, z-mz) for x,y,z in voxels)\n\ndef transform_voxels(voxels, perm, signs):\n    pmap = {'x':0, 'y':1, 'z':2}\n    new_voxels = set()\n    for v in voxels:\n        nv = [0,0,0]\n        for i, c in enumerate(perm):\n            val = v[pmap[c]]\n            if signs[i] == '-':\n                val = -val\n            nv[i] = val\n        new_voxels.add(tuple(nv))\n    mx = min(v[0] for v in new_voxels)\n    my = min(v[1] for v in new_voxels)\n    mz = min(v[2] for v in new_voxels)\n    return set((x-mx, y-my, z-mz) for x,y,z in new_voxels)\n\n# Build occupied set with normalized voxels\nbowl_v = get_voxels_no"]
[930.964374, "o", "python3 << 'EOF'\r\n\u001b[?2004l\r"]
[930.964423, "i", "rmalized('bowl1')\nball_v = get_voxels_normalized('ball')\n\nprint(f\"Ball z range: {min(z for x,y,z in ball_v)}..{max(z for x,y,z in ball_v)}\")\nprint(f\"Bowl z range: {min(z for x,y,z in bowl_v)}..{max(z for x,y,z in bowl_v)}\")\n\noccupied = set()\noccupied |= ball_v\nfor i in range(5):\n    for x,y,z in bowl_v:\n        occupied.add((x, y + 6 + i*2, z))\n\nprint(f\"After ball + 5 bowls: {len(occupied)} voxels\")\nprint(f\"Z range: {min(z for x,y,z in occupied)}..{max(z for x,y,z in occupied)}\")\nprint(f\"X range: {min(x for x,y,z in occupied)}..{max(x for x,y,z in occupied)}\")\nprint(f\"Y range: {min(y for x,y,z in occupied)}..{max(y for x,y,z in occupied)}\")\n\n# Now place small objects\nperms = ['xyz','xzy','yxz','yzx','zxy','zyx']\n\ndef find_placement(obj_name, occupied_set, max_dims=(12,18,6)):\n    obj_v = get_voxels_normalized(obj_name)\n    for perm in perms:\n        for signs in product('+-', repeat=3):\n            signs_str = ''.join(signs)\n            transformed = transform_voxels(obj_v, perm, signs_str)\n            sx = m"]
