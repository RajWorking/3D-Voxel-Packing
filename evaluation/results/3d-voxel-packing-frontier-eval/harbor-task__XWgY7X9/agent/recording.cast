[392.4447, "o", "bowl_zyx = set()\r\n\u001b[?2004l\r\u001b[?2004h> for x,y,z in bowl_v:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.444797, "o", "    bowl_zyx.add((z, y, x))  # new_x=z, new_y=y, new_z=x\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Normalize\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.444909, "o", "min_x = min(v[0] for v in bowl_zyx)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.44496, "o", "min_y = min(v[1] for v in bowl_zyx)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.44503, "o", "min_z = min(v[2] for v in bowl_zyx)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.445054, "o", "bowl_zyx = set((x-min_x, y-min_y, z-min_z) for x,y,z in bowl_zyx)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
