[1722.526859, "i", "shifted_3d | bowls_3d\n        max_y = max(y for x,y,z in combined)\n        min_y = min(y for x,y,z in combined)\n        h = max_y - min_y + 1\n        max_x = max(x for x,y,z in combined)\n        w = max_x + 1\n        vol = w * h * 6\n        print(f\"  Ball at y={ball_y}: {w}x{h}x6 = {vol}\")\n        \n        # Check if donut1 fits in bowl interior at y=0\n        # Bowl interior at y=0: x=2..9 (8 cells)\n        # Donut1 as 8x1x4 at x=2, y=0, z=0\n        donut1_v = get_voxels_normalized('donut1')\n        donut1_t = transform_voxels(donut1_v, 'xzy', '+++')\n        # 8x1x4 at offset (2, 0, 0)\n        donut1_placed = set((x+2, y+0, z+0) for x,y,z in donut1_t)\n        all_occupied = combined | donut1_placed\n        d1_overlap = donut1_placed & (ball_shifted_3d | bowls_3d)\n        if not d1_overlap:\n            max_y2 = max(y for x,y,z in all_occupied)\n            h2 = max_y2 - min(y for x,y,z in all_occupied) + 1\n            w2 = max(x for x,y,z in all_occupied) + 1\n            vol2 = w2 * h2 * 6\n            print(f\""]
