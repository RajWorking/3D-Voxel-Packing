[1019.463625, "i", "python3 << 'EOF'\nimport json\nfrom itertools import product\n\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\ndef get_voxels_normalized(name):\n    voxels = set()\n    for group in data[name].values():\n        for v in group:\n            voxels.add(tuple(v))\n    mx = min(v[0] for v in voxels)\n    my = min(v[1] for v in voxels)\n    mz = min(v[2] for v in voxels)\n    return set((x-mx, y-my, z-mz) for x,y,z in voxels)\n\ndef transform_voxels(voxels, perm, signs):\n    pmap = {'x':0, 'y':1, 'z':2}\n    new_voxels = set()\n    for v in voxels:\n        nv = [0,0,0]\n        for i, c in enumerate(perm):\n            val = v[pmap[c]]\n            if signs[i] == '-':\n                val = -val\n            nv[i] = val\n        new_voxels.add(tuple(nv))\n    mx = min(v[0] for v in new_voxels)\n    my = min(v[1] for v in new_voxels)\n    mz = min(v[2] for v in new_voxels)\n    return set((x-mx, y-my, z-mz) for x,y,z in new_voxels)\n\n# Build occupied: ball + 5 bowls + chocolate + donut2 + 4 match_boxes\nbowl_v = get_voxels_no"]
[1019.465559, "i", "rmalized('bowl1')\nball_v = get_voxels_normalized('ball')\n\noccupied = set()\noccupied |= ball_v\nfor i in range(5):\n    for x,y,z in bowl_v:\n        occupied.add((x, y + 6 + i*2, z))\n\n# Add the other small objects that fit\n# chocolate as 4x1x6 at (4,8,0)\nchoc_t = transform_voxels(get_voxels_normalized('chocolate'), 'yzx', '+++')\nfor x,y,z in choc_t:\n    occupied.add((x+4, y+8, z+0))\n\n# donut2 as 4x1x6 at (4,10,0)\ndon2_t = transform_voxels(get_voxels_normalized('donut2'), 'yzx', '+++')\nfor x,y,z in don2_t:\n    occupied.add((x+4, y+10, z+0))\n\n# match_boxes\nmb_t = transform_voxels(get_voxels_normalized('match_box1'), 'xyz', '+++')\nfor x,y,z in mb_t:\n    occupied.add((x+8, y+0, z+0))\nmb_t2 = transform_voxels(get_voxels_normalized('match_box1'), 'xyz', '+++')\nfor x,y,z in mb_t2:\n    occupied.add((x+8, y+0, z+3))\nmb_t3 = transform_voxels(get_voxels_normalized('match_box1'), 'yxz', '+++')\nfor x,y,z in mb_t3:\n    occupied.add((x+10, y+2, z+0))\nmb_t4 = transform_voxels(get_voxels_normalized('match_box1'), 'yxz', '+++')\nf"]
[1019.465637, "o", "python3 << 'EOF'\r\n"]
[1019.465786, "i", "or x,y,z in mb_t4:\n    occupied.add((x+10, y+2, z+3))\n\nprint(f\"Occupied: {len(occupied)} voxels\")\n\n# Show empty space map\nprint(\"\\nEmpty XY at z=0:\")\nfor y in range(18):\n    row = ''\n    for x in range(12):\n        if (x,y,0) in occupied:\n            row += '#'\n        else:\n            row += '.'\n    print(f\"  y={y:2d}: {row}\")\n\nprint(\"\\nEmpty XY at z=3:\")\nfor y in range(18):\n    row = ''\n    for x in range(12):\n        if (x,y,3) in occupied:\n            row += '#'\n        else:\n            row += '.'\n    print(f\"  y={y:2d}: {row}\")\n\n# Count empty per z\nfor z in range(6):\n    empty = sum(1 for x in range(12) for y in range(18) if (x,y,z) not in occupied)\n    print(f\"z={z}: {empty} empty\")\n\n# Now try donut1 in all orientations within 12x18x6\ndonut1_v = get_voxels_normalized('donut1')\nperms = ['xyz','xzy','yxz','yzx','zxy','zyx']\n\nprint(\"\\nSearching for donut1 placement in 12x18x6...\")\nfound = False\nfor perm in perms:\n    for signs in product('+-', repeat=3):\n        signs_str = ''.join(signs)\n        transfo"]
