[930.965313, "i", "ax(v[0] for v in transformed) + 1\n            sy = max(v[1] for v in transformed) + 1\n            sz = max(v[2] for v in transformed) + 1\n            if sx > max_dims[0] or sy > max_dims[1] or sz > max_dims[2]:\n                continue\n            for ox in range(max_dims[0] - sx + 1):\n                for oy in range(max_dims[1] - sy + 1):\n                    for oz in range(max_dims[2] - sz + 1):\n                        placed = set((x+ox, y+oy, z+oz) for x,y,z in transformed)\n                        if not (placed & occupied_set):\n                            return (perm, signs_str, ox, oy, oz, placed, sx, sy, sz)\n    return None\n\nplacements = {}\nfor obj_name in ['donut1', 'chocolate', 'donut2', 'match_box1', 'match_box2', 'match_box3', 'match_box4']:\n    result = find_placement(obj_name, occupied)\n    if result:\n        perm, signs, ox, oy, oz, placed, sx, sy, sz = result\n        occupied |= placed\n        placements[obj_name] = (perm, signs, ox, oy, oz)\n        print(f\"{obj_name}: perm={perm} signs={signs"]
