[1460.886328, "o", "\u001b[?2004h> "]
[1460.886432, "o", "# Total y: 0..20 = 21 -> 12x21x6 = 1512 (worse)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1460.886446, "o", "> "]
[1460.886529, "o", "\r\n\u001b[?2004l\r \u001b[?2004h> "]
[1460.886653, "o", "# What if donut1 goes at y=0..3 ABOVE the ball (before it)?\r\n\u001b[?2004l\r\u001b[?2004h> # Donut1 as 8x4x1 at y=-4..-1, ball at y=0..7, bowls at y=6..17\r\n\u001b[?2004l\r"]
[1460.8867, "o", "\u001b[?2004h> "]
[1460.886807, "o", "# Total y: -4..17 = 22 -> 12x22x6 = 1584 (worse)\r\n\u001b[?2004l\r    \u001b[?2004h> \r\n\u001b[?2004l\r \u001b[?2004h> "]
[1460.886884, "o", "# What if donut1 is oriented as 1x4x8 and placed at x=11?\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.886958, "o", "# Needs z=0..7 -> extends z to 8 -> 12x18x8 = 1728 (worse)\r\n\u001b[?2004l\rf co\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1460.887048, "o", "\u001b[?2004h> # What about a layout where bowls are oriented differently?\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.887146, "o", "# Rotated bowls (4x12) nested in x with dx=2\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.887171, "o", "# 5 rotated bowls: x=0..11, y=0..11 = 12x12x6\r\n\u001b[?2004l\r     \u001b[?2004h> "]
[1460.887343, "o", "# Ball at y=12..19: 12x20x6 = 1440\r\n\u001b[?2004l\r  if count5 >= 3:\r\n    \u001b[?2004h> "]
[1460.887484, "o", "# Donut1 somewhere in the 12x20x6 box\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.887574, "o", "# Actually, let me try: 4 rotated bowls (10x12) + ball (10x8) + donut1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.887641, "o", "# 4 rotated bowls: x=0..9, y=0..11\r\n\u001b[?2004l\r\u001b[?2004h> # Ball: x=0..9, y=12..19\r\n\u001b[?2004l\r"]
[1460.887662, "o", "\u001b[?2004h"]
[1460.887667, "o", "> "]
[1460.887753, "o", "# Total: 10x20x6 = 1200\r\n\u001b[?2004l\rf c\u001b[?2004h> "]
[1460.887887, "o", "# Donut1 needs to fit in this 10x20x6 box\r\n\u001b[?2004l\r    break\r\n    \u001b[?2004h> \r\n\u001b[?2004l\r "]
[1460.88791, "o", "\u001b[?2004h> "]
[1460.888021, "o", "bowl_rot_xy = set((y,x) for x,y in bowl_xy)\r\n\u001b[?2004l\r"]
[1460.888034, "o", "\u001b[?2004h"]
[1460.888106, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> occupied = set()\r\n\u001b[?2004l\r\u001b[?2004h> # 4 rotated bowls at dx=0,2,4,6\r\n\u001b[?2004l\r"]
[1460.888235, "o", "\u001b[?2004h> for i in range(4):"]
[1460.888257, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.888324, "o", "    for x,y in bowl_rot_xy:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.888345, "o", "        for z in range(6):\r\n\u001b[?2004l\r\u001b[?2004h"]
[1460.888393, "o", "> "]
[1460.888495, "o", "            occupied.add((x + i*2, y, z))\r\n\u001b[?2004l\r\u001b[?2004h> # Ball at y=12\r\n\u001b[?2004l\r\u001b[?2004h> for x,y,z in ball_v:\r\n\u001b[?2004l\r\u001b[?2004h>     occupied.add((x, y+12, z))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.888611, "o", "min_x = min(x for x,y,z in occupied)\r\n\u001b[?2004l\r\u001b[?2004h> max_x = max(x for x,y,z in occupied)\r\n\u001b[?2004l\r\u001b[?2004h> min_y = min(y for x,y,z in occupied)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.888685, "o", "max_y = max(y for x,y,z in occupied)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.888769, "o", "print(f\"4 rot bowls + ball: {max_x-min_x+1}x{max_y-min_y+1}x6 = {(max_x-min_x+1)*(max_y-min_y+1)*6}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.888845, "o", "print(f\"  Voxels: {len(occupied)}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[1460.888911, "o", "> # Check donut1 in 10x20x6\r\n\u001b[?2004l\r\u001b[?2004h"]
[1460.888933, "o", "> "]
[1460.888982, "o", "donut1_v = get_voxels_normalized('donut1')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.889041, "o", "perms_list = ['xyz','xzy','yxz','yzx','zxy','zyx']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.889075, "o", "w, h, d = max_x-min_x+1, max_y-min_y+1, 6\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.88911, "o", "count = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.889175, "o", "for perm in perms_list:\r\n\u001b[?2004l\r"]
[1460.889192, "o", "\u001b[?2004h> "]
[1460.889319, "o", "    for signs in product('+-', repeat=3):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.889457, "o", "        signs_str = ''.join(signs)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.889515, "o", "        transformed = transform_voxels(donut1_v, perm, signs_str)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.889608, "o", "        sx = max(v[0] for v in transformed) + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.889663, "o", "        sy = max(v[1] for v in transformed) + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.889739, "o", "        sz = max(v[2] for v in transformed) + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.889783, "o", "        if sx > w or sy > h or sz > d:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.889835, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.889924, "o", "        for ox in range(w - sx + 1):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.890026, "o", "            for oy in range(h - sy + 1):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.890105, "o", "                for oz in range(d - sz + 1):\r\n\u001b[?2004l\r\u001b[?2004h>                     placed = set((x+ox, y+oy, z+oz) for x,y,z in transformed)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.890168, "o", "                    if not (placed & occupied):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.890188, "o", "                        count += 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.890277, "o", "                        if count <= 5:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.890372, "o", "                            print(f\"  Donut1: perm={perm} signs={signs_str} offset=({ox},{oy},{oz}) size={sx}x{sy}x{sz}\")\r\n\u001b[?2004l\r\u001b[?2004h>                         if count >= 5:\r\n\u001b[?2004l\r\u001b[?2004h>                             break\r\n"]
[1460.890464, "o", "\u001b[?2004l\r\u001b[?2004h>                     if count >= 5:\r\n\u001b[?2004l\r\u001b[?2004h"]
[1460.890548, "o", ">                         break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.890594, "o", "                if count >= 5:\r\n\u001b[?2004l\r\u001b[?2004h>                     break\r\n\u001b[?2004l\r"]
[1460.890666, "o", "\u001b[?2004h>             if count >= 5:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.890828, "o", "                break\r\n\u001b[?2004l\r\u001b[?2004h>         if count >= 5:\r\n\u001b[?2004l\r\u001b[?2004h>             break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.890914, "o", "    if count >= 5:\r\n\u001b[?2004l\r\u001b[?2004h>         break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.891042, "o", "print(f\"  Donut1 positions: {count}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # If donut1 fits, check remaining objects\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.891206, "o", "if count > 0:\r\n\u001b[?2004l\r\u001b[?2004h>     # Need to also fit: 5th bowl + chocolate + donut2 + 4 match_boxes\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.891335, "o", "    # 5th bowl is the problem - it's 12x4x6 or 4x12x6\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.891452, "o", "    # In 10x20x6, a 4x12 rotated bowl at x=10 would extend to x=13: 14x20x6 = 1680\r\n\u001b[?2004l\r\u001b[?2004h>     # A 12x4 bowl extends x to 11: 12x20x6 = 1440\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.891678, "o", "    print(\"\\n  But still need 5th bowl! 12x4 extends to 12x20x6=1440\")\r\n\u001b[?2004l\r\u001b[?2004h>     print(\"  Or 4x12 at x=10 extends to 14x20x6=1680\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.891763, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h>     # What if 5th bowl nests with the 4 rotated bowls?\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.891833, "o", "    # 5 rotated bowls: x=0..11, y=0..11 = 12x12\r\n\u001b[?2004l\r"]
[1460.891989, "o", "\u001b[?2004h>     # Ball at y=12: 12x20x6 = 1440"]
[1460.892014, "o", "\r\n\u001b[?2004l\r"]
[1460.892129, "o", "\u001b[?2004h> "]
[1460.892156, "o", "    # Then donut1 in 12x20x6?\r\n\u001b[?2004l\r"]
[1460.892298, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     occupied5 = set()\r\n\u001b[?2004l\r\u001b[?2004h"]
[1460.892327, "o", "> "]
[1460.892436, "o", "    for i in range(5):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.892541, "o", "        for x,y in bowl_rot_xy:\r\n\u001b[?2004l\r\u001b[?2004h>             for z in range(6):\r\n\u001b[?2004l\r\u001b[?2004h>                 occupied5.add((x + i*2, y, z))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.89261, "o", "    for x,y,z in ball_v:\r\n\u001b[?2004l\r\u001b[?2004h>         occupied5.add((x, y+12, z))\r\n"]
[1460.892631, "o", "\u001b[?2004l\r"]
[1460.892782, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     w5 = max(x for x,y,z in occupied5) + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.892846, "o", "    h5 = max(y for x,y,z in occupied5) + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.892863, "o", "    print(f\"\\n  5 rot bowls + ball: {w5}x{h5}x6 = {w5*h5*6}\")\r\n\u001b[?2004l\r"]
[1460.892883, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[1460.892906, "o", "\u001b[?2004h> "]
[1460.892955, "o", "    count5 = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.893172, "o", "    for perm in perms_list:\r\n\u001b[?2004l\r\u001b[?2004h>         for signs in product('+-', repeat=3):\r\n\u001b[?2004l\r\u001b[?2004h>             signs_str = ''.join(signs)\r\n\u001b[?2004l\r\u001b[?2004h>             transformed = transform_voxels(donut1_v, perm, signs_str)\r\n\u001b[?2004l\r"]
[1460.893271, "o", "\u001b[?2004h> "]
[1460.893373, "o", "            sx = max(v[0] for v in transformed) + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.893451, "o", "            sy = max(v[1] for v in transformed) + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.893534, "o", "            sz = max(v[2] for v in transformed) + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.893592, "o", "            if sx > w5 or sy > h5 or sz > 6:\r\n\u001b[?2004l\r\u001b[?2004h>                 continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.893783, "o", "            for ox in range(w5 - sx + 1):\r\n\u001b[?2004l\r\u001b[?2004h>                 for oy in range(h5 - sy + 1):\r\n\u001b[?2004l\r\u001b[?2004h>                     for oz in range(6 - sz + 1):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.893876, "o", "                        placed = set((x+ox, y+oy, z+oz) for x,y,z in transformed)\r\n\u001b[?2004l\r"]
[1460.893976, "o", "\u001b[?2004h>                         if not (placed & occupied5):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.894042, "o", "                            count5 += 1\r\n\u001b[?2004l\r\u001b[?2004h>                             if count5 <= 3:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.894135, "o", "                                print(f\"    Donut1: perm={perm} signs={signs_str} offset=({ox},{oy},{oz}) size={sx}x{sy}x{sz}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.89426, "o", "                            if count5 >= 3:\r\n\u001b[?2004l\r\u001b[?2004h>                                 break\r\n\u001b[?2004l\r\u001b[?2004h>                         if count5 >= 3:\r\n"]
