[1282.641898, "i", "python3 << 'EOF'\nimport json\nfrom itertools import product\n\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\ndef get_voxels_normalized(name):\n    voxels = set()\n    for group in data[name].values():\n        for v in group:\n            voxels.add(tuple(v))\n    mx = min(v[0] for v in voxels)\n    my = min(v[1] for v in voxels)\n    mz = min(v[2] for v in voxels)\n    return set((x-mx, y-my, z-mz) for x,y,z in voxels)\n\ndef transform_voxels(voxels, perm, signs):\n    pmap = {'x':0, 'y':1, 'z':2}\n    new_voxels = set()\n    for v in voxels:\n        nv = [0,0,0]\n        for i, c in enumerate(perm):\n            val = v[pmap[c]]\n            if signs[i] == '-':\n                val = -val\n            nv[i] = val\n        new_voxels.add(tuple(nv))\n    mx = min(v[0] for v in new_voxels)\n    my = min(v[1] for v in new_voxels)\n    mz = min(v[2] for v in new_voxels)\n    return set((x-mx, y-my, z-mz) for x,y,z in new_voxels)\n\nbowl_v = get_voxels_normalized('bowl1')\nball_v = get_voxels_normalized('ball')\nperms = ['xyz"]
[1282.642242, "i", "','xzy','yxz','yzx','zxy','zyx']\n\n# Layout: ball at origin, 5 bowls at y=6,8,10,12,14\n# Donut1 at y=18 (extending to y=18)\n# Total: 12x19x6 = 1368\n\noccupied = set()\noccupied |= ball_v\nfor i in range(5):\n    for x,y,z in bowl_v:\n        occupied.add((x, y + 6 + i*2, z))\n\nprint(f\"Ball + 5 bowls: {len(occupied)} voxels\")\n\n# Place all small objects greedily, donut1 first\nobjects_to_place = ['donut1', 'donut2', 'chocolate', 'match_box1', 'match_box2', 'match_box3', 'match_box4']\nmax_dims = (12, 19, 6)\n\nplacements = {}\nfor obj_name in objects_to_place:\n    obj_v = get_voxels_normalized(obj_name)\n    placed = False\n    for perm in perms:\n        if placed:\n            break\n        for signs in product('+-', repeat=3):\n            if placed:\n                break\n            signs_str = ''.join(signs)\n            transformed = transform_voxels(obj_v, perm, signs_str)\n            sx = max(v[0] for v in transformed) + 1\n            sy = max(v[1] for v in transformed) + 1\n            sz = max(v[2] for v in transformed)"]
[1282.642249, "i", " + 1\n            if sx > max_dims[0] or sy > max_dims[1] or sz > max_dims[2]:\n                continue\n            for ox in range(max_dims[0] - sx + 1):\n                if placed:\n                    break\n                for oy in range(max_dims[1] - sy + 1):\n                    if placed:\n                        break\n                    for oz in range(max_dims[2] - sz + 1):\n                        p_set = set((x+ox, y+oy, z+oz) for x,y,z in transformed)\n                        if not (p_set & occupied):\n                            occupied |= p_set\n                            placements[obj_name] = (perm, signs_str, ox, oy, oz, sx, sy, sz)\n                            print(f\"{obj_name}: perm={perm} signs={signs_str} offset=({ox},{oy},{oz}) size={sx}x{sy}x{sz}\")\n                            placed = True\n                            break\n    if not placed:\n        print(f\"{obj_name}: DOES NOT FIT!\")\n\n# Final check\nmin_x = min(v[0] for v in occupied)\nmax_x = max(v[0] for v in occupied)\nmin_y = min(v[1] for "]
[1282.64227, "i", "v in occupied)\nmax_y = max(v[1] for v in occupied)\nmin_z = min(v[2] for v in occupied)\nmax_z = max(v[2] for v in occupied)\nw = max_x - min_x + 1\nh = max_y - min_y + 1\nd = max_z - min_z + 1\nprint(f\"\\nFinal bounding box: {w}x{h}x{d} = {w*h*d}\")\nprint(f\"Total voxels: {len(occupied)}\")\nprint(f\"\\nPlacements summary:\")\nfor name, (perm, signs, ox, oy, oz, sx, sy, sz) in placements.items():\n    print(f\"  {name}: perm={perm} signs={signs} offset=({ox},{oy},{oz})\")\nEOF\n"]
