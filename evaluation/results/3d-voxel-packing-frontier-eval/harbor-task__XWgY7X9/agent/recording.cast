[392.439988, "o", "\u001b[?2004h> # If ball and bowls don't overlap in XY at z=4,5:\r\n\u001b[?2004l\r"]
[392.440056, "o", "\u001b[?2004h> "]
[392.440215, "o", "#   Same constraint as before - they need separate XY space at those z levels\r\n\u001b[?2004l\r"]
[392.44032, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
