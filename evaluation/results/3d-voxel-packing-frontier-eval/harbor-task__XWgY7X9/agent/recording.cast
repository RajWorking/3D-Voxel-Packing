[1758.936951, "i", "t_voxels_normalized('donut1')\ndonut1_t = transform_voxels(donut1_v, 'xzy', '+++')  # 8x1x4\n\n# Try: n_above bowls at y=0,2,..., ball at y=ball_y, n_below bowls at y=...\n# Donut1 at y=0 interior (x=2..9)\n\nbest_vol = 1368  # current best\nbest_config = \"current\"\n\nfor n_above in range(1, 5):\n    n_below = 5 - n_above\n    # Above bowls at y=0, 2, ..., 2*(n_above-1)\n    above_max_y = 2*(n_above-1) + 3  # last bowl's y=3\n    \n    for ball_y in range(above_max_y - 1, above_max_y + 8):\n        # Build 3D occupied set\n        occupied = set()\n        \n        # Above bowls\n        for i in range(n_above):\n            for x,y,z in bowl_v:\n                occupied.add((x, y + i*2, z))\n        \n        # Ball\n        ball_3d = set((x, y+ball_y, z) for x,y,z in ball_v)\n        if ball_3d & occupied:\n            continue\n        occupied |= ball_3d\n        \n        # Below bowls - start after ball can overlap\n        ball_max_y = ball_y + 7\n        # Try different starting positions for below bowls\n        for below_start in"]
