[392.44547, "o", "    print(f\"  z={z}: \", end='')\r\n\u001b[?2004l\r\u001b[?2004h>     for y in range(max_y+1):\r\n\u001b[?2004l\r\u001b[?2004h"]
[392.445507, "o", ">         row = ''\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.445647, "o", "        for x in range(max_x+1):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.445755, "o", "            row += '#' if (x,y) in layer else '.'\r\n\u001b[?2004l\r\u001b[?2004h>         print(row + ' ', end='')\r\n\u001b[?2004l\r\u001b[?2004h>     print()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.445919, "o", "# This gives us a 6x4x12 shape. Can two of these nest?\r\n\u001b[?2004l\r\u001b[?2004h> # Check XY footprint at each z\r\n\u001b[?2004l\r\u001b[?2004h> print(\"\\nXY footprints per z-slice:\")\r\n\u001b[?2004l\r\u001b[?2004h> for z in range(max_z+1):\r\n\u001b[?2004l\r\u001b[?2004h> "]
