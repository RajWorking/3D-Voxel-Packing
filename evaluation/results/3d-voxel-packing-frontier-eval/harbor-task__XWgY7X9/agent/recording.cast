[515.461386, "o", "        if below_xy & ball_all_xy:\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.461493, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h>         # Flipped bowls above ball\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.461569, "o", "        # Flipped bowl occupies y=dy..dy+3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.461744, "o", "        # Need to not overlap with ball (y=0..7)\r\n\u001b[?2004l\r\u001b[?2004h>         # Try starting from various positions\r\n\u001b[?2004l\r\u001b[?2004h>         for start_above in range(-10, 2):\r\n\u001b[?2004l\r\u001b[?2004h"]
[515.461773, "o", ">             above_xy = set()\r\n\u001b[?2004l\r"]
[515.46187, "o", "\u001b[?2004h>             ok = True\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.461964, "o", "            for i in range(n_above):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.461988, "o", "                # Flipped bowls nest with dy=2 as well"]
[515.462068, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>                 for x,y in flipped_bowl_xy:\r\n\u001b[?2004l\r"]
[515.462094, "o", "\u001b[?2004h> "]
[515.462179, "o", "                    above_xy.add((x, y + start_above - i*2))\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.462272, "o", "            if above_xy & ball_all_xy:\r\n\u001b[?2004l\r\u001b[?2004h>                 continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.462368, "o", "            if above_xy & below_xy:\r\n\u001b[?2004l\r\u001b[?2004h>                 continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.462465, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.462679, "o", "            combined = ball_all_xy | below_xy | above_xy\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.46275, "o", "            min_x = min(x for x,y in combined)\r\n\u001b[?2004l\r\u001b[?2004h>             max_x = max(x for x,y in combined)\r\n\u001b[?2004l\r\u001b[?2004h>             min_y = min(y for x,y in combined)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.462851, "o", "            max_y = max(y for x,y in combined)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.462876, "o", "            w = max_x - min_x + 1\r\n\u001b[?2004l\r"]
[515.462935, "o", "\u001b[?2004h> "]
[515.463123, "o", "            h = max_y - min_y + 1\r\n\u001b[?2004l\r\u001b[?2004h>             vol = w * h * 6\r\n\u001b[?2004l\r\u001b[?2004h>             if vol < best_vol:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.463188, "o", "                best_vol = vol\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.463291, "o", "                best_config = f\"n_below={n_below} start={start_below}, n_above={n_above} start={start_above}, {w}x{h}x6\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.46347, "o", "print(f\"Best: vol={best_vol}, config={best_config}\")\r\n"]
[515.463492, "o", "\u001b[?2004l\r"]
[515.463617, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[515.463736, "o", "\u001b[?2004h> "]
