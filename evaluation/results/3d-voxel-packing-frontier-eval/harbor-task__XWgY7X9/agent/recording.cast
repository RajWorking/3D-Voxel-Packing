[340.103138, "o", "\u001b[?2004h> "]
[340.103287, "o", "    ball_shifted = set((x, y+by) for x,y in ball_xy)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.103335, "o", "    overlap = ball_shifted & four_bowls  # Using 4 bowls for now\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.103458, "o", "    if not overlap:\r\n\u001b[?2004l\r\u001b[?2004h>         combined = four_bowls | ball_shifted\r\n\u001b[?2004l\r\u001b[?2004h"]
[340.103533, "o", "> "]
[340.103659, "o", "        w = max(x for x,y in combined) - min(x for x,y in combined) + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.103699, "o", "        h = max(y for x,y in combined) - min(y for x,y in combined) + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.103988, "o", "        print(f\"Ball at by={by} with 4 bowls: {w}x{h}x6 = {w*h*6}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Try with 5 nested bowls (original orientation, 12x12)\r\n\u001b[?2004l\r\u001b[?2004h> nested_5_orig = set()\r\n\u001b[?2004l\r\u001b[?2004h> for i in range(5):\r\n\u001b[?2004l\r\u001b[?2004h"]
[340.104115, "o", ">     for x,y in bowl_xy:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.1043, "o", "        nested_5_orig.add((x, y + i*2))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[340.104321, "o", "\u001b[?2004h> "]
[340.104436, "o", "for by in range(8, 16):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.104594, "o", "    ball_shifted = set((x+1, y+by) for x,y in ball_xy)  # offset x by 1 to center\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.104636, "o", "    overlap = ball_shifted & nested_5_orig\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.104755, "o", "    if not overlap:\r\n\u001b[?2004l\r\u001b[?2004h>         combined = nested_5_orig | ball_shifted\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.104965, "o", "        w = max(x for x,y in combined) - min(x for x,y in combined) + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.104987, "o", "        h = max(y for x,y in combined) - min(y for x,y in combined) + 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[340.104993, "o", "> "]
[340.105072, "o", "        print(f\"Ball at bx=1,by={by} with 5 orig bowls: {w}x{h}x6 = {w*h*6}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.10525, "o", "print(\"\\n--- Trying ball overlapping with nested bowls ---\")\r\n\u001b[?2004l\r\u001b[?2004h> # The ball has rounded corners. Maybe it can tuck closer to bowls.\r\n\u001b[?2004l\r\u001b[?2004h> for bx in range(-2, 4):\r\n\u001b[?2004l\r\u001b[?2004h>     for by in range(8, 16):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.105304, "o", "        ball_shifted = set((x+bx, y+by) for x,y in ball_xy)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.105323, "o", "        overlap = ball_shifted & nested_5_orig\r\n\u001b[?2004l\r"]
[340.105373, "o", "\u001b[?2004h> "]
[340.105544, "o", "        if not overlap:\r\n\u001b[?2004l\r\u001b[?2004h>             combined = nested_5_orig | ball_shifted\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.105638, "o", "            w = max(x for x,y in combined) - min(x for x,y in combined) + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.105754, "o", "            h = max(y for x,y in combined) - min(y for x,y in combined) + 1\r\n\u001b[?2004l\r\u001b[?2004h>             vol = w*h*6\r\n\u001b[?2004l\r\u001b[?2004h"]
