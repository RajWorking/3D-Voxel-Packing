[1282.766506, "o", "\r\nFinal bounding box: 12x19x6 = 1368\r\nTotal voxels: 1004\r\n\r\nPlacements summary:\r\n  donut1: perm=xzy signs=+++ offset=(0,18,0)\r\n  donut2: perm=yzx signs=+++ offset=(4,8,0)\r\n  chocolate: perm=yzx signs=+++ offset=(4,10,0)\r\n  match_box1: perm=xyz signs=+++ offset=(8,0,0)\r\n  match_box2: perm=xyz signs=+++ offset=(8,0,3)\r\n  match_box3: perm=xyz signs=+++ offset=(9,17,0)\r\n  match_box4: perm=xyz signs=+++ offset=(9,17,3)\r\n"]
