[392.442486, "o", "# Not useful for nesting.\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # perm=zxy: new_x=z, new_y=x, new_z=y\r\n\u001b[?2004l\r\u001b[?2004h> "]
