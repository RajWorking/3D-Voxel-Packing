[340.102099, "o", "\u001b[?2004h> "]
[340.102247, "o", "# What if we orient the 5th bowl to be 6x12x4 (extrusion along z, only 4 thick)?\r\n\u001b[?2004l\r\u001b[?2004h> "]
[340.102384, "o", "# Then it's 6x12 in XY, 4 in z. Still too big.\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
