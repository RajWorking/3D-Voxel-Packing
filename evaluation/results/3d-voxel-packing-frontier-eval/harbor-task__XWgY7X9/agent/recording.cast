[910.688318, "i", "python3 << 'EOF'\nimport json\nwith open('/task/objects.json') as f:\n    data = json.load(f)\n\ndef get_voxels(name):\n    voxels = set()\n    for group in data[name].values():\n        for v in group:\n            voxels.add(tuple(v))\n    return voxels\n\n# Check raw z ranges\nfor name in ['ball', 'bowl1', 'chocolate', 'donut1', 'donut2', 'match_box1']:\n    v = get_voxels(name)\n    zmin = min(z for x,y,z in v)\n    zmax = max(z for x,y,z in v)\n    xmin = min(x for x,y,z in v)\n    ymin = min(y for x,y,z in v)\n    print(f\"{name}: x_min={xmin}, y_min={ymin}, z_min={zmin}, z_max={zmax}\")\nEOF\n"]
[910.691155, "o", "python3 << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> with open('/task/objects.json') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     data = json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def get_voxels(name):\r\n\u001b[?2004l\r\u001b[?2004h>     voxels = set()\r\n\u001b[?2004l\r\u001b[?2004h>     for group in data[name].values():\r\n\u001b[?2004l\r\u001b[?2004h>         for v in group:\r\n\u001b[?2004l\r\u001b[?2004h>             voxels.add(tuple(v))\r\n\u001b[?2004l\r\u001b[?2004h>     return voxels\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Check raw z ranges\r\n\u001b[?2004l\r\u001b[?2004h> for name in ['ball', 'bowl1', 'chocolate', 'donut1', 'donut2', 'match_box1']:\r\n\u001b[?2004l\r\u001b[?2004h>     v = get_voxels(name)\r\n\u001b[?2004l\r\u001b[?2004h>     zmin = min(z for x,y,z in v)\r\n\u001b[?2004l\r\u001b[?2004h>     zmax = max(z for x,y,z in v)\r\n\u001b[?2004l\r\u001b[?2004h>     xmin = min(x for x,y,z in v)\r\n\u001b[?2004l\r\u001b[?2004h>     ymin = min(y for x,y,z in v)\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"{name}: x_min={xmin}, y_min={ymin}, z_min={zmin}, z_max={zmax}\")\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
