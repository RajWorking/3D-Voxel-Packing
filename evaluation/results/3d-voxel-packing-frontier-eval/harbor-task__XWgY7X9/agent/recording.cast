[437.114927, "o", "        # We need the XY bbox to contain both\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.115015, "o", "        all_ball_xy = set((x,y) for x,y,z in ball_v)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.115149, "o", "        all_xy = nested_5_xy | all_ball_xy  # shifted ball\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.115231, "o", "        min_x = min(x for x,y in all_xy)\r\n\u001b[?2004l\r\u001b[?2004h>         max_x = max(x for x,y in all_xy)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.115327, "o", "        min_y = min(y for x,y in all_xy)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.115381, "o", "        max_y = max(y for x,y in all_xy)\r\n\u001b[?2004l\r"]
[437.115505, "o", "\u001b[?2004h>         w = max_x - min_x + 1\r\n\u001b[?2004l\r\u001b[?2004h>         h = max_y - min_y + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.115585, "o", "        vol = w * h * total_z\r\n\u001b[?2004l\r"]
[437.115701, "o", "\u001b[?2004h> "]
[437.115799, "o", "        print(f\"  dz={dz}: z_overlap={z_lo}-{z_hi}, z_range={total_z}, XY={w}x{h}, vol={vol} (no XY collision)\")\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r"]
[437.115841, "o", "\u001b[?2004h> "]
[437.115917, "o", "        # Need to offset ball in XY to avoid overlap\r\n\u001b[?2004l\r\u001b[?2004h>         # Try various XY offsets for ball\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.115971, "o", "        best_vol = 99999\r\n\u001b[?2004l\r"]
[437.115989, "o", "\u001b[?2004h>         best_info = \"\"\r\n\u001b[?2004l\r"]
[437.116078, "o", "\u001b[?2004h> "]
[437.116107, "o", "        for bx in range(-3, 5):\r\n\u001b[?2004l\r\u001b[?2004h>             for by in range(-3, 20):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.116187, "o", "                ball_shifted_xy = set((x+bx, y+by) for x,y in ball_xy_overlap)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.116259, "o", "                if ball_shifted_xy & nested_5_xy:\r\n\u001b[?2004l\r\u001b[?2004h>                     continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.116363, "o", "                # Check ALL ball layers\r\n\u001b[?2004l\r\u001b[?2004h>                 all_ok = True\r\n\u001b[?2004l\r\u001b[?2004h>                 for z in range(z_lo, z_hi+1):\r\n\u001b[?2004l\r"]
[437.116426, "o", "\u001b[?2004h>                     ball_z = z - dz\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.116482, "o", "                    if ball_z in ball_layers:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.11656, "o", "                        shifted = set((x+bx, y+by) for x,y in ball_layers[ball_z])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.11659, "o", "                        if shifted & nested_5_xy:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.116657, "o", "                            all_ok = False\r\n\u001b[?2004l\r\u001b[?2004h>                             break\r\n\u001b[?2004l\r\u001b[?2004h>                 if not all_ok:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.116736, "o", "                    continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.116863, "o", "                all_ball_shifted = set((x+bx, y+by) for x,y,z in ball_v)\r\n\u001b[?2004l\r\u001b[?2004h>                 all_xy = nested_5_xy | all_ball_shifted\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.116954, "o", "                min_x = min(x for x,y in all_xy)\r\n\u001b[?2004l\r\u001b[?2004h>                 max_x = max(x for x,y in all_xy)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.117042, "o", "                min_y = min(y for x,y in all_xy)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.117241, "o", "                max_y = max(y for x,y in all_xy)\r\n\u001b[?2004l\r\u001b[?2004h>                 w = max_x - min_x + 1\r\n\u001b[?2004l\r\u001b[?2004h>                 h = max_y - min_y + 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.117293, "o", "                vol = w * h * total_z\r\n\u001b[?2004l\r"]
[437.117301, "o", "\u001b[?2004h> "]
[437.117444, "o", "                if vol < best_vol:\r\n\u001b[?2004l\r\u001b[?2004h>                     best_vol = vol\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.117555, "o", "                    best_info = f\"bx={bx},by={by}, XY={w}x{h}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.117658, "o", "        if best_vol < 99999:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[437.117755, "o", "            print(f\"  dz={dz}: z_overlap={z_lo}-{z_hi}, z_range={total_z}, best vol={best_vol} ({best_info})\")\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r"]
