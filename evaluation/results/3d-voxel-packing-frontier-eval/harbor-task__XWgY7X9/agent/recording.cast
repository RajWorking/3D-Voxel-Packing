[1460.885453, "o", "    my = min(v[1] for v in new_voxels)\r\n\u001b[?2004l\r\u001b[?2004h>     mz = min(v[2] for v in new_voxels)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.885622, "o", "    return set((x-mx, y-my, z-mz) for x,y,z in new_voxels)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> bowl_v = get_voxels_normalized('bowl1')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.885709, "o", "ball_v = get_voxels_normalized('ball')\r\n\u001b[?2004l\r"]
[1460.885808, "o", "\u001b[?2004h> bowl_xy = set((x,y) for x,y,z in bowl_v)\r\n\u001b[?2004l\r m"]
[1460.885882, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1460.885973, "o", "# What if we put donut1 BETWEEN the ball and bowls?\r\n\u001b[?2004l\r\u001b[?2004h> # Ball y=0..7, bowls start at y=6\r\n\u001b[?2004l\r\u001b[?2004h> "]
