[1460.906688, "o", "4 rot bowls + ball: 10x20x6 = 1200\r\n  Voxels: 752\r\n"]
[1460.932369, "o", "  Donut1: perm=zxy signs=+++ offset=(0,2,0) size=1x8x4\r\n  Donut1: perm=zxy signs=+++ offset=(0,2,1) size=1x8x4\r\n  Donut1: perm=zxy signs=+++ offset=(0,2,2) size=1x8x4\r\n"]
[1460.933546, "o", "  Donut1: perm=zxy signs=++- offset=(0,2,0) size=1x8x4\r\n  Donut1: perm=zxy signs=++- offset=(0,2,1) size=1x8x4\r\n  Donut1 positions: 5\r\n\r\n  But still need 5th bowl! 12x4 extends to 12x20x6=1440\r\n  Or 4x12 at x=10 extends to 14x20x6=1680\r\n"]
