[392.458583, "o", "  z=1: ###### ###### ...... ...... \r\n  z=2: ...... ###### ###### ...... \r\n  z=3: ...... ...... ###### ###### \r\n  z=4: ...... ...... ...... ###### \r\n  z=5: ...... ...... ...... ###### \r\n  z=6: ...... ...... ...... ###### \r\n  z=7: ...... ...... ...... ###### \r\n  z=8: ...... ...... ###### ###### \r\n  z=9: ...... ###### ###### ...... \r\n  z=10: ###### ###### ...... ...... \r\n  z=11: ###### ...... ...... ...... \r\n\r\nXY footprints per z-slice:\r\n  z=0: 6 voxels\r\n  z=1: 12 voxels\r\n  z=2: 12 voxels\r\n  z=3: 12 voxels\r\n  z=4: 6 voxels\r\n  z=5: 6 voxels\r\n  z=6: 6 voxels\r\n  z=7: 6 voxels\r\n  z=8: 12 voxels\r\n  z=9: 12 voxels\r\n"]
