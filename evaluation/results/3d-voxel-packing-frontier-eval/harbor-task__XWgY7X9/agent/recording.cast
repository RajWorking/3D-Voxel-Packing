[290.813315, "o", "\r\n--- Alternative: bowls rotated to 4x12x6, nesting in x ---\r\nRotated bowl (4x12):\r\n  y= 0: #...\r\n  y= 1: ##..\r\n  y= 2: .##.\r\n  y= 3: ..##\r\n  y= 4: ...#\r\n  y= 5: ...#\r\n  y= 6: ...#\r\n  y= 7: ...#\r\n  y= 8: ..##\r\n  y= 9: .##.\r\n  y=10: ##..\r\n  y=11: #...\r\n  dx=1: overlap\r\n"]
[290.813339, "o", "  dx=2: 6x12 no overlap\r\n  dx=3: 7x12 no overlap\r\n"]
[290.81342, "o", "  dx=4: 8x12 no overlap\r\n"]
