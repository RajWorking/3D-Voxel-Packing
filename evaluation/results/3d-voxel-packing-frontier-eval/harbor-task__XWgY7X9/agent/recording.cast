[392.442754, "o", "\u001b[?2004h> "]
[392.442786, "o", "# The only way to preserve the U-shape for nesting is to keep\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.442843, "o", "# the bowl's opening direction as one of the XY axes.\r\n\u001b[?2004l\r"]
[392.442942, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.443068, "o", "# So bowls must be oriented with their U-shape in XY plane.\r\n\u001b[?2004l\r\u001b[?2004h> # The U-shape is 12x4 (or 4x12 if rotated).\r\n"]
[392.443084, "o", "\u001b[?2004l\r\u001b[?2004h"]
[392.443141, "o", "> # Extrusion is always along z.\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.443254, "o", "# Unless... I orient the U-shape in XZ or YZ plane!\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.443332, "o", "# perm=xyz, but with the extrusion along y instead of z.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.443398, "o", "# Original: uniform in z. If I swap y and z:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.443492, "o", "# perm=xzy: new_x=x, new_y=z, new_z=y\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.443589, "o", "# Shape: 12x6x4. Cross-section in XY is 12x6 SOLID. Not a U-shape.\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # What if I swap x and z?\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.443611, "o", "# perm=zyx: new_x=z, new_y=y, new_z=x\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.443702, "o", "# Shape: 6x4x12. Cross-section in XY is 6x4 SOLID (since original was uniform in z).\r\n\u001b[?2004l\r\u001b[?2004h"]
[392.443732, "o", "> "]
[392.443743, "o", "# Extrusion along new_z (=old x) for 12 units.\r\n\u001b[?2004l\r"]
[392.443819, "o", "\u001b[?2004h> "]
[392.443917, "o", "# But the cross-section varies with old x! The bowl is NOT uniform in x.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[392.443932, "o", "# So this gives a 6x4x12 shape where each z-slice is different.\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[392.444124, "o", "> "]
[392.44443, "o", "# Actually this is interesting! Let me compute what this looks like.\r\n"]
[392.444542, "o", "\u001b[?2004l\r\u001b[?2004h> print(\"Bowl with perm=zyx (swap x and z):\")\r\n"]
[392.444555, "o", "\u001b[?2004l\r"]
[392.444559, "o", "\u001b[?2004h"]
