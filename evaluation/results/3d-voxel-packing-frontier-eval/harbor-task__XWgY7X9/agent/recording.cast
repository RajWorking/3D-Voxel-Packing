[515.46385, "o", "for start in range(4, 10):\r\n\u001b[?2004l\r\u001b[?2004h>     all_bowl_xy = set()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.463998, "o", "    for i in range(5):\r\n\u001b[?2004l\r\u001b[?2004h>         for x,y in bowl_xy:\r\n\u001b[?2004l\r\u001b[?2004h>             all_bowl_xy.add((x, y + start + i*2))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.464102, "o", "    if all_bowl_xy & ball_all_xy:\r\n\u001b[?2004l\r\u001b[?2004h>         continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.4643, "o", "    combined = ball_all_xy | all_bowl_xy\r\n\u001b[?2004l\r"]
[515.464432, "o", "\u001b[?2004h>     min_x = min(x for x,y in combined)\r\n\u001b[?2004l\r"]
[515.464483, "o", "\u001b[?2004h>     max_x = max(x for x,y in combined)\r\n\u001b[?2004l\r"]
[515.464555, "o", "\u001b[?2004h> "]
[515.464661, "o", "    min_y = min(y for x,y in combined)\r\n\u001b[?2004l\r\u001b[?2004h>     max_y = max(y for x,y in combined)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.464793, "o", "    w = max_x - min_x + 1\r\n\u001b[?2004l\r\u001b[?2004h>     h = max_y - min_y + 1\r\n\u001b[?2004l\r\u001b[?2004h>     vol = w * h * 6\r\n\u001b[?2004l\r\u001b[?2004h> "]
[515.464941, "o", "    print(f\"All normal bowls start={start}: {w}x{h}x6 = {vol}\")\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
